{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"},"kind":"article","sections":[],"abstract":[{"type":"text","text":"Strategies for unit testing, integration testing, and mocking FlyHUD in your app."}],"metadata":{"modules":[{"name":"FlyHUD"}],"title":"Testing Guide","role":"article","roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"seeAlsoSections":[{"anchor":"Guides","generated":true,"identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices"],"title":"Guides"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flyhud\/testing"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Unit-Testing-HUD-Logic","level":2,"text":"Unit Testing HUD Logic"},{"type":"heading","anchor":"Testing-HUD-Display-State","level":3,"text":"Testing HUD Display State"},{"type":"codeListing","syntax":"swift","code":["import XCTest","@testable import FlyHUD","","@MainActor","final class HUDDisplayTests: XCTestCase {","    var containerView: UIView!","","    override func setUp() {","        super.setUp()","        containerView = UIView(frame: CGRect(x: 0, y: 0, width: 375, height: 812))","    }","","    override func tearDown() {","        containerView = nil","        super.tearDown()","    }","","    func testShowAddsHUDToView() {","        let hud = HUD.show(to: containerView, animated: false)","        XCTAssertTrue(containerView.subviews.contains(hud))","        hud.hide(animated: false)","    }","","    func testHideRemovesHUDFromView() {","        let hud = HUD.show(to: containerView, animated: false)","        hud.hide(animated: false)","        XCTAssertFalse(containerView.subviews.contains(hud))","    }","","    func testActivityCount() {","        let hud = HUD.show(to: containerView, animated: false)","        hud.isCountEnabled = true","","        hud.show(animated: false)  \/\/ count = 2","        hud.show(animated: false)  \/\/ count = 3","","        hud.hide(animated: false)  \/\/ count = 2","        XCTAssertTrue(containerView.subviews.contains(hud))","","        hud.hide(animated: false)  \/\/ count = 1","        XCTAssertTrue(containerView.subviews.contains(hud))","","        hud.hide(animated: false)  \/\/ count = 0, hides","        XCTAssertFalse(containerView.subviews.contains(hud))","    }","}"]},{"type":"heading","text":"Testing Content Configuration","anchor":"Testing-Content-Configuration","level":3},{"syntax":"swift","type":"codeListing","code":["@MainActor","func testLabelText() {","    let hud = HUD.show(to: containerView, animated: false, label: \"Loading\")","    XCTAssertEqual(hud.contentView.label.text, \"Loading\")","    hud.hide(animated: false)","}","","@MainActor","func testModeChange() {","    let hud = HUD.show(to: containerView, animated: false)","    hud.contentView.mode = .text","    XCTAssertTrue(hud.contentView.mode.isText)","    hud.hide(animated: false)","}","","@MainActor","func testProgressUpdate() {","    let hud = HUD.show(to: containerView, animated: false, mode: .progress(.default))","    hud.contentView.progress = 0.5","    XCTAssertEqual(hud.contentView.progress, 0.5)","    hud.hide(animated: false)","}"]},{"type":"heading","text":"Mocking HUD in App Tests","anchor":"Mocking-HUD-in-App-Tests","level":2},{"type":"paragraph","inlineContent":[{"identifier":"testing-mock.svg","type":"image"}]},{"type":"heading","text":"Protocol-Based Abstraction","anchor":"Protocol-Based-Abstraction","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Abstract HUD operations behind a protocol for testability:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ In your app code","@MainActor","protocol HUDDisplayable {","    func showLoading(on view: UIView, label: String?)","    func showSuccess(on view: UIView, label: String?)","    func showError(on view: UIView, label: String?)","    func hide(from view: UIView)","}","","@MainActor","final class RealHUDService: HUDDisplayable {","    func showLoading(on view: UIView, label: String?) {","        HUD.show(to: view, label: label)","    }","","    func showSuccess(on view: UIView, label: String?) {","        let image = UIImageView(image: UIImage(systemName: \"checkmark\"))","        HUD.showStatus(to: view, mode: .custom(image), label: label)","    }","","    func showError(on view: UIView, label: String?) {","        HUD.showStatus(to: view, mode: .text, label: label)","    }","","    func hide(from view: UIView) {","        HUD.hide(for: view)","    }","}"]},{"anchor":"Mock-Implementation-for-Tests","type":"heading","level":3,"text":"Mock Implementation for Tests"},{"syntax":"swift","type":"codeListing","code":["@MainActor","final class MockHUDService: HUDDisplayable {","    var showLoadingCalled = false","    var showSuccessCalled = false","    var showErrorCalled = false","    var hideCalled = false","    var lastLabel: String?","","    func showLoading(on view: UIView, label: String?) {","        showLoadingCalled = true","        lastLabel = label","    }","","    func showSuccess(on view: UIView, label: String?) {","        showSuccessCalled = true","        lastLabel = label","    }","","    func showError(on view: UIView, label: String?) {","        showErrorCalled = true","        lastLabel = label","    }","","    func hide(from view: UIView) {","        hideCalled = true","    }","}"]},{"anchor":"Using-the-Mock-in-Tests","level":3,"text":"Using the Mock in Tests","type":"heading"},{"syntax":"swift","type":"codeListing","code":["@MainActor","final class ViewModelTests: XCTestCase {","    func testFetchShowsAndHidesHUD() async {","        let mockHUD = MockHUDService()","        let viewModel = MyViewModel(hudService: mockHUD)","","        await viewModel.fetchData()","","        XCTAssertTrue(mockHUD.showLoadingCalled)","        XCTAssertTrue(mockHUD.hideCalled)","    }","}"]},{"level":2,"text":"Testing Animations","type":"heading","anchor":"Testing-Animations"},{"type":"paragraph","inlineContent":[{"text":"Animations are difficult to unit test directly. Use these strategies:","type":"text"}]},{"anchor":"Disable-Animations-in-Tests","level":3,"text":"Disable Animations in Tests","type":"heading"},{"code":["@MainActor","func testHideWithoutAnimation() {","    let hud = HUD.show(to: containerView, animated: false)","    hud.hide(animated: false)","    \/\/ Assert immediately — no animation delay","    XCTAssertTrue(hud.isHidden)","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"anchor":"Use-Animation-Style-none","text":"Use Animation Style `.none`"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: containerView, using: .animation(.none))","hud.hide(using: .animation(.none))"]},{"type":"heading","level":2,"anchor":"Testing-Delegates","text":"Testing Delegates"},{"syntax":"swift","type":"codeListing","code":["@MainActor","final class DelegateTests: XCTestCase, HUDDelegate {","    var hudDidHide = false","","    func hudWasHidden(_ hud: HUD) {","        hudDidHide = true","    }","","    func testDelegateCalledOnHide() {","        let hud = HUD.show(to: containerView, animated: false)","        hud.delegate = self","        hud.hide(animated: false)","        XCTAssertTrue(hudDidHide)","    }","}"]},{"type":"heading","level":2,"anchor":"Testing-Custom-Indicators","text":"Testing Custom Indicators"},{"type":"heading","level":3,"anchor":"ActivityIndicatorView-Tests","text":"ActivityIndicatorView Tests"},{"syntax":"swift","type":"codeListing","code":["@MainActor","func testActivityIndicatorStartStop() {","    let indicator = ActivityIndicatorView(style: .ringClipRotate)","    XCTAssertFalse(indicator.isAnimating)","","    indicator.startAnimating()","    XCTAssertTrue(indicator.isAnimating)","    XCTAssertFalse(indicator.isHidden)","","    indicator.stopAnimating()","    XCTAssertFalse(indicator.isAnimating)","    XCTAssertTrue(indicator.isHidden) \/\/ hidesWhenStopped = true","}"]},{"anchor":"ProgressView-Tests","level":3,"text":"ProgressView Tests","type":"heading"},{"syntax":"swift","type":"codeListing","code":["@MainActor","func testProgressViewBounds() {","    let progressView = ProgressView(style: .round)","    XCTAssertEqual(progressView.progress, 0.0)","","    progressView.progress = 0.75","    XCTAssertEqual(progressView.progress, 0.75)","}"]},{"anchor":"Test-Strategy","level":2,"text":"Test Strategy","type":"heading"},{"type":"paragraph","inlineContent":[{"identifier":"testing-strategy.svg","type":"image"}]},{"anchor":"Running-Tests","level":2,"text":"Running Tests","type":"heading"},{"anchor":"Command-Line","level":3,"text":"Command Line","type":"heading"},{"syntax":"bash","type":"codeListing","code":["# Run all unit tests",".\/scripts\/build.sh test","","# Run specific test class",".\/scripts\/build.sh test HUDTests","","# Run UI tests",".\/scripts\/build.sh test ui","","# SPM build (swift test not supported — UIKit unavailable on macOS CLI)",".\/scripts\/build.sh swift"]},{"level":3,"anchor":"Xcode","type":"heading","text":"Xcode"},{"inlineContent":[{"text":"Select the test target and press Cmd+U, or run individual tests via the test navigator.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Test Organization","level":2,"anchor":"Test-Organization"},{"code":["Tests\/","├── HUD\/","│   ├── HUDTests.swift              # Core show\/hide behavior","│   ├── HUDStressTests.swift        # Concurrent and stress scenarios","│   ├── ModelTests.swift            # Layout, Animation models","│   ├── Extensions\/                 # Extension tests","│   ├── Observables\/                # DisplayLink, Keyboard tests","│   ├── Protocols\/                  # Protocol conformance tests","│   └── Views\/                      # ContentView, BackgroundView tests","├── IndicatorHUD\/","│   └── ActivityIndicatorViewTests.swift","└── ProgressHUD\/","    └── ProgressViewTests.swift"],"syntax":"text","type":"codeListing"}]}],"references":{"doc://flyhud.FlyHUD/documentation/FlyHUD/advanced-features":{"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","kind":"article","title":"Advanced Features","abstract":[{"type":"text","text":"Explore keyboard tracking, animations, grace time, activity counts, and more."}],"url":"\/documentation\/flyhud\/advanced-features","role":"article","type":"topic"},"doc://flyhud.FlyHUD/documentation/FlyHUD/custom-ui":{"url":"\/documentation\/flyhud\/custom-ui","title":"Custom UI","role":"article","abstract":[{"type":"text","text":"Build custom activity indicators, progress views, and display modes."}],"kind":"article","type":"topic","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui"},"testing-strategy.svg":{"variants":[{"url":"\/images\/flyhud.FlyHUD\/testing-strategy.svg","svgID":"my-svg","traits":["1x","light"]}],"type":"image","identifier":"testing-strategy.svg","alt":"Flowchart showing test strategy decision tree: HUD display logic → use animated:false; Business logic → use Mock; Custom indicators → test state; Delegates → assert callbacks."},"doc://flyhud.FlyHUD/documentation/FlyHUD":{"type":"topic","title":"FlyHUD","role":"collection","kind":"symbol","url":"\/documentation\/flyhud","abstract":[{"type":"text","text":"A lightweight and easy-to-use HUD for displaying progress and status of ongoing tasks on iOS, tvOS, and visionOS."}],"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"},"doc://flyhud.FlyHUD/documentation/FlyHUD/best-practices":{"url":"\/documentation\/flyhud\/best-practices","title":"Best Practices","role":"article","abstract":[{"type":"text","text":"Recommended patterns for using FlyHUD effectively in production apps."}],"kind":"article","type":"topic","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices"},"doc://flyhud.FlyHUD/documentation/FlyHUD/swiftui-integration":{"title":"SwiftUI Integration","type":"topic","role":"article","url":"\/documentation\/flyhud\/swiftui-integration","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","kind":"article","abstract":[{"type":"text","text":"Use FlyHUD declaratively in SwiftUI with the "},{"type":"codeVoice","code":"FlyHUDSwiftUI"},{"type":"text","text":" module."}]},"testing-mock.svg":{"identifier":"testing-mock.svg","variants":[{"svgID":"my-svg","url":"\/images\/flyhud.FlyHUD\/testing-mock.svg","traits":["1x","light"]}],"type":"image","alt":"Class diagram showing HUDDisplayable protocol with RealHUDService (production) and MockHUDService (test) conformances, and ViewModel depending on the protocol."}}}