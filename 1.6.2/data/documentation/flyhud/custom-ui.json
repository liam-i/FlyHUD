{"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui"},"primaryContentSections":[{"content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following diagram shows the protocol hierarchy for custom indicators and progress views:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"custom-protocols.svg"}]},{"anchor":"Custom-Activity-Indicators","type":"heading","text":"Custom Activity Indicators","level":2},{"anchor":"Using-FlyIndicatorHUD-Built-in-Styles","type":"heading","text":"Using FlyIndicatorHUD Built-in Styles","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Import "},{"type":"codeVoice","code":"FlyIndicatorHUD"},{"type":"text","text":" to access pre-built indicator styles:"}]},{"code":["import FlyIndicatorHUD","","\/\/ Ring clip rotation","HUD.show(to: view, mode: .indicator(.ringClipRotate))","","\/\/ Ball spin fade","HUD.show(to: view, mode: .indicator(.ballSpinFade))","","\/\/ Circle stroke spin","HUD.show(to: view, mode: .indicator(.circleStrokeSpin))","","\/\/ Circle arc dot spin","HUD.show(to: view, mode: .indicator(.circleArcDotSpin))"],"type":"codeListing","syntax":"swift"},{"anchor":"Customizing-ActivityIndicatorView-Properties","type":"heading","text":"Customizing ActivityIndicatorView Properties","level":3},{"code":["let indicator = ActivityIndicatorView(style: .circleStrokeSpin)","indicator.color = .systemBlue","indicator.trackColor = UIColor.systemBlue.withAlphaComponent(0.2)","indicator.lineWidth = 3.0","","HUD.show(to: view, mode: .custom(indicator), label: \"Loading\")"],"type":"codeListing","syntax":"swift"},{"anchor":"Choosing-Your-Customization-Approach","type":"heading","text":"Choosing Your Customization Approach","level":3},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"custom-indicator-decision.svg"}]},{"anchor":"Implementing-ActivityIndicatorViewStyleable","type":"heading","text":"Implementing ActivityIndicatorViewStyleable","level":3},{"type":"paragraph","inlineContent":[{"text":"Create entirely custom indicator animations:","type":"text"}]},{"code":["struct PulseStyle: ActivityIndicatorViewStyleable {","    func isEqual(_ object: Any) -> Bool {","        object is PulseStyle","    }","","    func makeAnimation() -> ActivityIndicatorAnimationBuildable {","        PulseAnimation()","    }","","    var defaultSize: CGSize { CGSize(width: 40, height: 40) }","    var defaultColor: UIColor { .systemPurple }","    var defaultTrackColor: UIColor? { nil }","    var defaultLineWidth: CGFloat { 0 }","}","","struct PulseAnimation: ActivityIndicatorAnimationBuildable {","    func make(in layer: CALayer, color: UIColor, trackColor: UIColor?, lineWidth: CGFloat) {","        let circle = CAShapeLayer()","        circle.path = UIBezierPath(ovalIn: layer.bounds).cgPath","        circle.fillColor = color.cgColor","","        let animation = CABasicAnimation(keyPath: \"transform.scale\")","        animation.fromValue = 0.5","        animation.toValue = 1.0","        animation.duration = 0.8","        animation.autoreverses = true","        animation.repeatCount = .greatestFiniteMagnitude","        circle.add(animation, forKey: \"pulse\")","","        layer.addSublayer(circle)","    }","}","","\/\/ Usage","HUD.show(to: view, mode: .indicator(PulseStyle()))"],"type":"codeListing","syntax":"swift"},{"anchor":"Implementing-RotateViewable","type":"heading","text":"Implementing RotateViewable","level":3},{"inlineContent":[{"type":"text","text":"For simple rotation-based indicators, conform to "},{"type":"codeVoice","code":"RotateViewable"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["class SpinnerView: UIView, RotateViewable {","    var duration: CFTimeInterval { 0.5 }","","    override init(frame: CGRect) {","        super.init(frame: frame)","        \/\/ VoiceOver: ContentView handles accessibility for the HUD.","        \/\/ Custom indicators should not be separate focus elements.","        isAccessibilityElement = false","    }","","    required init?(coder: NSCoder) { fatalError() }","","    override var intrinsicContentSize: CGSize {","        CGSize(width: 37, height: 37)","    }","","    override func draw(_ rect: CGRect) {","        \/\/ Draw your custom shape","    }","}","","\/\/ Usage — rotation is handled automatically","let spinner = SpinnerView()","HUD.show(to: view, mode: .custom(spinner))"],"syntax":"swift"},{"type":"heading","anchor":"Custom-Progress-Views","level":2,"text":"Custom Progress Views"},{"type":"heading","anchor":"Using-FlyProgressHUD-Built-in-Styles","level":3,"text":"Using FlyProgressHUD Built-in Styles"},{"inlineContent":[{"type":"text","text":"Import "},{"type":"codeVoice","code":"FlyProgressHUD"},{"type":"text","text":" for pre-built progress styles:"}],"type":"paragraph"},{"type":"codeListing","code":["import FlyProgressHUD","","\/\/ Bar progress (butt cap)","HUD.show(to: view, mode: .progress(.buttBar))","","\/\/ Bar progress (round cap)","HUD.show(to: view, mode: .progress(.roundBar))","","\/\/ Circular progress ring","HUD.show(to: view, mode: .progress(.round))","","\/\/ Annular ring","HUD.show(to: view, mode: .progress(.annularRound))","","\/\/ Pie chart","HUD.show(to: view, mode: .progress(.pie))"],"syntax":"swift"},{"type":"heading","anchor":"Customizing-ProgressView-Properties","level":3,"text":"Customizing ProgressView Properties"},{"type":"codeListing","code":["let progressView = ProgressView(style: .annularRound)","progressView.progressTintColor = .systemGreen","progressView.trackTintColor = UIColor.systemGreen.withAlphaComponent(0.15)","progressView.lineWidth = 4.0","progressView.isLabelEnabled = true  \/\/ Show percentage text","progressView.labelFont = .boldSystemFont(ofSize: 12)","","let hud = HUD.show(to: view, mode: .custom(progressView))"],"syntax":"swift"},{"type":"heading","anchor":"Implementing-ProgressViewStyleable","level":3,"text":"Implementing ProgressViewStyleable"},{"inlineContent":[{"type":"text","text":"Create entirely custom progress animations:"}],"type":"paragraph"},{"type":"codeListing","code":["struct GradientBarStyle: ProgressViewStyleable {","    func isEqual(_ object: Any) -> Bool {","        object is GradientBarStyle","    }","","    func makeAnimation() -> ProgressAnimationBuildable {","        GradientBarAnimation()","    }","","    var defaultSize: CGSize { CGSize(width: 120, height: 12) }","    var defaultProgressTintColor: UIColor { .systemBlue }","    var defaultTrackTintColor: UIColor? { .systemGray5 }","    var defaultLineWidth: CGFloat { 0 }","    var defaultIsLabelEnabled: Bool { false }","    var defaultLabelFont: UIFont { .boldSystemFont(ofSize: 8) }","}","","struct GradientBarAnimation: ProgressAnimationBuildable {","    func makeShape(in layer: CALayer, progress: CGFloat, color: UIColor, trackColor: UIColor?, lineWidth: CGFloat) {","        let size = layer.bounds.size","        let radius = size.height \/ 2.0","","        \/\/ Track","        if let trackColor {","            let trackPath = UIBezierPath(roundedRect: layer.bounds, cornerRadius: radius)","            trackColor.setFill()","            trackPath.fill()","        }","","        \/\/ Progress fill","        let progressWidth = size.width * progress","        let progressRect = CGRect(x: 0, y: 0, width: progressWidth, height: size.height)","        let progressPath = UIBezierPath(roundedRect: progressRect, cornerRadius: radius)","        color.setFill()","        progressPath.fill()","    }","}"],"syntax":"swift"},{"type":"heading","anchor":"Implementing-ProgressViewable-Protocol","level":3,"text":"Implementing ProgressViewable Protocol"},{"inlineContent":[{"text":"For full control, implement ","type":"text"},{"type":"codeVoice","code":"ProgressViewable"},{"text":" on your own UIView subclass:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["class CustomProgressView: UIView, ProgressViewable {","    var progress: Float = 0.0 {","        didSet { setNeedsDisplay() }","    }","    var progressTintColor: UIColor? = .systemBlue","    var trackTintColor: UIColor? = .systemGray5","    var observedProgress: Progress?","","    override var intrinsicContentSize: CGSize {","        CGSize(width: 100, height: 100)","    }","","    override func draw(_ rect: CGRect) {","        \/\/ Your custom drawing","    }","}"],"syntax":"swift"},{"type":"heading","anchor":"Custom-Background-Styles","level":2,"text":"Custom Background Styles"},{"type":"heading","anchor":"Blur-Styles","level":3,"text":"Blur Styles"},{"type":"codeListing","code":["hud.contentView.style = .blur(.systemUltraThinMaterial)","hud.backgroundView.style = .blur(.systemMaterial)"],"syntax":"swift"},{"type":"heading","anchor":"Solid-Color","level":3,"text":"Solid Color"},{"type":"codeListing","code":["hud.contentView.style = .solidColor","hud.contentView.color = UIColor(white: 0.1, alpha: 0.9)"],"syntax":"swift"},{"type":"heading","anchor":"Liquid-Glass-iOS-26+","level":3,"text":"Liquid Glass (iOS 26+)"},{"type":"codeListing","code":["if #available(iOS 26.0, *) {","    hud.contentView.style = .glass","    hud.contentView.color = .systemBlue  \/\/ Glass tint color","}"],"syntax":"swift"},{"type":"heading","anchor":"Rounded-Corners","level":3,"text":"Rounded Corners"},{"type":"codeListing","code":["\/\/ Custom radius","hud.contentView.roundedCorners = .radius(12.0)","","\/\/ Fully rounded (capsule)","hud.contentView.roundedCorners = .full"],"syntax":"swift"},{"type":"heading","anchor":"Combining-Custom-Elements","level":2,"text":"Combining Custom Elements"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Build complex HUD configurations by combining elements:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Custom indicator with progress-style layout","let indicator = ActivityIndicatorView(style: .circleStrokeSpin)","indicator.color = .white","","let hud = HUD.show(to: view, mode: .custom(indicator)) { hud in","    hud.contentView.label.text = \"Syncing...\"","    hud.contentView.detailsLabel.text = \"3 of 10 files\"","    hud.contentView.contentColor = .white","    hud.contentView.style = .solidColor","    hud.contentView.color = UIColor.black.withAlphaComponent(0.85)","    hud.contentView.roundedCorners = .radius(16)","    hud.contentView.layout.hMargin = 24","    hud.contentView.layout.vMargin = 20","    hud.animation = .animation(.zoomInOut, damping: .default)","    hud.backgroundView.style = .solidColor","    hud.backgroundView.color = UIColor.black.withAlphaComponent(0.2)","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flyhud\/custom-ui"]}],"metadata":{"role":"article","modules":[{"name":"FlyHUD"}],"title":"Custom UI","roleHeading":"Article"},"abstract":[{"type":"text","text":"Build custom activity indicators, progress views, and display modes."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"seeAlsoSections":[{"generated":true,"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"]}],"sections":[],"references":{"doc://flyhud.FlyHUD/documentation/FlyHUD/advanced-features":{"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","kind":"article","title":"Advanced Features","abstract":[{"type":"text","text":"Explore keyboard tracking, animations, grace time, activity counts, and more."}],"url":"\/documentation\/flyhud\/advanced-features","role":"article","type":"topic"},"custom-indicator-decision.svg":{"alt":"Flowchart decision tree: Simple rotation → RotateViewable; Complex animation → ActivityIndicatorViewStyleable; Any UIView → .custom(view).","type":"image","identifier":"custom-indicator-decision.svg","variants":[{"traits":["1x","light"],"svgID":"my-svg","url":"\/images\/flyhud.FlyHUD\/custom-indicator-decision.svg"}]},"custom-protocols.svg":{"type":"image","alt":"Class diagram showing the relationships between ActivityIndicatorViewStyleable, ProgressViewStyleable, RotateViewable, ProgressViewable protocols and their concrete implementations.","variants":[{"traits":["1x","light"],"svgID":"my-svg","url":"\/images\/flyhud.FlyHUD\/custom-protocols.svg"}],"identifier":"custom-protocols.svg"},"doc://flyhud.FlyHUD/documentation/FlyHUD":{"type":"topic","title":"FlyHUD","role":"collection","kind":"symbol","url":"\/documentation\/flyhud","abstract":[{"type":"text","text":"A lightweight and easy-to-use HUD for displaying progress and status of ongoing tasks on iOS, tvOS, and visionOS."}],"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"},"doc://flyhud.FlyHUD/documentation/FlyHUD/best-practices":{"url":"\/documentation\/flyhud\/best-practices","title":"Best Practices","role":"article","abstract":[{"type":"text","text":"Recommended patterns for using FlyHUD effectively in production apps."}],"kind":"article","type":"topic","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices"},"doc://flyhud.FlyHUD/documentation/FlyHUD/swiftui-integration":{"title":"SwiftUI Integration","type":"topic","role":"article","url":"\/documentation\/flyhud\/swiftui-integration","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","kind":"article","abstract":[{"type":"text","text":"Use FlyHUD declaratively in SwiftUI with the "},{"type":"codeVoice","code":"FlyHUDSwiftUI"},{"type":"text","text":" module."}]},"doc://flyhud.FlyHUD/documentation/FlyHUD/testing":{"type":"topic","kind":"article","abstract":[{"type":"text","text":"Strategies for unit testing, integration testing, and mocking FlyHUD in your app."}],"title":"Testing Guide","role":"article","url":"\/documentation\/flyhud\/testing","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"}}}