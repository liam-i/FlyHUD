{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Explore keyboard tracking, animations, grace time, activity counts, and more."}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Animation-System","level":2,"text":"Animation System","type":"heading"},{"inlineContent":[{"text":"FlyHUD provides a rich animation system for showing and hiding the HUD.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"animation-states.svg"}],"type":"paragraph"},{"anchor":"Animation-Styles","level":3,"text":"Animation Styles","type":"heading"},{"inlineContent":[{"text":"Configure via ","type":"text"},{"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/HUD\/Animation-swift.struct","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Fade (default)","HUD.show(to: view, using: .animation(.fade))","","\/\/ Zoom in when appearing, zoom out when disappearing","HUD.show(to: view, using: .animation(.zoomInOut))","","\/\/ Slide up when appearing, slide down when disappearing","HUD.show(to: view, using: .animation(.slideUpDown))"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Available styles:"}],"type":"paragraph"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Style"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".none"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No animation"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".fade"}]}],[{"type":"paragraph","inlineContent":[{"text":"Opacity transition","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".zoomInOut","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Zoom in on show, zoom out on hide","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".zoomOutIn"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Zoom out on show, zoom in on hide"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".zoomIn","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always zoom in"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".zoomOut","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always zoom out"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideUpDown","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Slide up on show, slide down on hide"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideDownUp","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Slide down on show, slide up on hide","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".slideUp"}]}],[{"inlineContent":[{"type":"text","text":"Always slide up"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".slideDown"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Always slide down","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".slideRightLeft"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Slide right on show, slide left on hide","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".slideLeftRight"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Slide left on show, slide right on hide"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".slideRight","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Always slide right"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".slideLeft","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Always slide left","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"type":"heading","level":3,"text":"Spring Damping","anchor":"Spring-Damping"},{"type":"paragraph","inlineContent":[{"text":"Add bounce effects with spring damping:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Default damping (0.65)","HUD.show(to: view, using: .animation(.zoomInOut, damping: .default))","","\/\/ Custom damping ratio (lower = more bounce)","HUD.show(to: view, using: .animation(.slideUpDown, damping: .ratio(0.5)))","","\/\/ No damping (smooth deceleration)","HUD.show(to: view, using: .animation(.fade, damping: .disable))"]},{"type":"heading","level":3,"text":"Animation Duration","anchor":"Animation-Duration"},{"type":"codeListing","syntax":"swift","code":["HUD.show(to: view, using: .animation(.fade, duration: 0.5))"]},{"type":"heading","level":3,"text":"Per-Hide Animation","anchor":"Per-Hide-Animation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Override animation when hiding:"}]},{"type":"codeListing","syntax":"swift","code":["let hud = HUD.show(to: view, using: .animation(.slideUp))","","\/\/ Hide with a different animation","hud.hide(using: .animation(.slideDown))"]},{"type":"heading","level":2,"text":"Keyboard Layout Guide (iOS)","anchor":"Keyboard-Layout-Guide-iOS"},{"type":"paragraph","inlineContent":[{"text":"FlyHUD can automatically adjust its position when the keyboard appears.","type":"text"}]},{"level":3,"type":"heading","text":"Global Configuration","anchor":"Global-Configuration"},{"type":"paragraph","inlineContent":[{"text":"Set once in ","type":"text"},{"code":"AppDelegate","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"SceneDelegate","type":"codeVoice"},{"text":":","type":"text"}]},{"code":["\/\/ Center HUD in the visible area above keyboard","HUD.keyboardGuide = .center()","","\/\/ Center with vertical offset","HUD.keyboardGuide = .center(-20.0)","","\/\/ Keep content bottom above keyboard","HUD.keyboardGuide = .bottom(8.0)"],"syntax":"swift","type":"codeListing"},{"level":3,"type":"heading","text":"Per-Instance Configuration","anchor":"Per-Instance-Configuration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Override the global setting for individual HUDs:"}]},{"code":["let hud = HUD.show(to: view, label: \"Verifying...\")","hud.keyboardGuide = .center()"],"syntax":"swift","type":"codeListing"},{"level":3,"type":"heading","text":"Keyboard Guide Modes","anchor":"Keyboard-Guide-Modes"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Mode"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Behavior","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".disable","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No keyboard tracking (default)"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".center(offsetY)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Center HUD in visible area above keyboard"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".bottom(spacing)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Position content bottom relative to keyboard top"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Keyboard guide is only available on iOS. It has no effect on tvOS or visionOS."}]}]},{"level":2,"type":"heading","text":"Grace Time","anchor":"Grace-Time"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following diagram illustrates how "},{"type":"codeVoice","code":"graceTime"},{"type":"text","text":" and "},{"type":"codeVoice","code":"minShowTime"},{"type":"text","text":" interact:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"grace-time.svg"}]},{"type":"paragraph","inlineContent":[{"text":"Prevent HUD from appearing for very short tasks:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let hud = HUD(with: view)","hud.graceTime = 0.5  \/\/ Don't show if task completes within 0.5s","view.addSubview(hud)","hud.show()","","\/\/ If hide() is called within 0.5s, HUD never appears","DispatchQueue.main.asyncAfter(deadline: .now() + 0.3) {","    hud.hide()  \/\/ HUD was never shown","}"]},{"type":"aside","style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"graceTime"},{"type":"text","text":" must be set before calling "},{"type":"codeVoice","code":"show()"},{"type":"text","text":". The convenience"},{"type":"text","text":" "},{"type":"text","text":"method "},{"type":"codeVoice","code":"HUD.show(to:)"},{"type":"text","text":" does not support grace time — use manual initialization instead."}]}]},{"type":"heading","level":2,"text":"Minimum Show Time","anchor":"Minimum-Show-Time"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prevent HUD from flickering by enforcing a minimum display duration:"}]},{"type":"codeListing","syntax":"swift","code":["let hud = HUD(with: view)","hud.minShowTime = 1.0  \/\/ Show for at least 1 second","view.addSubview(hud)","hud.show()","","\/\/ Even if hide() is called immediately, HUD stays for 1s","hud.hide()"]},{"type":"heading","level":2,"text":"Activity Count","anchor":"Activity-Count"},{"type":"paragraph","inlineContent":[{"identifier":"activity-count.svg","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Track multiple show\/hide pairs with a reference counter:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let hud = HUD.show(to: view)","hud.isCountEnabled = true","","\/\/ Each show increments count","hud.show()  \/\/ count = 2","hud.show()  \/\/ count = 3","","\/\/ Each hide decrements count; HUD hides only when count reaches 0","hud.hide()  \/\/ count = 2, still visible","hud.hide()  \/\/ count = 1, still visible","hud.hide()  \/\/ count = 0, hides"]},{"type":"paragrap