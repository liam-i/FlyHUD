{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices"},"metadata":{"modules":[{"name":"FlyHUD"}],"role":"article","roleHeading":"Article","title":"Best Practices"},"kind":"article","abstract":[{"text":"Recommended patterns for using FlyHUD effectively in production apps.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Lifecycle Management","anchor":"Lifecycle-Management","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following diagram shows the recommended pattern for managing HUD lifecycle with async operations:"}]},{"type":"paragraph","inlineContent":[{"identifier":"best-practices-lifecycle.svg","type":"image"}]},{"type":"heading","text":"Always Hide Your HUDs","anchor":"Always-Hide-Your-HUDs","level":3},{"type":"paragraph","inlineContent":[{"text":"Ensure every ","type":"text"},{"type":"codeVoice","code":"show()"},{"text":" has a matching ","type":"text"},{"type":"codeVoice","code":"hide()"},{"text":" to prevent leaked HUD views:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view)","","Task {","    do {","        let result = try await fetchData()","        hud.contentView.mode = .custom(UIImageView(image: UIImage(systemName: \"checkmark\")))","        hud.contentView.label.text = \"Done\"","        hud.hide(afterDelay: 1.0)","    } catch {","        hud.contentView.mode = .text","        hud.contentView.label.text = \"Failed\"","        hud.hide(afterDelay: 2.0)","    }","}"]},{"type":"heading","text":"Use removeFromSuperViewOnHide","anchor":"Use-removeFromSuperViewOnHide","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"When using "},{"type":"codeVoice","code":"HUD.show(to:)"},{"type":"text","text":", the HUD is automatically removed from its superview"},{"text":" ","type":"text"},{"text":"on hide (default behavior). For manually created HUDs, set this explicitly:","type":"text"}]},{"type":"codeListing","code":["let hud = HUD(with: view)","hud.removeFromSuperViewOnHide = true","view.addSubview(hud)","hud.show()"],"syntax":"swift"},{"anchor":"Avoid-Retain-Cycles","type":"heading","level":3,"text":"Avoid Retain Cycles"},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"[weak self]"},{"text":" when referencing ","type":"text"},{"type":"codeVoice","code":"self"},{"text":" in completion blocks:","type":"text"}]},{"type":"codeListing","code":["hud.completionBlock = { [weak self] _ in","    self?.navigateToNextScreen()","}"],"syntax":"swift"},{"anchor":"View-Hierarchy","type":"heading","level":2,"text":"View Hierarchy"},{"anchor":"Choose-the-Right-Parent-View","type":"heading","level":3,"text":"Choose the Right Parent View"},{"type":"codeListing","code":["\/\/ Good: Add to the view controller's view","HUD.show(to: self.view)","","\/\/ Good: Add to a specific container","HUD.show(to: tableView)","","\/\/ Caution: Adding to window covers everything","HUD.show(to: view.window!)"],"syntax":"swift"},{"anchor":"Avoid-Adding-to-Scrollable-Views","type":"heading","level":3,"text":"Avoid Adding to Scrollable Views"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Adding a HUD to a "},{"type":"codeVoice","code":"UIScrollView"},{"type":"text","text":" or "},{"type":"codeVoice","code":"UITableView"},{"type":"text","text":" directly may cause"},{"type":"text","text":" "},{"type":"text","text":"unexpected behavior as the user scrolls. Prefer adding to the view controller’s view."}]},{"anchor":"AsyncAwait-Integration","type":"heading","level":2,"text":"Async\/Await Integration"},{"anchor":"With-Swift-Concurrency","type":"heading","level":3,"text":"With Swift Concurrency"},{"type":"codeListing","code":["@MainActor","func loadData() async {","    let hud = HUD.show(to: view)","","    do {","        let data = try await api.fetchItems()","        updateUI(with: data)","    } catch {","        showError(error)","    }","","    hud.hide()","}"],"syntax":"swift"},{"anchor":"With-URLSession","type":"heading","level":3,"text":"With URLSession"},{"type":"codeListing","code":["let hud = HUD.show(to: view, mode: .progress(.roundBar), label: \"Downloading\")","","let observation = task.progress.observe(\\.fractionCompleted) { progress, _ in","    DispatchQueue.main.async {","        hud.contentView.progress = Float(progress.fractionCompleted)","    }","}","","\/\/ Or use observedProgress for automatic binding","hud.contentView.observedProgress = task.progress"],"syntax":"swift"},{"anchor":"Grace-Time-Usage","type":"heading","level":2,"text":"Grace Time Usage"},{"type":"paragraph","inlineContent":[{"text":"Use grace time to avoid HUD flicker for fast operations:","type":"text"}]},{"type":"codeListing","code":["let hud = HUD(with: view)","hud.graceTime = 0.3          \/\/ Don't show for tasks < 300ms","hud.minShowTime = 0.5        \/\/ If shown, display for at least 500ms","hud.removeFromSuperViewOnHide = true","view.addSubview(hud)","hud.show()","","\/\/ Fast task — HUD never appears","DispatchQueue.main.asyncAfter(deadline: .now() + 0.1) {","    hud.hide()","}"],"syntax":"swift"},{"level":2,"anchor":"Activity-Count-Pattern","type":"heading","text":"Activity Count Pattern"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use activity counts for multi-source loading states:"}]},{"type":"codeListing","code":["class DataManager {","    private var hud: HUD?","","    func showLoading(on view: UIView) {","        if hud == nil {","            hud = HUD.show(to: view)","            hud?.isCountEnabled = true","        } else {","            hud?.show()","        }","    }","","    func hideLoading() {","        hud?.hide()","    }","}"],"syntax":"swift"},{"type":"heading","anchor":"Performance","text":"Performance","level":2},{"type":"heading","anchor":"Reuse-HUD-Instances","text":"Reuse HUD Instances","level":3},{"type":"paragraph","inlineContent":[{"text":"For repeated show\/hide cycles, reuse the same HUD instance:","type":"text"}]},{"type":"codeListing","code":["class ViewController: UIViewController {","    private lazy var hud: HUD = {","        let hud = HUD(with: view)","        hud.removeFromSuperViewOnHide = false","        view.addSubview(hud)","        return hud","    }()","","    func refresh() {","        hud.show()","        \/\/ ...","        hud.hide()","    }","}"],"syntax":"swift"},{"type":"heading","anchor":"Avoid-Unnecessary-Mode-Changes","text":"Avoid Unnecessary Mode Changes","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing "},{"code":"mode","type":"codeVoice"},{"type":"text","text":" tears down and rebuilds indicator views. Only change when needed:"}]},{"type":"codeListing","code":["\/\/ Avoid in tight loops","\/\/ ❌ hud.contentView.mode = .indicator(.large)  \/\/ every frame","","\/\/ ✅ Set once, update progress\/labels as needed","hud.contentView.progress = newValue"],"syntax":"swift"},{"type":"heading","anchor":"Error-Handling-Pattern","text":"Error Handling Pattern","level":2},{"type":"paragraph","inlineContent":[{"identifier":"error-handling-states.svg","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Transition HUD state on success\/failure:"}]},{"type":"codeListing","code":["let hud = HUD.show(to: view, label: \"Saving...\")","","saveDocument { result in","    switch result {","    case .success:","        let checkmark = UIImageView(image: UIImage(systemName: \"checkmark\"))","        hud.contentView.mode = .custom(checkmark)","        hud.contentView.label.text = \"Saved\"","        hud.hide(afterDelay: 1.5)","","    case .failure(let error):","        hud.contentView.mode = .text","        hud.contentView.label.text = \"Error\"","        hud.contentView.detailsLabel.text = error.localizedDescription","        hud.hide(afterDelay: 3.0)","    }","}"],"syntax":"swift"},{"type":"heading","anchor":"Accessibility","text":"Accessibility","level":2},{"type":"paragraph","inlineContent":[{"text":"FlyHUD provides comprehensive VoiceOver and accessibility support out of the box.","type":"text"}]},{"type":"heading","anchor":"VoiceOver-Architecture","text":"VoiceOver Architecture","level":3},{"type":"paragraph","inlineContent":[{"identifier":"accessibility-architecture.svg","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"FlyHUD uses a ","type":"text"},{"inlineContent":[{"type":"text","text":"single-element"}],"type":"strong"},{"text":" accessibility design:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"ContentView"},{"text":" is the sole VoiceOver focus element within the HUD","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"All child views (labels, buttons, indicators, progress views) are hidden from accessibility"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"VoiceOver reads a combined description of labels + progress status as one coherent announcement","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Button actions are exposed via ","type":"text"},{"code":"accessibilityCustomActions","type":"codeVoice"},{"text":" (swipe up\/down to discover)","type":"text"}]}]}]},{"inlineContent":[{"text":"The HUD automatically manages VoiceOver focus:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ When shown:  VoiceOver focus moves to HUD (via .screenChanged notification)","\/\/ When hidden: VoiceOver focus returns to underlying content","","let hud = HUD.show(to: view, mode: .indicator(), label: \"Loading...\")","\/\/ VoiceOver announces: \"Loading...\"","","hud.contentView.detailsLabel.text = \"Please wait\"","\/\/ VoiceOver re-reads: \"Loading..., Please wait\""],"type":"codeListing"},{"level":3,"anchor":"Escape-Gesture","text":"Escape Gesture","type":"heading"},{"inlineContent":[{"type":"text","text":"VoiceOver users can dismiss the HUD via the standard two-finger Z-scrub (escape) gesture."},{"type":"text","text":" "},{"type":"text","text":"This calls "},{"type":"codeVoice","code":"accessibilityPerformEscape()"},{"type":"text","text":" and hides the HUD with animation."}],"type":"paragraph"},{"level":3,"anchor":"Contextual-Hints","text":"Contextual Hints","type":"heading"},{"inlineContent":[{"code":"accessibilityHint","type":"codeVoice"},{"text":" provides mode-aware context to VoiceOver users:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Indicator modes: “Loading in progress”","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Progress modes: “Task in progress”"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Text-only modes: no hint (nil)"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Modal Focus Management","type":"heading","level":3,"anchor":"Modal-Focus-Management"},{"inlineContent":[{"text":"HUD sets ","type":"text"},{"code":"accessibilityViewIsModal = true","type":"codeVoice"},{"text":" to prevent VoiceOver from navigating","type":"text"},{"text":" ","type":"text"},{"text":"to elements behind the overlay. This is automatic — no configuration needed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"isEventDeliveryEnabled = true"},{"type":"text","text":" (touches pass through), "},{"type":"codeVoice","code":"accessibilityViewIsModal"},{"type":"text","text":" "},{"type":"text","text":"is automatically set to "},{"type":"codeVoice","code":"false"},{"type":"text","text":" so VoiceOver focus can reach underlying content."}],"type":"paragraph"},{"text":"Progress Announcements","type":"heading","level":3,"anchor":"Progress-Announcements"},{"inlineContent":[{"type":"text","text":"In progress mode, VoiceOver users receive periodic updates:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"accessibilityValue"},{"type":"text","text":" dynamically reports the current percentage (e.g., “45%”)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"accessibilityTraits"},{"type":"text","text":" includes "},{"type":"codeVoice","code":".updatesFrequently"},{"type":"text","text":" for progress\/indicator modes"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Milestone announcements are posted at 25% intervals (0%, 25%, 50%, 75%, 100%)","type":"text"}]}]}],"type":"unorderedList"},{"code":["let hud = HUD.show(to: view, mode: .progress(.round), label: \"Downloading\")","\/\/ VoiceOver announces: \"Downloading\" with value \"0%\"","","hud.contentView.progress = 0.5","\/\/ VoiceOver announces: \"50%\" (milestone notification)"],"type":"codeListing","syntax":"swift"},{"text":"Dynamic Type","type":"heading","level":3,"anchor":"Dynamic-Type"},{"inlineContent":[{"type":"text","text":"Enable Dynamic Type for HUD labels:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["hud.contentView.isDynamicTypeEnabled = true"]},{"level":3,"anchor":"Content-Color-Contrast","type":"heading","text":"Content Color Contrast"},{"inlineContent":[{"type":"text","text":"Ensure sufficient contrast between content and background:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Dark background with light text","hud.contentView.style = .solidColor","hud.contentView.color = UIColor(white: 0.1, alpha: 0.9)","hud.contentView.contentColor = .white"]},{"level":3,"anchor":"Custom-Views--Accessibility","type":"heading","text":"Custom Views & Accessibility"},{"inlineContent":[{"type":"text","text":"When using "},{"type":"codeVoice","code":".custom(UIView)"},{"type":"text","text":" mode, set "},{"type":"codeVoice","code":"isAccessibilityElement = false"},{"type":"text","text":" on your custom view"},{"type":"text","text":" "},{"type":"text","text":"to maintain the single-element pattern:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let checkmark = UIImageView(image: UIImage(systemName: \"checkmark\"))","checkmark.isAccessibilityElement = false  \/\/ Recommended","","HUD.show(to: view, mode: .custom(checkmark), label: \"Done\")","\/\/ VoiceOver announces: \"Done\" (not the image's default accessibility)"]},{"level":3,"anchor":"Button-Actions","type":"heading","text":"Button Actions"},{"inlineContent":[{"type":"text","text":"When a button is configured, VoiceOver exposes it via custom actions:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let hud = HUD.show(to: view, mode: .indicator(), label: \"Uploading...\")","hud.contentView.button.setTitle(\"Cancel\", for: .normal)","hud.contentView.button.addTarget(self, action: #selector(cancel), for: .touchUpInside)","\/\/ VoiceOver: Swipe up\/down to discover \"Cancel\" action"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flyhud\/best-practices"]}],"seeAlsoSections":[{"title":"Guides","anchor":"Guides","identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"],"generated":true}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"error-handling-states.svg":{"variants":[{"svgID":"my-svg","traits":["1x","light"],"url":"\/images\/flyhud.FlyHUD\/error-handling-states.svg"}],"type":"image","identifier":"error-handling-states.svg","alt":"State diagram showing HUD state transitions: Loading → Success (checkmark, short auto-hide) or Failure (text, longer auto-hide), both ending with completionBlock."},"doc://flyhud.FlyHUD/documentation/FlyHUD/testing":{"type":"topic","kind":"article","abstrac