{"abstract":[{"text":"A comprehensive introduction to FlyHUD’s architecture, capabilities, and use cases.","type":"text"}],"variants":[{"paths":["\/documentation\/flyhud\/overview"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"metadata":{"role":"article","title":"Overview","roleHeading":"Article","modules":[{"name":"FlyHUD"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"seeAlsoSections":[{"generated":true,"anchor":"Essentials","title":"Essentials","identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/getting-started","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/basic-features"]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/overview"},"kind":"article","primaryContentSections":[{"content":[{"level":2,"text":"SDK Positioning","type":"heading","anchor":"SDK-Positioning"},{"inlineContent":[{"text":"FlyHUD is a lightweight, high-performance HUD (Heads-Up Display) library for Apple platforms.","type":"text"},{"text":" ","type":"text"},{"text":"It serves as a drop-in solution for displaying transient status information — such as","type":"text"},{"text":" ","type":"text"},{"text":"loading spinners, progress bars, success\/error indicators, and toast messages — without","type":"text"},{"text":" ","type":"text"},{"text":"blocking the user interface or requiring complex view controller orchestration.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Core Design Principles","type":"heading","anchor":"Core-Design-Principles"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Minimal footprint"}]},{"type":"text","text":" — No external dependencies; pure UIKit"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Thread-safe API"}]},{"type":"text","text":" — All public methods are "},{"code":"@MainActor","type":"codeVoice"},{"type":"text","text":"-isolated"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Composable"}]},{"type":"text","text":" — Mix and match indicator, progress, and custom views"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Customizable"}]},{"type":"text","text":" — Fine-grained control over layout, animation, and appearance"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Accessible"}]},{"type":"text","text":" — Full VoiceOver support (modal focus, escape gesture, dynamic labels, contextual hints, progress announcements), Dynamic Type, and RTL layouts"}]}]}]},{"level":2,"text":"Architecture","type":"heading","anchor":"Architecture"},{"inlineContent":[{"text":"FlyHUD follows a modular architecture with clear dependency boundaries:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"architecture.svg"}],"type":"paragraph"},{"syntax":"text","type":"codeListing","code":["┌─────────────────────────────────────────────────┐","│                  Your App                        │","├────────────────┬────────────────┬───────────────┤","│ FlyIndicatorHUD│  FlyProgressHUD│ FlyHUDSwiftUI │","├────────────────┴────────────────┴───────────────┤","│                    FlyHUD                        │","│  ┌──────────┐ ┌───────────┐ ┌────────────────┐ │","│  │   HUD    │ │ContentView│ │ BackgroundView │ │","│  │ (root)   │ │(indicator,│ │ (blur, solid,  │ │","│  │          │ │ labels,   │ │  glass)        │ │","│  │          │ │ button)   │ │                │ │","│  └──────────┘ └───────────┘ └────────────────┘ │","│  ┌──────────────────────────────────────────┐   │","│  │  Observables: DisplayLink, Keyboard      │   │","│  └──────────────────────────────────────────┘   │","├─────────────────────────────────────────────────┤","│                    UIKit                         │","└─────────────────────────────────────────────────┘"]},{"level":3,"text":"Module Responsibilities","type":"heading","anchor":"Module-Responsibilities"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Module"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Target"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Responsibility"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"FlyHUD"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"FlyHUD"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Core HUD container, layout engine, animation system, background styles, keyboard tracking"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"FlyHUDSwiftUI"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"FlyHUDSwiftUI"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"SwiftUI declarative modifiers, UIKit bridge, convenience presets"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"FlyIndicatorHUD"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"FlyIndicatorHUD"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Custom activity indicator animations (ring, ball spin, circle stroke, arc dot)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"FlyProgressHUD"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"FlyProgressHUD"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Custom progress view styles (bar, round, annular, pie)"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"level":3,"text":"Dependency Direction","type":"heading","anchor":"Dependency-Direction"},{"syntax":"text","type":"codeListing","code":["FlyIndicatorHUD ──depends on──▶ FlyHUD ◀──depends on── FlyProgressHUD","                                  ▲","                                  │","                            FlyHUDSwiftUI"]},{"name":"Important","type":"aside","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"FlyHUD"},{"type":"text","text":" must never import "},{"type":"codeVoice","code":"FlyIndicatorHUD"},{"type":"text","text":", "},{"type":"codeVoice","code":"FlyProgressHUD"},{"type":"text","text":", or "},{"type":"codeVoice","code":"FlyHUDSwiftUI"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Reverse dependencies are strictly forbidden."}],"type":"paragraph"}],"style":"important"},{"level":2,"text":"View Hierarchy","type":"heading","anchor":"View-Hierarchy"},{"inlineContent":[{"text":"When displayed, a HUD instance creates the following view hierarchy:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"view-hierarchy.svg"}],"type":"paragraph"},{"syntax":"text","type":"codeListing","code":["UIView (superview)","└── HUD (full-screen overlay)","    ├── BackgroundView (blur\/solid\/glass)","    └── keyboardGuideView (keyboard offset container)","        └── ContentView (rounded card)","            ├── hStackView","            │   ├── indicator (UIView)","            │   └── vStackView","            │       ├── label (UILabel)","            │       ├── detailsLabel (UILabel)","            │       └── button (UIButton)","            └── ..."]},{"level":2,"text":"Interaction Flow","type":"heading","anchor":"Interaction-Flow"},{"inlineContent":[{"text":"The following sequence diagram illustrates a typical HUD show → update → hide cycle:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"sequence.svg"}],"type":"paragraph"},{"level":2,"text":"Use Cases","type":"heading","anchor":"Use-Cases"},{"level":3,"text":"Loading States","type":"heading","anchor":"Loading-States"},{"inlineContent":[{"text":"Display a spinner while fetching data, uploading files, or performing background work.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Progress Tracking","type":"heading","anchor":"Progress-Tracking"},{"inlineContent":[{"text":"Show determinate progress for downloads, uploads, file processing, or multi-step workflows.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Status Messages","type":"heading","anchor":"Status-Messages"},{"inlineContent":[{"text":"Show brief toast-style messages for success, error, or informational feedback.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Custom Indicators","type":"heading","anchor":"Custom-Indicators"},{"inlineContent":[{"text":"Display branded or app-specific indicator views with full animation control.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Platform Compatibility","type":"heading","anchor":"Platform-Compatibility"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Min Version"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Notes"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iOS"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"13.0+"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Full feature set"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"tvOS"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"13.0+"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No keyboard guide"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"visionOS"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1.0+"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No keyboard guide, no glass style"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"level":2,"text":"What’s Next","type":"heading","anchor":"Whats-Next"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/getting-started","isActive":true,"type":"refere