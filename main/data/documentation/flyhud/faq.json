{"kind":"article","abstract":[{"type":"text","text":"Frequently asked questions about FlyHUD."}],"sections":[],"metadata":{"modules":[{"name":"FlyHUD"}],"roleHeading":"Article","role":"article","title":"FAQ"},"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"General","anchor":"General"},{"level":3,"type":"heading","text":"What is the difference between FlyHUD, FlyIndicatorHUD, and FlyProgressHUD?","anchor":"What-is-the-difference-between-FlyHUD-FlyIndicatorHUD-and-FlyProgressHUD"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"FlyHUD","type":"text"}],"type":"strong"},{"text":" — The core module containing the ","type":"text"},{"type":"codeVoice","code":"HUD"},{"text":" class, layout system, animations,","type":"text"},{"text":" ","type":"text"},{"text":"and background views. This is all you need for system indicators and custom views.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"FlyIndicatorHUD"}],"type":"strong"},{"type":"text","text":" — Provides custom activity indicator styles (ring clip, ball spin,"},{"type":"text","text":" "},{"type":"text","text":"circle stroke, arc dot). Depends on FlyHUD."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"FlyProgressHUD"}],"type":"strong"},{"text":" — Provides custom progress view styles (bar, round, annular, pie).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Depends on FlyHUD."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can import only what you need. All three are independent of each other."}]},{"type":"heading","level":3,"text":"Why was it renamed from LPHUD to FlyHUD?","anchor":"Why-was-it-renamed-from-LPHUD-to-FlyHUD"},{"inlineContent":[{"text":"The library was renamed in version 1.5.6 to better reflect its nature: “Fly” implies","type":"text"},{"type":"text","text":" "},{"text":"fast, efficient, and flexible — consistent with the real-time nature of a HUD.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Does FlyHUD support SwiftUI?","anchor":"Does-FlyHUD-support-SwiftUI","level":3},{"inlineContent":[{"text":"Yes! The ","type":"text"},{"type":"codeVoice","code":"FlyHUDSwiftUI"},{"text":" module provides native SwiftUI support with declarative modifiers:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import FlyHUDSwiftUI","","MyView()","    .hudLoading(isPresented: $isLoading, label: \"Loading...\")"]},{"inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","type":"reference","isActive":true},{"type":"text","text":" for complete documentation covering all API layers."}],"type":"paragraph"},{"text":"Installation","anchor":"Installation","level":2,"type":"heading"},{"text":"Which module should I import?","level":3,"type":"heading","anchor":"Which-module-should-I-import"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Need"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Import","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"System spinner + custom views only"}]}],[{"inlineContent":[{"type":"codeVoice","code":"FlyHUD"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"SwiftUI declarative modifiers"}]}],[{"type":"paragraph","inlineContent":[{"code":"FlyHUDSwiftUI","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Custom indicator animations"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"FlyHUD"},{"text":" + ","type":"text"},{"code":"FlyIndicatorHUD","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Custom progress styles"}]}],[{"inlineContent":[{"type":"codeVoice","code":"FlyHUD"},{"type":"text","text":" + "},{"type":"codeVoice","code":"FlyProgressHUD"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"All features"}],"type":"paragraph"}],[{"inlineContent":[{"text":"All three","type":"text"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"text":"Can I use only CocoaPods subspecs?","level":3,"type":"heading","anchor":"Can-I-use-only-CocoaPods-subspecs"},{"type":"paragraph","inlineContent":[{"text":"Yes. Use subspecs to minimize dependencies:","type":"text"}]},{"syntax":"ruby","type":"codeListing","code":["pod 'FlyHUD', :subspecs => ['FlyHUD']           # Core only","pod 'FlyHUD', :subspecs => ['FlyIndicatorHUD']  # Core + indicators","pod 'FlyHUD', :subspecs => ['FlyProgressHUD']   # Core + progress"]},{"text":"Why do I get “No such module ‘FlyHUD’” in my Xcode project?","anchor":"Why-do-I-get-No-such-module-FlyHUD-in-my-Xcode-project","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Ensure you have:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Added the SPM package dependency correctly","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Added the library product to your target’s “Frameworks, Libraries, and Embedded Content”","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Cleaned build folder (Shift+Cmd+K) and rebuilt"}],"type":"paragraph"}]}]},{"anchor":"Usage","type":"heading","level":2,"text":"Usage"},{"anchor":"Why-does-my-HUD-stay-on-screen-forever","type":"heading","level":3,"text":"Why does my HUD stay on screen forever?"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every "},{"code":"show()","type":"codeVoice"},{"type":"text","text":" must be paired with a "},{"code":"hide()","type":"codeVoice"},{"type":"text","text":". Common causes:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Forgetting to call "},{"type":"codeVoice","code":"hide()"},{"type":"text","text":" on error paths"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Calling "},{"code":"hide()","type":"codeVoice"},{"type":"text","text":" on a different HUD instance"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Using ","type":"text"},{"code":"isCountEnabled = true","type":"codeVoice"},{"text":" without matching show\/hide pairs","type":"text"}]}]}]},{"level":3,"type":"heading","text":"Why does my HUD appear behind other views?","anchor":"Why-does-my-HUD-appear-behind-other-views"},{"inlineContent":[{"type":"text","text":"HUD is added as a subview of the view you specify. Ensure no other views are added"},{"type":"text","text":" "},{"type":"text","text":"after the HUD, or call "},{"type":"codeVoice","code":"view.bringSubviewToFront(hud)"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Why-doesnt-the-keyboard-guide-work","text":"Why doesn’t the keyboard guide work?"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Keyboard guide is iOS-only (not available on tvOS or visionOS)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Ensure ","type":"text"},{"code":"HUD.keyboardGuide","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"hud.keyboardGuide","type":"codeVoice"},{"text":" is set to ","type":"text"},{"code":".center()","type":"codeVoice"},{"text":" or ","type":"text"},{"code":".bottom()","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The keyboard must actually appear (test with a focused text field)"}],"type":"paragraph"}]}]},{"type":"heading","level":3,"anchor":"How-do-I-show-HUD-on-the-full-screen-over-navigation-bar","text":"How do I show HUD on the full screen (over navigation bar)?"},{"type":"paragraph","inlineContent":[{"text":"Add the HUD to the window instead of the view controller’s view:","type":"text"}]},{"type":"codeListing","code":["if let window = view.window {","    HUD.show(to: window)","}"],"syntax":"swift"},{"level":3,"text":"Can I show multiple HUDs simultaneously?","anchor":"Can-I-show-multiple-HUDs-simultaneously","type":"heading"},{"inlineContent":[{"type":"text","text":"Yes. Each "},{"type":"codeVoice","code":"HUD.show(to:)"},{"type":"text","text":" call creates a new HUD instance:"}],"type":"paragraph"},{"syntax":"swift","code":["let hud1 = HUD.show(to: view, label: \"Step 1\")","let hud2 = HUD.show(to: view, label: \"Step 2\")"],"type":"codeListing"},{"inlineContent":[{"text":"Use ","type":"text"},{"code":"HUD.hideAll(for:)","type":"codeVoice"},{"text":" to dismiss all at once.","type":"text"}],"type":"paragraph"},{"level":3,"text":"How do I update HUD content after showing?","anchor":"How-do-I-update-HUD-content-after-showing","type":"heading"},{"inlineContent":[{"type":"text","text":"Access the HUD’s "},{"type":"codeVoice","code":"contentView"},{"type":"text","text":" to update labels, mode, or progress:"}],"type":"paragraph"},{"syntax":"swift","code":["let hud = HUD.show(to: view)","\/\/ Later...","hud.contentView.label.text = \"Almost done...\"","hud.contentView.mode = .custom(checkmarkView)"],"type":"codeListing"},{"level":2,"text":"Appearance","anchor":"Appearance","type":"heading"},{"level":3,"text":"How do I change the HUD’s background transparency?","anchor":"How-do-I-change-the-HUDs-background-transparency","type":"heading"},{"syntax":"swift","code":["\/\/ Content card background","hud.contentView.color = UIColor.black.withAlphaComponent(0.7)","","\/\/ Full-screen overlay","hud.backgroundView.color = UIColor.black.withAlphaComponent(0.3)","hud.backgroundView.style = .solidColor"],"type":"codeListing"},{"level":3,"text":"How do I make the HUD larger\/smaller?","anchor":"How-do-I-make-the-HUD-largersmaller","type":"heading"},{"syntax":"swift","code":["\/\/ Set minimum size","hud.contentView.layout.minSize = CGSize(width: 150, height: 150)","","\/\/ Or adjust margins","hud.contentView.layout.hMargin = 30","hud.contentView.layout.vMargin = 30"],"type":"codeListing"},{"level":3,"text":"Can I use SF Symbols as custom views?","anchor":"Can-I-use-SF-Symbols-as-custom-views","type":"heading"},{"inlineContent":[{"text":"Yes:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let config = UIImage.SymbolConfiguration(pointSize: 30, weight: .medium)","let image = UIImage(systemName: \"wifi.exclamationmark\", withConfiguration: config)","let imageView = UIImageView(image: image)","HUD.showStatus(to: view, mode: .custom(imageView), label: \"No Connection\")"],"type":"codeListing"},{"level":2,"text":"Threading","anchor":"Threading","type":"heading"},{"level":3,"text":"Is FlyHUD thread-safe?","anchor":"Is-FlyHUD-thread-safe","type":"heading"},{"inlineContent":[{"type":"text","text":"All HUD APIs must be called on the main thread. The library uses "},{"code":"@MainActor","type":"codeVoice"},{"type":"text","text":" isolation"},{"type":"text","text":" "},{"type":"text","text":"and debug assertions to enforce this. Background work should dispatch to main before"},{"type":"text","text":" "},{"type":"text","text":"interacting with HUD:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["DispatchQueue.global().async {","    let result = heavyComputation()","    DispatchQueue.main.async {","        hud.contentView.label.text = result","        hud.hide()","    }","}"]},{"anchor":"Migration","type":"heading","level":2,"text":"Migration"},{"anchor":"How-do-I-migrate-from-MBProgressHUD","type":"heading","level":3,"text":"How do I migrate from MBProgressHUD?"},{"inlineContent":[{"type":"text","text":"FlyHUD is inspired by MBProgressHUD with a modernized API:"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"text","text":"MBProgressHUD"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"FlyHUD"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"MBProgressHUD.showAdded(to:animated:)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"HUD.show(to:animated:)","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"MBProgressHUD.hide(for:animated:)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"HUD.hide(for:animated:)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"hud.mode = .text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"hud.contentView.mode = .text","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"hud.label.text","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"hud.contentView.label.text","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"hud.progress"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"hud.contentView.progress"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"hud.bezelView"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"hud.contentView"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"hud.backgroundView"}]}],[{"type":"paragraph","inlineContent":[{"code":"hud.backgroundView","type":"codeVoice"}]}]]],"type":"table","header":"row"}]}],"variants":[{"paths":["\/documentation\/flyhud\/faq"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/faq"},"seeAlsoSections":[{"identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/privacy","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/benchmark","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/release-notes","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/CHANGELOG"],"generated":true,"title":"Reference","anchor":"Reference"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://flyhud.FlyHUD/documentation/FlyHUD/CHANGELOG":{"type":"topic","kin