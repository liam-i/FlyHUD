d)"}]}]}]},{"type":"heading","anchor":"How-do-I-show-HUD-on-the-full-screen-over-navigation-bar","level":3,"text":"How do I show HUD on the full screen (over navigation bar)?"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the HUD to the window instead of the view controller’s view:"}]},{"type":"codeListing","code":["if let window = view.window {","    HUD.show(to: window)","}"],"syntax":"swift"},{"type":"heading","anchor":"Can-I-show-multiple-HUDs-simultaneously","level":3,"text":"Can I show multiple HUDs simultaneously?"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes. Each "},{"type":"codeVoice","code":"HUD.show(to:)"},{"type":"text","text":" call creates a new HUD instance:"}]},{"type":"codeListing","code":["let hud1 = HUD.show(to: view, label: \"Step 1\")","let hud2 = HUD.show(to: view, label: \"Step 2\")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"HUD.hideAll(for:)"},{"type":"text","text":" to dismiss all at once."}]},{"type":"heading","anchor":"How-do-I-update-HUD-content-after-showing","level":3,"text":"How do I update HUD content after showing?"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Access the HUD’s "},{"type":"codeVoice","code":"contentView"},{"type":"text","text":" to update labels, mode, or progress:"}]},{"type":"codeListing","code":["let hud = HUD.show(to: view)","\/\/ Later...","hud.contentView.label.text = \"Almost done...\"","hud.contentView.mode = .custom(checkmarkView)"],"syntax":"swift"},{"type":"heading","anchor":"Appearance","level":2,"text":"Appearance"},{"type":"heading","anchor":"How-do-I-change-the-HUDs-background-transparency","level":3,"text":"How do I change the HUD’s background transparency?"},{"type":"codeListing","code":["\/\/ Content card background","hud.contentView.color = UIColor.black.withAlphaComponent(0.7)","","\/\/ Full-screen overlay","hud.backgroundView.color = UIColor.black.withAlphaComponent(0.3)"