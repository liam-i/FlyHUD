{"kind":"article","abstract":[{"type":"text","text":"Frequently asked questions about FlyHUD."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/faq"},"sections":[],"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"General","anchor":"General"},{"level":3,"type":"heading","text":"What is the difference between FlyHUD, FlyIndicatorHUD, and FlyProgressHUD?","anchor":"What-is-the-difference-between-FlyHUD-FlyIndicatorHUD-and-FlyProgressHUD"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"FlyHUD"}],"type":"strong"},{"text":" — The core module containing the ","type":"text"},{"code":"HUD","type":"codeVoice"},{"type":"text","text":" class, layout system, animations,"},{"type":"text","text":" "},{"type":"text","text":"and background views. This is all you need for system indicators and custom views."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"FlyIndicatorHUD"}],"type":"strong"},{"text":" — Provides custom activity indicator styles (ring clip, ball spin,","type":"text"},{"text":" ","type":"text"},{"text":"circle stroke, arc dot). Depends on FlyHUD.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"FlyProgressHUD"}]},{"type":"text","text":" — Provides custom progress view styles (bar, round, annular, pie)."},{"type":"text","text":" "},{"type":"text","text":"Depends on FlyHUD."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can import only what you need. All three are independent of each other."}]},{"level":3,"type":"heading","text":"Why was it renamed from LPHUD to FlyHUD?","anchor":"Why-was-it-renamed-from-LPHUD-to-FlyHUD"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The library was renamed in version 1.5.6 to better reflect its nature: “Fly” implies"},{"type":"text","text":" "},{"type":"text","text":"fast, efficient, and flexible — consistent with the real-time nature of a HUD."}]},{"level":3,"type":"heading","text":"Does FlyHUD support SwiftUI?","anchor":"Does-FlyHUD-support-SwiftUI"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes! The "},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"type":"text","text":" module provides native SwiftUI support with declarative modifiers:"}]},{"type":"codeListing","code":["import FlyHUDSwiftUI","","MyView()","    .hudLoading(isPresented: $isLoading, label: \"Loading...\")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","type":"reference","isActive":true},{"type":"text","text":" for complete documentation covering all API layers."}]},{"level":2,"type":"heading","text":"Installation","anchor":"Installation"},{"level":3,"type":"heading","text":"Which module should I import?","anchor":"Which-module-should-I-import"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Need"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Import"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"System spinner + custom views only"}]}],[{"type":"paragraph","inlineContent":[{"code":"FlyHUD","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"SwiftUI declarative modifiers"}]}],[{"type":"paragraph","inlineContent":[{"code":"FlyHUDSwiftUI","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Custom indicator animations"}]}],[{"type":"paragraph","inlineContent":[{"code":"FlyHUD","type":"codeVoice"},{"type":"text","text":" + "},{"code":"FlyIndicatorHUD","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Custom progress styles"}]}],[{"type":"paragraph","inlineContent":[{"code":"FlyHUD","type":"codeVoice"},{"type":"text","text":" + "},{"code":"FlyProgressHUD","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"All features"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All three"}]}]]]},{"level":3,"type":"heading","text":"Can I use only CocoaPods subspecs?","anchor":"Can-I-use-only-CocoaPods-subspecs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes. Use subspecs to minimize dependencies:"}]},{"type":"codeListing","code":["pod 'FlyHUD', :subspecs => ['FlyHUD']           # Core only","pod 'FlyHUD', :subspecs => ['FlyIndicatorHUD']  # Core + indicators","pod 'FlyHUD', :subspecs => ['FlyProgressHUD']   # Core + progress"],"syntax":"ruby"},{"level":3,"type":"heading","text":"Why do I get “No such module ‘FlyHUD’” in my Xcode project?","anchor":"Why-do-I-get-No-such-module-FlyHUD-in-my-Xcode-project"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Ensure you have:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Added the SPM package dependency correctly"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Added the library product to your target’s “Frameworks, Libraries, and Embedded Content”"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cleaned build folder (Shift+Cmd+K) and rebuilt"}]}]}]},{"level":2,"type":"heading","text":"Usage","anchor":"Usage"},{"level":3,"type":"heading","text":"Why does my HUD stay on screen forever?","anchor":"Why-does-my-HUD-stay-on-screen-forever"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every "},{"code":"show()","type":"codeVoice"},{"type":"text","text":" must be paired with a "},{"code":"hide()","type":"codeVoice"},{"type":"text","text":". Common causes:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Forgetting to call "},{"type":"codeVoice","code":"hide()"},{"type":"text","text":" on error paths"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"hide()"},{"type":"text","text":" on a different HUD instance"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Using "},{"type":"codeVoice","code":"isCountEnabled = true"},{"type":"text","text":" without matching show\/hide pairs"}]}]}]},{"level":3,"type":"heading","text":"Why does my HUD appear behind other views?","anchor":"Why-does-my-HUD-appear-behind-other-views"},{"type":"paragraph","inlineContent":[{"type":"text","text":"HUD is added as a subview of the view you specify. Ensure no other views are added"},{"type":"text","text":" "},{"type":"text","text":"after the HUD, or call "},{"code":"view.bringSubviewToFront(hud)","type":"codeVoice"},{"type":"text","text":"."}]},{"level":3,"type":"heading","text":"Why doesn’t the keyboard guide work?","anchor":"Why-doesnt-the-keyboard-guide-work"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Keyboard guide is iOS-only (not available on tvOS or visionOS)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Ensure "},{"type":"codeVoice","code":"HUD.keyboardGuide"},{"type":"text","text":" or "},{"type":"codeVoice","code":"hud.keyboardGuide"},{"type":"text","text":" is set to "},{"type":"codeVoice","code":".center()"},{"type":"text","text":" or "},{"type":"codeVoice","code":".bottom()"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The keyboard must actually appear (test with a focused text field)"}]}]}]},{"level":3,"type":"heading","text":"How do I show HUD on the full screen (over navigation bar)?","anchor":"How-do-I-show-HUD-on-the-full-screen-over-navigation-bar"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the HUD to the window instead of the view controller’s view:"}]},{"type":"codeListing","code":["if let window = view.window {","    HUD.show(to: window)","}"],"syntax":"swift"},{"level":3,"type":"heading","text":"Can I show multiple HUDs simultaneously?","anchor":"Can-I-show-multiple-HUDs-simultaneously"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes. Each "},{"code":"HUD.show(to:)","type":"codeVoice"},{"type":"text","text":" call creates a new HUD instance:"}]},{"type":"codeListing","code":["let hud1 = HUD.show(to: view, label: \"Step 1\")","let hud2 = HUD.show(to: view, label: \"Step 2\")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":"HUD.hideAll(for:)","type":"codeVoice"},{"type":"text","text":" to dismiss all at once."}]},{"level":3,"type":"heading","text":"How do I update HUD content after showing?","anchor":"How-do-I-update-HUD-content-after-showing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Access the HUD’s "},{"code":"contentView","type":"codeVoice"},{"type":"text","text":" to update labels, mode, or progress:"}]},{"type":"codeListing","code":["let hud = HUD.show(to: view)","\/\/ Later...","hud.contentView.label.text = \"Almost done...\"","hud.contentView.mode = .custom(checkmarkView)"],"syntax":"swift"},{"level":2,"type":"heading","text":"Appearance","anchor":"Appearance"},{"level":3,"type":"heading","text":"How do I change the HUD’s background transparency?","anchor":"How-do-I-change-the-HUDs-background-transparency"},{"type":"codeListing","code":["\/\/ Content card background","hud.contentView.color = UIColor.black.withAlphaComponent(0.7)","","\/\/ Full-screen overlay","hud.backgroundView.color = UIColor.black.withAlphaComponent(0.3)","hud.backgroundView.style = .solidColor"],"syntax":"swift"},{"level":3,"type":"heading","text":"How do I make the HUD larger\/smaller?","anchor":"How-do-I-make-the-HUD-largersmaller"},{"type":"codeListing","code":["\/\/ Set minimum size","hud.contentView.layout.minSize = CGSize(width: 150, height: 150)","","\/\/ Or adjust margins","hud.contentView.layout.hMargin = 30","hud.contentView.layout.vMargin = 30"],"syntax":"swift"},{"level":3,"type":"heading","text":"Can I use SF Symbols as custom views?","anchor":"Can-I-use-SF-Symbols-as-custom-views"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Yes:"}]},{"type":"codeListing","code":["let config = UIImage.SymbolConfiguration(pointSize: 30, weight: .medium)","let image = UIImage(systemName: \"wifi.exclamationmark\", withConfiguration: config)","let imageView = UIImageView(image: image)","HUD.showStatus(to: view, mode: .custom(imageView), label: \"No Connection\")"],"syntax":"swift"},{"level":2,"type":"heading","text":"Threading","anchor":"Threading"},{"level":3,"type":"heading","text":"Is FlyHUD thread-safe?","anchor":"Is-FlyHUD-thread-safe"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All HUD APIs must be called on the main thread. The library uses "},{"code":"@MainActor","type":"codeVoice"},{"type":"text","text":" isolation"},{"type":"text","text":" "},{"type":"text","text":"and debug assertions to enforce this. Background work should dispatch to main before"},{"type":"text","text":" "},{"type":"text","text":"interacting with HUD:"}]},{"type":"codeListing","code":["DispatchQueue.global().async {","    let result = heavyComputation()","    DispatchQueue.main.async {","        hud.contentView.label.text = result","        hud.hide()","    }","}"],"syntax":"swift"},{"level":2,"type":"heading","text":"Migration","anchor":"Migration"},{"level":3,"type":"heading","text":"How do I migrate from MBProgressHUD?","anchor":"How-do-I-migrate-from-MBProgressHUD"},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD is inspired by MBProgressHUD with a modernized API:"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"MBProgressHUD"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD"}]}]],[[{