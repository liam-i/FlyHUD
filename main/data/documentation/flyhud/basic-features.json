 5 seconds","HUD.showStatus(to: view, duration: 5.0, label: \"Processing complete\")"]},{"level":3,"type":"heading","text":"Hide with Delay","anchor":"Hide-with-Delay"},{"type":"codeListing","syntax":"swift","code":["hud.hide(afterDelay: 1.5)"]},{"level":3,"type":"heading","text":"Class-Level Hide","anchor":"Class-Level-Hide"},{"type":"paragraph","inlineContent":[{"text":"Find and hide HUDs by their parent view:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Hide the top-most HUD","HUD.hide(for: view)","","\/\/ Hide all HUDs on a view","HUD.hideAll(for: view)"]},{"level":2,"type":"heading","text":"Labels","anchor":"Labels"},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD provides two labels for displaying text:"}]},{"type":"codeListing","syntax":"swift","code":["let hud = HUD.show(to: view)","hud.contentView.label.text = \"Loading...\"","hud.contentView.detailsLabel.text = \"Please wait while we process your request\""]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"label"}]},{"type":"text","text":" — Primary text (bold, single line by default)"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"detailsLabel","type":"text"}]},{"type":"text","text":" — Secondary text (smaller, multi-line)"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Button","anchor":"Button","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"A button is included in the content view. It’s visible only when a title and action are set:","type":"text"}]},{"code":["let hud = HUD.show(to: view, label: \"Downloading\")","hud.contentView.button.setTitle(\"Cancel\", for: .normal)","hud.contentView.button.addTarget(self, action: #selector(cancelDownload), for: .touchUpInside)"],"type":"codeListing","syntax":"swift"},{"text":"Progress Tracking","anchor":"Progress-Tracking","type":"heading","level":2},{"text":"Manual Progress","anchor":"M