{"metadata":{"roleHeading":"Article","modules":[{"name":"FlyHUD"}],"role":"article","title":"Basic Features"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"identifier":"basic-lifecycle.svg","type":"image"}]},{"text":"Display Modes","type":"heading","level":2,"anchor":"Display-Modes"},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD supports four primary display modes through "},{"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/ContentView\/Mode-swift.enum","type":"reference","isActive":true},{"type":"text","text":":"}]},{"text":"Text Only","type":"heading","level":3,"anchor":"Text-Only"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Displays labels and an optional button without any indicator:"}]},{"type":"codeListing","syntax":"swift","code":["HUD.showStatus(to: view, mode: .text, label: \"Network error\")"]},{"text":"System Activity Indicator","type":"heading","level":3,"anchor":"System-Activity-Indicator"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Uses "},{"type":"codeVoice","code":"UIActivityIndicatorView"},{"type":"text","text":" with configurable style:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Large spinner (default)","HUD.show(to: view, mode: .indicator(.large))","","\/\/ Medium spinner","HUD.show(to: view, mode: .indicator(.medium))"]},{"type":"heading","level":3,"text":"System Progress View","anchor":"System-Progress-View"},{"type":"paragraph","inlineContent":[{"text":"Uses ","type":"text"},{"type":"codeVoice","code":"UIProgressView"},{"text":" with configurable style:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let hud = HUD.show(to: view, mode: .progress(.default))","hud.contentView.progress = 0.75"]},{"type":"heading","level":3,"text":"Custom View","anchor":"Custom-View"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Display any "},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" as the HUD indicator:"}]},{"type":"codeListing","syntax":"swift","code":["let imageView = UIImageView(image: UIImage(systemName: \"checkmark.circle\"))","HUD.show(to: view, mode: .custom(imageView), label: \"Success\")"]},{"type":"heading","level":2,"text":"Show and Hide","anchor":"Show-and-Hide"},{"anchor":"Basic-ShowHide","type":"heading","level":3,"text":"Basic Show\/Hide"},{"syntax":"swift","type":"codeListing","code":["\/\/ Show with default animation","let hud = HUD.show(to: view)","","\/\/ Hide with default animation","hud.hide()"]},{"type":"heading","level":3,"text":"Animated vs. Immediate","anchor":"Animated-vs-Immediate"},{"type":"codeListing","syntax":"swift","code":["\/\/ Show without animation","let hud = HUD.show(to: view, animated: false)","","\/\/ Hide without animation","hud.hide(animated: false)"]},{"type":"heading","level":3,"text":"Auto-Hide with Duration","anchor":"Auto-Hide-with-Duration"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"showStatus"},{"type":"text","text":" automatically hides after a specified duration:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Hides after 2 seconds (default)","HUD.showStatus(to: view, label: \"Saved\")","","\/\/ Hides after 5 seconds","HUD.showStatus(to: view, duration: 5.0, label: \"Processing complete\")"]},{"type":"heading","level":3,"text":"Hide with Delay","anchor":"Hide-with-Delay"},{"type":"codeListing","syntax":"swift","code":["hud.hide(afterDelay: 1.5)"]},{"type":"heading","level":3,"text":"Class-Level Hide","anchor":"Class-Level-Hide"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Find and hide HUDs by their parent view:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Hide the top-most HUD","HUD.hide(for: view)","","\/\/ Hide all HUDs on a view","HUD.hideAll(for: view)"]},{"text":"Labels","type":"heading","level":2,"anchor":"Labels"},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD provides two labels for displaying text:"}]},{"type":"codeListing","syntax":"swift","code":["let hud = HUD.show(to: view)","hud.contentView.label.text = \"Loading...\"","hud.contentView.detailsLabel.text = \"Please wait while we process your request\""]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"label"}]},{"type":"text","text":" — Primary text (bold, single line by default)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"detailsLabel"}]},{"type":"text","text":" — Secondary text (smaller, multi-line)"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Button","type":"heading","level":2,"anchor":"Button"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A button is included in the content view. It’s visible only when a title and action are set:"}]},{"type":"codeListing","syntax":"swift","code":["let hud = HUD.show(to: view, label: \"Downloading\")","hud.contentView.button.setTitle(\"Cancel\", for: .normal)","hud.contentView.button.addTarget(self, action: #selector(cancelDownload), for: .touchUpInside)"]},{"text":"Progress Tracking","type":"heading","level":2,"anchor":"Progress-Tracking"},{"text":"Manual Progress","type":"heading","level":3,"anchor":"Manual-Progress"},{"type":"codeListing","syntax":"swift","code":["let hud = HUD.show(to: view, mode: .progress(.default))","hud.contentView.progress = 0.0","","\/\/ Update as work progresses","hud.contentView.progress = 0.5","hud.contentView.progress = 1.0"]},{"text":"Observed Progress","type":"heading","level":3,"anchor":"Observed-Progress"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Bind to a "},{"type":"codeVoice","code":"Progress"},{"type":"text","text":" object for automatic updates:"}]},{"type":"codeListing","syntax":"swift","code":["let hud = HUD.show(to: view, mode: .progress(.default))","hud.contentView.observedProgress = myProgress","","\/\/ Labels auto-update from Progress.localizedDescription","\/\/ and Progress.localizedAdditionalDescription"]},{"text":"Content View Layout","type":"heading","level":2,"anchor":"Content-View-Layout"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"content-layout.svg"}]},{"text":"Background Styles","type":"heading","level":2,"anchor":"Background-Styles"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Configure the HUD background via "},{"type":"reference","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/BackgroundView","isActive":true},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["let hud = HUD.show(to: view)","","\/\/ Blur (default)","hud.contentView.style = .blur(.systemThickMaterial)","","\/\/ Solid color","hud.contentView.style = .solidColor","hud.contentView.color = UIColor.black.withAlphaComponent(0.8)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The full-screen overlay background is also configurable:"}]},{"type":"codeListing","syntax":"swift","code":["hud.backgroundView.style = .solidColor","hud.backgroundView.color = UIColor.black.withAlphaComponent(0.3)"]},{"text":"Indicator Position","type":"heading","level":2,"anchor":"Indicator-Position"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Control where the indicator appears relative to labels:"}]},{"type":"codeListing","syntax":"swift","code":["let hud = HUD.show(to: view, mode: .custom(myImage), label: \"Done\")","","\/\/ Position options: .top (default), .bottom, .leading, .trailing","hud.contentView.indicatorPosition = .leading"]},{"text":"Content Color","type":"heading","level":2,"anchor":"Content-Color"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set a unified color for all content (labels, indicator, button):"}]},{"type":"codeListing","syntax":"swift","code":["hud.contentView.contentColor = .white"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to manage each element’s color individually."}]},{"text":"Populator Block","type":"heading","level":2,"anchor":"Populator-Block"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the trailing closure to configure HUD properties inline:"}]},{"type":"codeListing","syntax":"swift","code":["HUD.show(to: view, mode: .indicator(.large), label: \"Loading\") { hud in","    hud.contentView.detailsLabel.text = \"Fetching data...\"","    hud.contentView.contentColor = .systemBlue","    hud.layout.offset = .zero","}"]},{"text":"Finding HUDs","type":"heading","level":2,"anchor":"Finding-HUDs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Retrieve existing HUDs from a view:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Get all active HUDs","let allHuds = HUD.huds(for: view)","","\/\/ Get the top-most HUD","if let topHud = HUD.lastHUD(for: view) {","    topHud.contentView.label.text = \"Almost done...\"","}"]},{"text":"Delegate & Completion","type":"heading","level":2,"anchor":"Delegate--Completion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Get notified when a HUD finishes hiding:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Via delegate","hud.delegate = self","","\/\/ Via completion block","hud.completionBlock = { hud in","    print(\"HUD was hidden\")","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement "},{"type":"codeVoice","code":"HUDDelegate"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["func hudWasHidden(_ hud: HUD) {","    \/\/ Clean up or navigate","}"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flyhud\/basic-features"]}],"kind":"article","identifier":{"url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/basic-features","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"seeAlsoSections":[{"anchor":"Essentials","gener