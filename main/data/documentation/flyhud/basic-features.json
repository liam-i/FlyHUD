{"kind":"article","seeAlsoSections":[{"anchor":"Essentials","title":"Essentials","generated":true,"identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/overview","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/getting-started"]}],"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Learn the fundamental display modes, configurations, and lifecycle of FlyHUD."}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"inlineContent":[{"identifier":"basic-lifecycle.svg","type":"image"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Display-Modes","text":"Display Modes"},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD supports four primary display modes through "},{"isActive":true,"type":"reference","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/ContentView\/Mode-swift.enum"},{"type":"text","text":":"}]},{"type":"heading","level":3,"text":"Text Only","anchor":"Text-Only"},{"inlineContent":[{"type":"text","text":"Displays labels and an optional button without any indicator:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["HUD.showStatus(to: view, mode: .text, label: \"Network error\")"]},{"text":"System Activity Indicator","level":3,"type":"heading","anchor":"System-Activity-Indicator"},{"inlineContent":[{"type":"text","text":"Uses "},{"code":"UIActivityIndicatorView","type":"codeVoice"},{"type":"text","text":" with configurable style:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Large spinner (default)","HUD.show(to: view, mode: .indicator(.large))","","\/\/ Medium spinner","HUD.show(to: view, mode: .indicator(.medium))"]},{"text":"System Progress View","level":3,"type":"heading","anchor":"System-Progress-View"},{"inlineContent":[{"type":"text","text":"Uses "},{"code":"UIProgressView","type":"codeVoice"},{"type":"text","text":" with configurable style:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view, mode: .progress(.default))","hud.contentView.progress = 0.75"]},{"text":"Custom View","level":3,"type":"heading","anchor":"Custom-View"},{"inlineContent":[{"type":"text","text":"Display any "},{"code":"UIView","type":"codeVoice"},{"type":"text","text":" as the HUD indicator:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let imageView = UIImageView(image: UIImage(systemName: \"checkmark.circle\"))","HUD.show(to: view, mode: .custom(imageView), label: \"Success\")"]},{"text":"Show and Hide","level":2,"type":"heading","anchor":"Show-and-Hide"},{"text":"Basic Show\/Hide","level":3,"type":"heading","anchor":"Basic-ShowHide"},{"syntax":"swift","type":"codeListing","code":["\/\/ Show with default animation","let hud = HUD.show(to: view)","","\/\/ Hide with default animation","hud.hide()"]},{"text":"Animated vs. Immediate","level":3,"type":"heading","anchor":"Animated-vs-Immediate"},{"syntax":"swift","type":"codeListing","code":["\/\/ Show without animation","let hud = HUD.show(to: view, animated: false)","","\/\/ Hide without animation","hud.hide(animated: false)"]},{"text":"Auto-Hide with Duration","level":3,"type":"heading","anchor":"Auto-Hide-with-Duration"},{"inlineContent":[{"code":"showStatus","type":"codeVoice"},{"type":"text","text":" automatically hides after a specified duration:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Hides after 2 seconds (default)","HUD.showStatus(to: view, label: \"Saved\")","","\/\/ Hides after 5 seconds","HUD.showStatus(to: view, duration: 5.0, label: \"Processing complete\")"]},{"text":"Hide with Delay","level":3,"type":"heading","anchor":"Hide-with-Delay"},{"syntax":"swift","type":"codeListing","code":["hud.hide(afterDelay: 1.5)"]},{"text":"Class-Level Hide","level":3,"type":"heading","anchor":"Class-Level-Hide"},{"inlineContent":[{"type":"text","text":"Find and hide HUDs by their parent view:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Hide the top-most HUD","HUD.hide(for: view)","","\/\/ Hide all HUDs on a view","HUD.hideAll(for: view)"]},{"text":"Labels","level":2,"type":"heading","anchor":"Labels"},{"inlineContent":[{"type":"text","text":"FlyHUD provides two labels for displaying text:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view)","hud.contentView.label.text = \"Loading...\"","hud.contentView.detailsLabel.text = \"Please wait while we process your request\""]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"label","type":"text"}]},{"type":"text","text":" — Primary text (bold, single line by default)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"detailsLabel","type":"text"}]},{"type":"text","text":" — Secondary text (smaller, multi-line)"}],"type":"paragraph"}]}]},{"text":"Button","level":2,"type":"heading","anchor":"Button"},{"inlineContent":[{"type":"text","text":"A button is included in the content view. It’s visible only when a title and action are set:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view, label: \"Downloading\")","hud.contentView.button.setTitle(\"Cancel\", for: .normal)","hud.contentView.button.addTarget(self, action: #selector(cancelDownload), for: .touchUpInside)"]},{"text":"Progress Tracking","level":2,"type":"heading","anchor":"Progress-Tracking"},{"text":"Manual Progress","level":3,"type":"heading","anchor":"Manual-Progress"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view, mode: .progress(.default))","hud.contentView.progress = 0.0","","\/\/ Update as work progresses","hud.contentView.progress = 0.5","hud.contentView.progress = 1.0"]},{"text":"Observed Progress","level":3,"type":"heading","anchor":"Observed-Progress"},{"inlineContent":[{"type":"text","text":"Bind to a "},{"code":"Progress","type":"codeVoice"},{"type":"text","text":" object for automatic updates:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view, mode: .progress(.default))","hud.contentView.observedProgress = myProgress","","\/\/ Labels auto-update from Progress.localizedDescription","\/\/ and Progress.localizedAdditionalDescription"]},{"text":"Content View Layout","level":2,"type":"heading","anchor":"Content-View-Layout"},{"inlineContent":[{"identifier":"content-layout.svg","type":"image"}],"type":"paragraph"},{"text":"Background Styles","level":2,"type":"heading","anchor":"Background-Styles"},{"inlineContent":[{"type":"text","text":"Configure the HUD background via "},{"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/BackgroundView","type":"reference","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view)","","\/\/ Blur (default)","hud.contentView.style = .blur(.systemThickMaterial)","","\/\/ Solid color","hud.contentView.style = .solidColor","hud.contentView.color = UIColor.black.withAlphaComponent(0.8)"]},{"inlineContent":[{"type":"text","text":"The full-screen overlay background is also configurable:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["hud.backgroundView.style = .solidColor","hud.backgroundView.color = UIColor.black.withAlphaComponent(0.3)"]},{"text":"Indicator Position","level":2,"type":"heading","anchor":"Indicator-Position"},{"inlineContent":[{"type":"text","text":"Control where the indicator appears relative to labels:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view, mode: .custom(myImage), label: \"Done\")","","\/\/ Position options: .top (default), .bottom, .leading, .trailing","hud.contentView.indicatorPosition = .leading"]},{"text":"Content Color","level":2,"type":"heading","anchor":"Content-Color"},{"inlineContent":[{"type":"text","text":"Set a unified color for all content (labels, indicator, button):"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["hud.contentView.contentColor = .white"]},{"inlineContent":[{"type":"text","text":"Set to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to manage each element’s color individually."}],"type":"paragraph"},{"text":"Populator Block","level":2,"type":"heading","anchor":"Populator-Block"},{"inlineContent":[{"type":"text","text":"Use the trailing closure to configure HUD properties inline:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["HUD.show(to: view, mode: .indicator(.large), label: \"Loading\") { hud in","    hud.contentView.detailsLabel.text = \"Fetching data...\"","    hud.contentView.contentColor = .systemBlue","    hud.layout.offset = .zero","}"]},{"text":"Finding HUDs","level":2,"type":"heading","anchor":"Finding-HUDs"},{"inlineContent":[{"type":"text","text":"Retrieve existing HUDs from a view:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Get all active HUDs","let allHuds = HUD.huds(for: view)","","\/\/ Get the top-most HUD","if let topHud = HUD.lastHUD(for: view) {","    topHud.contentView.label.text = \"Almost done...\"","}"]},{"text":"Delegate & Completion","level":2,"type":"heading","anchor":"Delegate--Completion"},{"inlineContent":[{"type":"text","text":"Get notified when a HUD finishes hiding:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Via delegate","hud.delegate = self","","\/\/ Via completion block","hud.completionBlock = { hud in","    print(\"HUD was hidden\")","}"]},{"inlineContent":[{"type":"text","text":"Implement "},{"code":"HUDDelegate","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func hudWasHidden(_ hud: HUD) {","    \/\/ Clean up or navigate","}"