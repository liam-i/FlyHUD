{"abstract":[{"text":"Recommended patterns for using FlyHUD effectively in production apps.","type":"text"}],"variants":[{"paths":["\/documentation\/flyhud\/best-practices"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"identifier":{"url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","interfaceLanguage":"swift"},"kind":"article","sections":[],"metadata":{"role":"article","title":"Best Practices","modules":[{"name":"FlyHUD"}],"roleHeading":"Article"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Lifecycle-Management","text":"Lifecycle Management","type":"heading"},{"inlineContent":[{"text":"The following diagram shows the recommended pattern for managing HUD lifecycle with async operations:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"best-practices-lifecycle.svg"}],"type":"paragraph"},{"level":3,"anchor":"Always-Hide-Your-HUDs","text":"Always Hide Your HUDs","type":"heading"},{"inlineContent":[{"text":"Ensure every ","type":"text"},{"type":"codeVoice","code":"show()"},{"text":" has a matching ","type":"text"},{"type":"codeVoice","code":"hide()"},{"text":" to prevent leaked HUD views:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let hud = HUD.show(to: view)","","Task {","    do {","        let result = try await fetchData()","        hud.contentView.mode = .custom(UIImageView(image: UIImage(systemName: \"checkmark\")))","        hud.contentView.label.text = \"Done\"","        hud.hide(afterDelay: 1.0)","    } catch {","        hud.contentView.mode = .text","        hud.contentView.label.text = \"Failed\"","        hud.hide(afterDelay: 2.0)","    }","}"],"type":"codeListing"},{"level":3,"anchor":"Use-removeFromSuperViewOnHide","text":"Use removeFromSuperViewOnHide","type":"heading"},{"inlineContent":[{"text":"When using ","type":"text"},{"type":"codeVoice","code":"HUD.show(to:)"},{"text":", the HUD is automatically removed from its superview","type":"text"},{"text":" ","type":"text"},{"text":"on hide (default behavior). For manually created HUDs, set this explicitly:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let hud = HUD(with: view)","hud.removeFromSuperViewOnHide = true","view.addSubview(hud)","hud.show()"],"type":"codeListing"},{"level":3,"anchor":"Avoid-Retain-Cycles","text":"Avoid Retain Cycles","type":"heading"},{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"[weak self]"},{"text":" when referencing ","type":"text"},{"type":"codeVoice","code":"self"},{"text":" in completion blocks:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["hud.completionBlock = { [weak self] _ in","    self?.navigateToNextScreen()","}"],"type":"codeListing"},{"level":2,"anchor":"View-Hierarchy","text":"View Hierarchy","type":"heading"},{"level":3,"anchor":"Choose-the-Right-Parent-View","text":"Choose the Right Parent View","type":"heading"},{"syntax":"swift","code":["\/\/ Good: Add to the view controller's view","HUD.show(to: self.view)","","\/\/ Good: Add to a specific container","HUD.show(to: tableView)","","\/\/ Caution: Adding to window covers everything","HUD.show(to: view.window!)"],"type":"codeListing"},{"level":3,"anchor":"Avoid-Adding-to-Scrollable-Views","text":"Avoid Adding to Scrollable Views","type":"heading"},{"inlineContent":[{"text":"Adding a HUD to a ","type":"text"},{"type":"codeVoice","code":"UIScrollView"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"UITableView"},{"text":" directly may cause","type":"text"},{"text":" ","type":"text"},{"text":"unexpected behavior as the user scrolls. Prefer adding to the view controller’s view.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"AsyncAwait-Integration","text":"Async\/Await Integration","type":"heading"},{"level":3,"anchor":"With-Swift-Concurrency","text":"With Swift Concurrency","type":"heading"},{"syntax":"swift","code":["@MainActor","func loadData() async {","    let hud = HUD.show(to: view)","","    do {","        let data = try await api.fetchItems()","        updateUI(with: data)","    } catch {","        showError(error)","    }","","    hud.hide()","}"],"type":"codeListing"},{"level":3,"anchor":"With-URLSession","text":"With URLSession","type":"heading"},{"syntax":"swift","code":["let hud = HUD.show(to: view, mode: .progress(.roundBar), label: \"Downloading\")","","let observation = task.progress.observe(\\.fractionCompleted) { progress, _ in","    DispatchQueue.main.async {","        hud.contentView.progress = Float(progress.fractionCompleted)","    }","}","","\/\/ Or use observedProgress for automatic binding","hud.contentView.observedProgress = task.progress"],"type":"codeListing"},{"level":2,"anchor":"Grace-Time-Usage","text":"Grace Time Usage","type":"heading"},{"inlineContent":[{"text":"Use grace time to avoid HUD flicker for fast operations:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let hud = HUD(with: view)","hud.graceTime = 0.3          \/\/ Don't show for tasks < 300ms","hud.minShowTime = 0.5        \/\/ If shown, display for at least 500ms","hud.removeFromSuperViewOnHide = true","view.addSubview(hud)","hud.show()","","\/\/ Fast task — HUD never appears","DispatchQueue.main.asyncAfter(deadline: .now() + 0.1) {","    hud.hide()","}"],"type":"codeListing"},{"level":2,"anchor":"Activity-Count-Pattern","text":"Activity Count Pattern","type":"heading"},{"inlineContent":[{"text":"Use activity counts for multi-source loading states:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class DataManager {","    private var hud: HUD?","","    func showLoading(on view: UIView) {","        if hud == nil {","            hud = HUD.show(to: view)","            hud?.isCountEnabled = true","        } else {","            hud?.show()","        }","    }","","    func hideLoading() {","        hud?.hide()","    }","}"],"type":"codeListing"},{"level":2,"anchor":"Performance","text":"Performance","type":"heading"},{"level":3,"anchor":"Reuse-HUD-Instances","text":"Reuse HUD Instances","type":"heading"},{"inlineContent":[{"text":"For repeated show\/hide cycles, reuse the same HUD instance:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class ViewController: UIViewController {","    private lazy var hud: HUD = {","        let hud = HUD(with: view)","        hud.removeFromSuperViewOnHide = false","        view.addSubview(hud)","        return hud","    }()","","    func refresh() {","        hud.show()","        \/\/ ...","        hud.hide()","    }","}"],"type":"codeListing"},{"level":3,"anchor":"Avoid-Unnecessary-Mode-Changes","text":"Avoid Unnecessary Mode Changes","type":"heading"},{"inlineContent":[{"text":"Changing ","type":"text"},{"type":"codeVoice","code":"mode"},{"text":" tears down and rebuilds indicator views. Only change when needed:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Avoid in tight loops","\/\/ ❌ hud.contentView.mode = .indicator(.large)  \/\/ every frame","","\/\/ ✅ Set once, update progress\/labels as needed","hud.contentView.progress = newValue"],"type":"codeListing"},{"level":2,"anchor":"Error-Handling-Pattern","text":"Error Handling Pattern","type":"heading"},{"inlineContent":[{"type":"image","identifier":"error-handling-states.svg"}],"type":"paragraph"},{"inlineContent":[{"text":"Transition HUD state on success\/failure:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let hud = HUD.show(to: view, label: \"Saving...\")","","saveDocument { result in","    switch result {","    case .success:","        let checkmark = UIImageView(image: UIImage(systemName: \"checkmark\"))","        hud.contentView.mode = .custom(checkmark)","        hud.contentView.label.text = \"Saved\"","        hud.hide(afterDelay: 1.5)","","    case .failure(let error):","        hud.contentView.mode = .text","        hud.contentView.label.text = \"Error\"","        hud.contentView.detailsLabel.text = error.localizedDescription","        hud.hide(afterDelay: 3.0)","    }","}"],"type":"codeListing"},{"level":2,"anchor":"Accessibility","text":"Accessibility","type":"heading"},{"inlineContent":[{"text":"FlyHUD provides comprehensive VoiceOver and accessibility support out of the box.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"VoiceOver-Architecture","text":"VoiceOver Architecture","type":"heading"},{"inlineContent":[{"type":"image","identifier":"accessibility-architecture.svg"}],"type":"paragraph"},{"inlineContent":[{"text":"FlyHUD uses a ","type":"text"},{"inlineContent":[{"text":"single-element","type":"text"}],"type":"strong"},{"text":" accessibility design:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"ContentView"},{"text":" is the sole VoiceOver focus element within the HUD","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"All child views (labels, buttons, indicators, progress views) are hidden from accessibility","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"VoiceOver reads a combined description of labels + progress status as one coherent announcement","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Button actions are exposed via ","type":"text"},{"type":"codeVoice","code":"accessibilityCustomActions"},{"text":" (swipe up\/down to discover)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The HUD automatically manages VoiceOver focus:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ When shown:  VoiceOver focus moves to HUD (via .screenChanged notification)","\/\/ When hidden: VoiceOver focus returns to underlying content","","let hud = HUD.show(to: view, mode: .indicator(), label: \"Loading...\")","\/\/ VoiceOver announces: \"Loading...\"","","hud.contentView.detailsLabel.text = \"Please wait\"","\/\/ VoiceOver re-reads: \"Loading..., Please wait\""],"type":"codeListing"},{"level":3,"anchor":"Escape-Gesture","text":"Escape Gesture","type":"heading"},{"inlineContent":[{"text":"VoiceOver users can dismiss the HUD via the standard two-finger Z-scrub (escape) gesture.","type":"text"},{"text":" ","type":"text"},{"text":"This calls ","type":"text"},{"type":"codeVoice","code":"accessibilityPerformEscape()"},{"text":" and hides the HUD with animation.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Contextual-Hints","text":"Contextual Hints","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"accessibilityHint"},{"text":" provides mode-aware context to VoiceOver users:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Indicator modes: “Loading in progress”","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Progress modes: “Task in progress”","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Text-only modes: no hint (nil)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"anchor":"Modal-Focus-Management","text":"Modal Focus Management","type":"heading"},{"inlineContent":[{"text":"HUD sets ","type":"text"},{"type":"codeVoice","code":"accessibilityViewIsModal = true"},{"text":" to prevent VoiceOver from navigating","type":"text"},{"text":" ","type":"text"},{"text":"to elements behind the overlay. This is automatic — no configuration needed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When ","type":"text"},{"type":"codeVoice","code":"isEventDeliveryEnabled = true"},{"text":" (touches pass through), ","type":"text"},{"type":"codeVoice","code":"accessibilityViewIsModal"},{"text":" ","type":"text"},{"text":"is automatically set to ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" so VoiceOver focus can reach underlying content.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Progress-Announcements","text":"Progress Announcements","type":"heading"},{"inlineContent":[{"text":"In progress mode, VoiceOver users receive periodic updates:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"accessibilityValue"},{"text":" dynamically reports the current percentage (e.g., “45%”)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"accessibilityTraits"},{"text":" includes ","type":"text"},{"type":"codeVoice","code":".updatesFrequently"},{"text":" for progress\/indicator modes","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Milestone announcements are posted at 25% intervals (0%, 25%, 50%, 75%, 100%)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":"swift","code":["let hud = HUD.show(to: view, mode: .progress(.round), label: \"Downloading\")","\/\/ VoiceOver announces: \"Downloading\" with value \"0%\"","","hud.contentView.progress = 0.5","\/\/ VoiceOver announces: \"50%\" (milestone notification)"],"type":"codeListing"},{"level":3,"anchor":"Dynamic-Type","text":"Dynamic Type","type":"heading"},{"inlineContent":[{"text":"Enable Dynamic Type for HUD labels:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["hud.contentView.isDynamicTypeEnabled = true"],"type":"codeListing"},{"level":3,"anchor":"Content-Color-Contrast","text":"Content Color Contrast","type":"heading"},{"inlineContent":[{"text":"Ensure sufficient contrast between content and background:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Dark background with light text","hud.contentView.style = .solidColor","hud.contentView.color = UIColor(white: 0.1, alpha: 0.9)","hud.contentView.contentColor = .white"],"type":"codeListing"},{"level":3,"anchor":"Custom-Views--Accessibility","text":"Custom Views & Accessibility","type":"heading"},{"inlineContent":[{"text":"When using ","type":"text"},{"type":"codeVoice","code":".custom(UIView)"},{"text":" mode, set ","type":"text"},{"type":"codeVoice","code":"isAccessibilityElement = false"},{"text":" on your custom view","type":"text"},{"text":" ","type":"text"},{"text":"to maintain the single-element pattern:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let checkmark = UIImageView(image: UIImage(systemName: \"checkmark\"))","checkmark.isAccessibilityElement = false  \/\/ Recommended","","HUD.show(to: view, mode: .custom(checkmark), label: \"Done\")","\/\/ VoiceOver announces: \"Done\" (not the image's default accessibility)"],"type":"codeListing"},{"level":3,"anchor":"Button-Actions","text":"Button Actions","type":"heading"},{"inlineContent":[{"text":"When a button is configured, VoiceOver exposes it via custom actions:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let hud = HUD.show(to: view, mode: .indicator(), label: \"Uploading...\")","hud.contentView.button.setTitle(\"Cancel\", for: .normal)","hud.contentView.button.addTarget(self, action: #selector(cancel), for: .touchUpInside)","\/\/ VoiceOver: Swipe up\/down to discover \"Cancel\" action"],"type":"codeListing"}]}],"seeAlsoSections":[{"anchor":"Guides","title":"Guides","generated":true,"identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"]}],"references":{"doc://flyhud.FlyHUD/documentation/FlyHUD/swiftui-integration":{"abstract":[{"type":"text","text":"Use FlyHUD declaratively in SwiftUI with the "},{"type":"codeVoice","code":"FlyHUDSwiftUI"},{"type":"text","text":" module."}],"role":"article","url":"\/documentation\/flyhud\/swiftui-integration","title":"SwiftUI Integration","type":"topic","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","kind":"article"},"accessibility-architecture.svg":{"alt":"Diagram showing the single-element accessibility pattern where ContentView is the sole VoiceOver focus element","type":"image","identifier":"accessibility-architecture.svg","variants":[{"svgID":"my-svg","url":"\/images\/flyhud.FlyHUD\/accessibility-architecture.svg","traits":["1x","light"]}]},"best-practices-lifecycle.svg":{"alt":"Sequence diagram showing ViewController starting a HUD, performing an async task, then transitioning to success or failure state before auto-hiding.","type":"image","identifier":"best-practices-lifecycle.svg","variants":[{"traits":["1x","light"],"svgID":"my-svg","url":"\/images\/flyhud.FlyHUD\/best-practices-lifecycle.svg"}]},"doc://flyhud.FlyHUD/documentation/FlyHUD/advanced-features":{"abstract":[{"text":"Explore keyboard tracking, animations, grace time, activity counts, and more.","type":"text"}],"role":"article","url":"\/documentation\/flyhud\/advanced-features","title":"Advanced Features","type":"topic","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","kind":"article"},"doc://flyhud.FlyHUD/documentation/FlyHUD/custom-ui":{"abstract":[{"text":"Build custom activity indicators, progress views, and display modes.","type":"text"}],"role":"article","url":"\/documentation\/flyhud\/custom-ui","title":"Custom UI","type":"topic","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","kind":"article"},"doc://flyhud.FlyHUD/documentation/FlyHUD/testing":{"kind":"article","type":"topic","abstract":[{"type":"text","text":"Strategies for unit testing, integration testing, and mocking FlyHUD in your app."}],"role":"article","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing","title":"Testing Guide","url":"\/documentation\/flyhud\/testing"},"doc://flyhud.FlyHUD/documentation/FlyHUD":{"abstract":[{"text":"A lightweight and easy-to-use HUD for displaying progress and status of ongoing tasks on iOS, tvOS, and visionOS.","type":"text"}],"role":"collection","title":"FlyHUD","url":"\/documentation\/flyhud","type":"topic","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD","kind":"symbol"},"error-handling-states.svg":{"alt":"State diagram showing HUD state transitions: Loading → Success (checkmark, short auto-hide) or Failure (text, longer auto-hide), both ending with completionBlock.","type":"image","identifier":"error-handling-states.svg","variants":[{"svgID":"my-svg","url":"\/images\/flyhud.FlyHUD\/error-handling-states.svg","traits":["1x","light"]}]}}}