if hud == nil {","            hud = HUD.show(to: view)","            hud?.isCountEnabled = true","        } else {","            hud?.show()","        }","    }","","    func hideLoading() {","        hud?.hide()","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"anchor":"Performance","text":"Performance"},{"type":"heading","level":3,"anchor":"Reuse-HUD-Instances","text":"Reuse HUD Instances"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For repeated show\/hide cycles, reuse the same HUD instance:"}]},{"code":["class ViewController: UIViewController {","    private lazy var hud: HUD = {","        let hud = HUD(with: view)","        hud.removeFromSuperViewOnHide = false","        view.addSubview(hud)","        return hud","    }()","","    func refresh() {","        hud.show()","        \/\/ ...","        hud.hide()","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"anchor":"Avoid-Unnecessary-Mode-Changes","text":"Avoid Unnecessary Mode Changes"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing "},{"type":"codeVoice","code":"mode"},{"type":"text","text":" tears down and rebuilds indicator views. Only change when needed:"}]},{"code":["\/\/ Avoid in tight loops","\/\/ ❌ hud.contentView.mode = .indicator(.large)  \/\/ every frame","","\/\/ ✅ Set once, update progress\/labels as needed","hud.contentView.progress = newValue"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"anchor":"Error-Handling-Pattern","text":"Error Handling Pattern"},{"type":"paragraph","inlineContent":[{"identifier":"error-handling-states.svg","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Transition HUD state on success\/failure:"}]},{"code":["let hud = HUD.show(to: view, label: \"Saving...\")","","saveDocument { result in","    switch result {","    case .success:","        let checkmark = UIImageView(image: UIImage(systemName: \"checkmark\"))","        hud.contentView.mode = .custom(checkmark)","        hud.contentView.label.text = \"Saved\"","        hud.hide(afterDelay: 1.5)","","    case .failure(let error):","        hud.contentView.mode = .text","        hud.contentView.label.text = \"Error\"","        hud.contentView.detailsLabel.text = error.localizedDescription","        hud.hide(afterDelay: 3.0)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"anchor":"Accessibility","text":"Accessibility"},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD provides comprehensive VoiceOver and accessibility support out of the box."}]},{"type":"heading","level":3,"anchor":"VoiceOver-Architecture","text":"VoiceOver Architecture"},{"type":"paragraph","inlineContent":[{"identifier":"accessibility-architecture.svg","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD uses a "},{"type":"strong","inlineContent":[{"type":"text","text":"single-element"}]},{"type":"text","text":" accessibility design:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"ContentView","type":"codeVoice"},{"text":" is the sole VoiceOver focus element within the HUD","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"All child views (labels, buttons, indicators, progress views) are hidden from accessibility","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"VoiceOver reads a combined description of labels + progress status as one coherent announcement","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Button actions are exposed via ","type":"text"},{"code":"accessibilityCustomActions","type":"codeVoice"},{"text":" (swipe up\/down to discover)","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The HUD automatically manages VoiceOver focus:"}]},{"code":["\/\/ When shown:  VoiceOver focus moves to HUD (via .screenChanged notification)","\/\/ When hidden: VoiceOver focus returns to underlying content","","let hud = HUD.show(to: view, mode: .indicator(), label: \"Loading...\")","\/\/ VoiceOver announces: \"Loading...\"","","hud.contentView.detailsLabel.text = \"Please wait\"","\/\/ VoiceOver re-reads: \"Loading..., Please wait\""],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"anchor":"Escape-Gesture","text":"Escape Gesture"},{"type":"paragraph","inlineContent":[{"type":"text","text":"VoiceOver users can dismiss the HUD via the standard two-finger Z-scrub (escape) gesture."},{"type":"text","text":" "},{"type":"text","text":"This calls "},{"type":"codeVoice","code":"accessibilityPerformEscape()"},{"type":"text","text":" and hides the HUD with animation."}]},{"type":"heading","level":3,"anchor":"Contextual-Hints","text":"Contextual Hints"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"accessibilityHint"},{"type":"text","text":" provides mode-aware context to VoiceOver users:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Indicator modes: “Loading in progress”","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Progress modes: “Task in progress”","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Text-only modes: no hint (nil)","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":3,"anchor":"Modal-Focus-Management","text":"Modal Focus Management"},{"type":"paragraph","inlineContent":[{"type":"text","text":"HUD sets "},{"type":"codeVoice","code":"accessibilityViewIsModal = true"},{"type":"text","text":" to prevent VoiceOver from navigating"},{"type":"text","text":" "},{"type":"text","text":"to elements behind the overlay. This is automatic — no configuration needed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"isEventDeliveryEnabled = true"},{"type":"text","text":" (touches pass through), "},{"type":"codeV