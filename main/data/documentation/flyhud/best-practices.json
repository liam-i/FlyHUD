de(afterDelay: 2.0)","    }","}"],"type":"codeListing"},{"text":"Use removeFromSuperViewOnHide","anchor":"Use-removeFromSuperViewOnHide","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"When using "},{"code":"HUD.show(to:)","type":"codeVoice"},{"type":"text","text":", the HUD is automatically removed from its superview"},{"type":"text","text":" "},{"type":"text","text":"on hide (default behavior). For manually created HUDs, set this explicitly:"}],"type":"paragraph"},{"syntax":"swift","code":["let hud = HUD(with: view)","hud.removeFromSuperViewOnHide = true","view.addSubview(hud)","hud.show()"],"type":"codeListing"},{"text":"Avoid Retain Cycles","anchor":"Avoid-Retain-Cycles","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"[weak self]","type":"codeVoice"},{"text":" when referencing ","type":"text"},{"code":"self","type":"codeVoice"},{"text":" in completion blocks:","type":"text"}]},{"code":["hud.completionBlock = { [weak self] _ in","    self?.navigateToNextScreen()","}"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"anchor":"View-Hierarchy","text":"View Hierarchy"},{"text":"Choose the Right Parent View","anchor":"Choose-the-Right-Parent-View","type":"heading","level":3},{"code":["\/\/ Good: Add to the view controller's view","HUD.show(to: self.view)","","\/\/ Good: Add to a specific container","HUD.show(to: tableView)","","\/\/ Caution: Adding to window covers everything","HUD.show(to: view.window!)"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"anchor":"Avoid-Adding-to-Scrollable-Views","text":"Avoid Adding to Scrollable Views"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Adding a HUD to a "},{"type":"codeVoice","code":"UIScrollView"},{"type":"text","text":" or "},{"type":"codeVoice","code":"UITableView"},{"type":"text","text":" directly may cause"},{"type":"text","text":" "},{"type":"text","text":"unexpected behavior as the user