deVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"type":"text","text":" depends on "},{"code":"FlyHUD","type":"codeVoice"},{"type":"text","text":" automatically. You only need to add "},{"code":"FlyIndicatorHUD","type":"codeVoice"},{"type":"text","text":" or "},{"code":"FlyProgressHUD","type":"codeVoice"},{"type":"text","text":" if you use custom indicator\/progress styles."}]}],"name":"Note","style":"note","type":"aside"},{"level":2,"anchor":"Import","text":"Import","type":"heading"},{"syntax":"swift","code":["import FlyHUDSwiftUI","","\/\/ Optional — for custom indicator styles","import FlyIndicatorHUD","","\/\/ Optional — for custom progress styles","import FlyProgressHUD"],"type":"codeListing"},{"level":2,"anchor":"Layer-1-UIKit-Bridge","text":"Layer 1: UIKit Bridge","type":"heading"},{"inlineContent":[{"type":"text","text":"For maximum control, use "},{"code":".hudHost()","type":"codeVoice"},{"type":"text","text":" to obtain a backing UIView, then call UIKit APIs directly:"}],"type":"paragraph"},{"syntax":"swift","code":["struct MyView: View {","    @State private var hostView: UIView?","","    var body: some View {","        VStack {","            Button(\"Show HUD\") {","                guard let view = hostView else { return }","                HUD.show(to: view, mode: .indicator(), label: \"Loading...\")","            }","            Button(\"Hide HUD\") {","                guard let view = hostView else { return }","                HUD.hide(for: view)","            }","        }","        .hudHost($hostView)","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This pattern gives you full access to the HUD instance and all configuration options."}],"type":"paragraph"},{"level":2,"anchor":"Layer-2-Declarative-Modifiers","text":"Layer 2: Declarative Modifiers","type":"heading"},{"level":3,"anchor":"Boolean-Driven-HUD","text":"Boolean-Driven HUD","type":"heading"},{"inlineContent":[{"type":"text","text":"Toggle a HUD by binding a Boolean:"}],"type":"paragraph"},{"syntax":"swift","code":["struct DownloadView: View {","    @State private var isLoading = false","","    var body: some View {","        Button(\"Download\") {","            isLoading = true","            startDownload { isLoading = false }","        }","        .hud(isPresented: $isLoading) { hud in","            hud.contentView.mode = .indicator()","            hud.contentView.label.text = \"Downloading...\"","        }","    }","}"],"type":"codeListing"},{"level":3,"anchor":"Item-Driven-HUD","text":"Item-Driven HUD","type":"heading"},{"inlineContent":[{"type":"text","text":"Present different HUD states based on an "},{"code":"Identifiable","type":"codeVoice"},{"type":"text","text":" item:"}],"type":"paragraph"},{"syntax":"swift","code":["struct HUDItem: Identifiable {","    let id = UUID()","    let mode: ContentView.Mode","    let label: String","}","","struct TaskView: View {","    @State private var hudItem: HUDItem?","","    var body: some View {","        Button(\"Start\") {","            hudItem = HUDItem(mode: .indicator(), label: \"Working...\")","        }","        .hud(item: $hudItem) { item, hud in","            hud.contentView.mode = item.mode","            hud.contentView.label.text = item.label","        }","    }","}"],"type":"codeListing"},{"level":3,"anchor":"Self-Dismissing-Status","text":"Self-Dismissing Status","type":"heading"},{"inlineContent":[{"type":"text","text":"Show a toast that automatically hides after a duration:"}],"type":"paragraph"},{"syntax":"swift","code":["struct SaveView: View {","    @State private var showSaved = false","","    var body: some View {","        Button(\"Save\") {","            save()","            showSaved = true","        }","        .hudStatus(isPresented: $showSaved, duration: 2.0) { hud in","            hud.contentView.mode = .text","            hud.contentView.label.text = \"Saved!\"","        }","    }","}"],"type":"codeListing"},{"level":2,"anchor":"Layer-3-Convenience-Presets","text":"Layer 3: Convenience Presets","type":"heading"},{"level":3,"anchor":"Loading-Indicator","text":"Loading Indicator","type":"heading"},{"syntax":"swift","code":["MyView()","    .hudLoading(isPresented: $isLoading, label: \"Please wait...\")"],"type":"codeListing"},{"level":3,"anchor":"Toast-Message","text":"Toast Message","type":"heading"},{"syntax":"swift","code":["MyView()","    .hudToast(isPresented: $showToast, duration: 1.5, label: \"File deleted\")"],"type":"codeListing"},{"level":3,"anchor":"Progress-Tracking","text":"Progress Tracking","type":"heading"},{"syntax":"swift","code":["struct UploadView: View {","    @State private var isUploading = false","    @State private var progress: Float = 0","","    var body: some View {","        Button(\"Upload\") { startUpload() }","            .hudProgress(isPresented: $isUploading, progress: $progress, label: \"Uploading\")","    }","}"],"type":"codeListing"},{"level":2,"anchor":"Layer-4-Liquid-Glass-iOS-26+","text":"Layer 4: Liquid Glass (iOS 26+)","type":"heading"},{"inlineContent":[{"type":"text","text":"On iOS 26 and later, use the glass style for a modern translucent appearance:"}],"type":"paragraph"},{"syntax":"swift","code":["MyView()","    .hudGlass(isPresented: $isLoading, label: \"Loading...\")"],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":".hudGlass()","type":"codeVoice"},{"type":"text","text":" is only available when compiling with Swift 6.2+ and targeting iOS 26.0 or tvOS 26.0."}]}],"name":"Important","style":"important","type":"aside"},{"level":2,"anchor":"Animation-Customization","text":"Animation Customization","type":"heading"},{"inlineContent":[{"type":"text","text":"All declarative modifiers accept an "},{"code":"animation","type":"codeVoice"},{"type":"text","text":" parameter:"}],"type":"paragraph"}