{"identifier":{"url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/flyhud\/swiftui-integration"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"inlineContent":[{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"type":"text","text":" provides a native SwiftUI API on top of FlyHUD’s UIKit core. It offers four levels of abstraction:"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Layer","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"API","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Use Case","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Bridge","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":".hudHost($hostView)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Direct UIKit-style control","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Declarative","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":".hud(isPresented:)","type":"codeVoice"},{"text":", ","type":"text"},{"code":".hud(item:)","type":"codeVoice"},{"text":", ","type":"text"},{"code":".hudStatus(isPresented:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Binding-driven state management","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Convenience","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":".hudLoading()","type":"codeVoice"},{"text":", ","type":"text"},{"code":".hudToast()","type":"codeVoice"},{"text":", ","type":"text"},{"code":".hudProgress()","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Common presets with minimal setup","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Liquid Glass","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":".hudGlass()","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"iOS 26+ translucent glass style","type":"text"}]}]]],"type":"table","header":"row"},{"inlineContent":[{"type":"text","text":"All APIs support iOS 13+, tvOS 13+, and visionOS 1.0+."}],"type":"paragraph"},{"level":3,"text":"Architecture","type":"heading","anchor":"Architecture"},{"inlineContent":[{"type":"text","text":"The following diagram shows the layered architecture and how each public API flows through internal components to the UIKit core:"}],"type":"paragraph"},{"inlineContent":[{"identifier":"swiftui-architecture.svg","type":"image"}],"type":"paragraph"},{"level":3,"text":"How It Works","type":"heading","anchor":"How-It-Works"},{"inlineContent":[{"type":"text","text":"The following diagram shows the interaction flow between SwiftUI bindings and the UIKit HUD:"}],"type":"paragraph"},{"inlineContent":[{"identifier":"swiftui-bridge.svg","type":"image"}],"type":"paragraph"},{"level":2,"text":"Installation","type":"heading","anchor":"Installation"},{"inlineContent":[{"type":"text","text":"Add "},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"type":"text","text":" to your package dependencies:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/liam-i\/FlyHUD.git\", from: \"1.7.0\")","],","targets: [","    .target(","        name: \"MyTarget\",","        dependencies: [","            .product(name: \"FlyHUDSwiftUI\", package: \"FlyHUD\")","        ]","    )","]"]},{"inlineContent":[{"type":"text","text":"Or in Xcode: File → Add Package Dependencies → select "},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"text":" depends on ","type":"text"},{"code":"FlyHUD","type":"codeVoice"},{"text":" automatically. You only need to add ","type":"text"},{"code":"FlyIndicatorHUD","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"FlyProgressHUD","type":"codeVoice"},{"text":" if you use custom indicator\/progress styles.","type":"text"}]}],"name":"Note","type":"aside"},{"level":2,"text":"Import","type":"heading","anchor":"Import"},{"syntax":"swift","type":"codeListing","code":["import FlyHUDSwiftUI","","\/\/ Optional — for custom indicator styles","import FlyIndicatorHUD","","\/\/ Optional — for custom progress styles","import FlyProgressHUD"]},{"level":2,"text":"Layer 1: UIKit Bridge","type":"heading","anchor":"Layer-1-UIKit-Bridge"},{"inlineContent":[{"type":"text","text":"For maximum control, use "},{"code":".hudHost()","type":"codeVoice"},{"type":"text","text":" to obtain a backing UIView, then call UIKit APIs directly:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct MyView: View {","    @State private var hostView: UIView?","","    var body: some View {","        VStack {","            Button(\"Show HUD\") {","                guard let view = hostView else { return }","                HUD.show(to: view, mode: .indicator(), label: \"Loading...\")","            }","            Button(\"Hide HUD\") {","                guard let view = hostView else { return }","                HUD.hide(for: view)","            }","        }","        .hudHost($hostView)","    }","}"]},{"inlineContent":[{"type":"text","text":"This pattern gives you full access to the HUD instance and all configuration options."}],"type":"paragraph"},{"level":2,"text":"Layer 2: Declarative Modifiers","type":"heading","anchor":"Layer-2-Declarative-Modifiers"},{"level":3,"text":"Boolean-Driven HUD","type":"heading","anchor":"Boolean-Driven-HUD"},{"inlineContent":[{"type":"text","text":"Toggle a HUD by binding a Boolean:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct DownloadView: View {","    @State private var isLoading = false","","    var body: some View {","        Button(\"Download\") {","            isLoading = true","            startDownload { isLoading = false }","        }","        .hud(isPresented: $isLoading) { hud in","            hud.contentView.mode = .indicator()","            hud.contentView.label.text = \"Downloading...\"","        }","    }","}"]},{"level":3,"text":"Item-Driven HUD","type":"heading","anchor":"Item-Driven-HUD"},{"inlineContent":[{"type":"text","text":"Present different HUD states based on an "},{"code":"Identifiable","type":"codeVoice"},{"type":"text","text":" item:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct HUDItem: Identifiable {","    let id = UUID()","    let mode: ContentView.Mode","    let label: String","}","","struct TaskView: View {","    @State private var hudItem: HUDItem?","","    var body: some View {","        Button(\"Start\") {","            hudItem = HUDItem(mode: .indicator(), label: \"Working...\")","        }","        .hud(item: $hudItem) { item, hud in","            hud.contentView.mode = item.mode","            hud.contentView.label.text = item.label","        }","    }","}"]},{"level":3,"text":"Self-Dismissing Status","type":"heading","anchor":"Self-Dismissing-Status"},{"inlineContent":[{"type":"text","text":"Show a toast that automatically hides after a duration:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct SaveView: View {","    @State private var showSaved = false","","    var body: some View {","        Button(\"Save\") {","            save()","            showSaved = true","        }","        .hudStatus(isPresented: $showSaved, duration: 2.0) { hud in","            hud.contentView.mode = .text","            hud.contentView.label.text = \"Saved!\"","        }","    }","}"]},{"level":2,"text":"Layer 3: Convenience Presets","type":"heading","anchor":"Layer-3-Convenience-Presets"},{"level":3,"text":"Loading Indicator","type":"heading","anchor":"Loading-Indicator"},{"syntax":"swift","type":"codeListing","code":["MyView()","    .hudLoading(isPresented: $isLoading, label: \"Please wait...\")"]},{"level":3,"text":"Toast Message","type":"heading","anchor":"Toast-Message"},{"syntax":"swift","type":"codeListing","code":["MyView()","    .hudToast(isPresented: $showToast, duration: 1.5, label: \"File deleted\")"]},{"anchor":"Progress-Tracking","level":3,"text":"Progress Tracking","type":"heading"},{"code":["struct UploadView: View {","    @State private var isUploading = false","    @State private var progress: Float = 0","","    var body: some View {","        Button(\"Upload\") { startUpload() }","            .hudProgress(isPresented: $isUploading, progress: $progress, label: \"Uploading\")","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Layer-4-Liquid-Glass-iOS-26+","level":2,"text":"Layer 4: Liquid Glass (iOS 26+)","type":"heading"},{"inlineContent":[{"text":"On iOS 26 and later, use the glass style for a modern translucent appearance:","type":"text"}],"type":"paragraph"},{"code":["MyView()","    .hudGlass(isPresented: $isLoading, label: \"Loading...\")"],"syntax":"swift","type":"codeListing"},{"style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":".hudGlass()"},{"text":" is only available when compiling with Swift 6.2+ and targeting iOS 26.0 or tvOS 26.0.","type":"text"}]}],"type":"aside"},{"text":"Animation Customization","level":2,"anchor":"Animation-Customization","type":"heading"},{"inlineContent":[{"text":"All declarative modifiers accept an ","type":"text"},{"code":"animation","type":"codeVoice"},{"text":" parameter:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":[".hud(isPresented: $isLoading, animation: .init(.zoomInOut, damping: .default)) { hud in","    hud.contentView.mode = .indicator()","}"]},{"text":"Migration from UIKit Bridge","level":2,"anchor":"Migration-from-UIKit-Bridge","type":"heading"},{"inlineContent":[{"text":"If you previously used a local ","type":"text"},{"type":"codeVoice","code":"HUDHostView"},{"text":" helper, you can now:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Replace ","type":"text"},{"type":"codeVoice","code":"import FlyHUD"},{"type":"text","text":" with "},{"type":"codeVoice","code":"import FlyHUDSwiftUI"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Remove your local "},{"type":"codeVoice","code":"HUDHostView"},{"type":"text","text":", "},{"type":"codeVoice","code":"HUDContainerModifier"},{"type":"text","text":", and "},{"type":"codeVoice","code":"hudHost()"},{"type":"text","text":" definitions"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":".hudHost($hostView)"},{"type":"text","text":" API is now provided by the SDK"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"type":"text","text":"For new code, prefer the declarative modifiers (Layer 2\/3) over "},{"code":".hudHost()","type":"codeVoice"},{"type":"text","text":" for cleaner state management."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Best Practices","anchor":"Best-Practices"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"One HUD per view hierarchy"}],"type":"strong"},{"text":" — Avoid attaching multiple ","type":"text"},{"type":"codeVoice","code":".hud()"},{"text":" modifiers to the same view. Use ","type":"text"},{"type":"codeVoice","code":"item:"},{"text":" variant for multiple states.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Set binding to "},{"code":"false","type":"codeVoice"},{"type":"text","text":" on dismissal"}],"type":"strong"},{"text":" — The status modifier does this automatically, but for ","type":"text"},{"type":"codeVoice","code":".hud(isPresented:)"},{"text":" you must reset the binding yourself.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Combine with "},{"code":"FlyIndicatorHUD","type":"codeVoice"},{"type":"text","text":"\/"},{"code":"FlyProgressHUD","type":"codeVoice"}],"type":"strong"},{"text":" — Custom styles work the same way; just pass them via the configuration closure.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Prefer convenience presets"}],"type":"strong"},{"text":" — Use ","type":"text"},{"type":"codeVoice","code":".hudLoading()"},{"text":", ","type":"text"},{"type":"codeVoice","code":".hudToast()"},{"text":", and ","type":"text"},{"type":"codeVoice","code":".hudProgress()"},{"text":" for common cases to reduce boilerplate.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"abstract":[{"text":"Use FlyHUD declaratively in SwiftUI with the ","type":"text"},{"type":"codeVoice","code":"FlyHUDSwiftUI"},{"text":" module.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"seeAlsoSections":[{"identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"],"anchor":"Guides","title":"Guides","generated":true}],"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"metadata":{"modules":[{"name":"FlyHUD"}],"title":"SwiftUI Integration","roleHeading":"Article","role":"article"},"sections":[],"kind":"article","references":{"doc://flyhud.FlyHUD/documentation/FlyHUD/best-practices":{"url":"\/documentation\/flyhud\/best-practices","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","abstract":[{"type":"text","text":"Recommended patterns for using FlyHUD effectively in production apps."}],"title":"Best Practices","type":"topic","kind":"article","role":"article"},"doc://flyhud.FlyHUD/do