{"metadata":{"modules":[{"name":"FlyHUD"}],"title":"SwiftUI Integration","role":"article","roleHeading":"Article"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"type":"text","text":" provides a native SwiftUI API on top of FlyHUD’s UIKit core. It offers four levels of abstraction:"}]},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Layer"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"API"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use Case"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Bridge"}]}],[{"type":"paragraph","inlineContent":[{"code":".hudHost($hostView)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Direct UIKit-style control"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Declarative","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":".hud(isPresented:)","type":"codeVoice"},{"type":"text","text":", "},{"code":".hud(item:)","type":"codeVoice"},{"text":", ","type":"text"},{"code":".hudStatus(isPresented:)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Binding-driven state management"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Convenience","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".hudLoading()"},{"type":"text","text":", "},{"code":".hudToast()","type":"codeVoice"},{"type":"text","text":", "},{"code":".hudProgress()","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Common presets with minimal setup"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Liquid Glass","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":".hudGlass()","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"iOS 26+ translucent glass style","type":"text"}]}]]]},{"inlineContent":[{"type":"text","text":"All APIs support iOS 13+, tvOS 13+, and visionOS 1.0+."}],"type":"paragraph"},{"anchor":"Architecture","type":"heading","level":3,"text":"Architecture"},{"inlineContent":[{"type":"text","text":"The following diagram shows the layered architecture and how each public API flows through internal components to the UIKit core:"}],"type":"paragraph"},{"inlineContent":[{"identifier":"swiftui-architecture.svg","type":"image"}],"type":"paragraph"},{"anchor":"How-It-Works","type":"heading","level":3,"text":"How It Works"},{"inlineContent":[{"type":"text","text":"The following diagram shows the interaction flow between SwiftUI bindings and the UIKit HUD:"}],"type":"paragraph"},{"inlineContent":[{"identifier":"swiftui-bridge.svg","type":"image"}],"type":"paragraph"},{"anchor":"Installation","type":"heading","level":2,"text":"Installation"},{"inlineContent":[{"type":"text","text":"Add "},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"type":"text","text":" to your package dependencies:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/liam-i\/FlyHUD.git\", from: \"1.7.0\")","],","targets: [","    .target(","        name: \"MyTarget\",","        dependencies: [","            .product(name: \"FlyHUDSwiftUI\", package: \"FlyHUD\")","        ]","    )","]"]},{"inlineContent":[{"type":"text","text":"Or in Xcode: File → Add Package Dependencies → select "},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"text":" depends on ","type":"text"},{"code":"FlyHUD","type":"codeVoice"},{"text":" automatically. You only need to add ","type":"text"},{"code":"FlyIndicatorHUD","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"FlyProgressHUD","type":"codeVoice"},{"text":" if you use custom indicator\/progress styles.","type":"text"}]}],"type":"aside","style":"note","name":"Note"},{"anchor":"Import","type":"heading","level":2,"text":"Import"},{"syntax":"swift","type":"codeListing","code":["import FlyHUDSwiftUI","","\/\/ Optional — for custom indicator styles","import FlyIndicatorHUD","","\/\/ Optional — for custom progress styles","import FlyProgressHUD"]},{"anchor":"Layer-1-UIKit-Bridge","type":"heading","level":2,"text":"Layer 1: UIKit Bridge"},{"inlineContent":[{"type":"text","text":"For maximum control, use "},{"code":".hudHost()","type":"codeVoice"},{"type":"text","text":" to obtain a backing UIView, then call UIKit APIs directly:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct MyView: View {","    @State private var hostView: UIView?","","    var body: some View {","        VStack {","            Button(\"Show HUD\") {","                guard let view = hostView else { return }","                HUD.show(to: view, mode: .indicator(), label: \"Loading...\")","            }","            Button(\"Hide HUD\") {","                guard let view = hostView else { return }","                HUD.hide(for: view)","            }","        }","        .hudHost($hostView)","    }","}"]},{"inlineContent":[{"type":"text","text":"This pattern gives you full access to the HUD instance and all configuration options."}],"type":"paragraph"},{"anchor":"Layer-2-Declarative-Modifiers","type":"heading","level":2,"text":"Layer 2: Declarative Modifiers"},{"anchor":"Boolean-Driven-HUD","type":"heading","level":3,"text":"Boolean-Driven HUD"},{"inlineContent":[{"type":"text","text":"Toggle a HUD by binding a Boolean:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct DownloadView: View {","    @State private var isLoading = false","","    var body: some View {","        Button(\"Download\") {","            isLoading = true","            startDownload { isLoading = false }","        }","        .hud(isPresented: $isLoading) { hud in","            hud.contentView.mode = .indicator()","            hud.contentView.label.text = \"Downloading...\"","        }","    }","}"]},{"anchor":"Item-Driven-HUD","type":"heading","level":3,"text":"Item-Driven HUD"},{"inlineContent":[{"type":"text","text":"Present different HUD states based on an "},{"code":"Identifiable","type":"codeVoice"},{"type":"text","text":" item:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct HUDItem: Identifiable {","    let id = UUID()","    let mode: ContentView.Mode","    let label: String","}","","struct TaskView: View {","    @State private var hudItem: HUDItem?","","    var body: some View {","        Button(\"Start\") {","            hudItem = HUDItem(mode: .indicator(), label: \"Working...\")","        }","        .hud(item: $hudItem) { item, hud in","            hud.contentView.mode = item.mode","            hud.contentView.label.text = item.label","        }","    }","}"]},{"anchor":"Self-Dismissing-Status","type":"heading","level":3,"text":"Self-Dismissing Status"},{"inlineContent":[{"type":"text","text":"Show a toast that automatically hides after a duration:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct SaveView: View {","    @State private var showSaved = false","","    var body: some View {","        Button(\"Save\") {","            save()","            showSaved = true","        }","        .hudStatus(isPresented: $showSaved, duration: 2.0) { hud in","            hud.contentView.mode = .text","            hud.contentView.label.text = \"Saved!\"","        }","    }","}"]},{"anchor":"Layer-3-Convenience-Presets","type":"heading","level":2,"text":"Layer 3: Convenience Presets"},{"anchor":"Loading-Indicator","type":"heading","level":3,"text":"Loading Indicator"},{"syntax":"swift","type":"codeListing","code":["MyView()","    .hudLoading(isPresented: $isLoading, label: \"Please wait...\")"]},{"anchor":"Toast-Message","type":"heading","level":3,"text":"Toast Message"},{"syntax":"swift","type":"codeListing","code":["MyView()","    .hudToast(isPresented: $showToast, duration: 1.5, label: \"File deleted\")"]},{"anchor":"Progress-Tracking","type":"heading","level":3,"text":"Progress Tracking"},{"syntax":"swift","type":"codeListing","code":["struct UploadView: View {","    @State private var isUploading = false","    @State private var progress: Float = 0","","    var body: some View {","        Button(\"Upload\") { startUpload() }","            .hudProgress(isPresented: $isUploading, progress: $progress, label: \"Uploading\")","    }","}"]},{"anchor":"Layer-4-Liquid-Glass-iOS-26+","type":"heading","level":2,"text":"Layer 4: Liquid Glass (iOS 26+)"},{"inlineContent":[{"type":"text","text":"On iOS 26 and later, use the glass style for a modern translucent appearance:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["MyView()","    .hudGlass(isPresented: $isLoading, label: \"Loading...\")"]},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":".hudGlass()","type":"codeVoice"},{"text":" is only available when compiling with Swift 6.2+ and targeting iOS 26.0 or tvOS 26.0.","type":"text"}]}],"type":"aside","style":"important","name":"Important"},{"anchor":"Animation-Customization","type":"heading","level":2,"text":"Animation Customization"},{"inlineContent":[{"type":"text","text":"All declarative modifiers accept an "},{"code":"animation","type":"codeVoice"},{"type":"text","text":" parameter:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":[".hud(isPresented: $isLoading, animation: .init(.zoomInOut, damping: .default)) { hud in","    hud.contentView.mode = .indicator()","}"]},{"anchor":"Migration-from-UIKit-Bridge","type":"heading","level":2,"text":"Migration from UIKit Bridge"},{"inlineContent":[{"type":"text","text":"If you previously used a local "},{"code":"HUDHostView","type":"codeVoice"},{"type":"text","text":" helper, you can now:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Replace ","type":"text"},{"type":"codeVoice","code":"import FlyHUD"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"import FlyHUDSwiftUI"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Remove your local ","type":"text"},{"type":"codeVoice","code":"HUDHostView"},{"text":", ","type":"text"},{"type":"codeVoice","code":"HUDContainerModifier"},{"text":", and ","type":"text"},{"type":"codeVoice","code":"hudHost()"},{"text":" definitions","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":".hudHost($hostView)"},{"text":" API is now provided by the SDK","type":"text"}]}]}],"type":"orderedList"},{"inlineContent":[{"type":"text","text":"For new code, prefer the declarative modifiers (Layer 2\/3) over "},{"code":".hudHost()","type":"codeVoice"},{"type":"text","text":" for cleaner state management."}],"type":"paragraph"},{"anchor":"Best-Practices","type":"heading","level":2,"text":"Best Practices"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"One HUD per view hierarchy"}]},{"text":" — Avoid attaching multiple ","type":"text"},{"type":"codeVoice","code":".hud()"},{"text":" modifiers to the same view. Use ","type":"text"},{"type":"codeVoice","code":"item:"},{"text":" variant for multiple states.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Set binding to "},{"code":"false","type":"codeVoice"},{"type":"text","text":" on dismissal"}]},{"text":" — The status modifier does this automatically, but for ","type":"text"},{"type":"codeVoice","code":".hud(isPresented:)"},{"text":" you must reset the binding yourself.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"t