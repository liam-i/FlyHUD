cies: [","    .package(url: \"https:\/\/github.com\/liam-i\/FlyHUD.git\", from: \"1.7.0\")","],","targets: [","    .target(","        name: \"MyTarget\",","        dependencies: [","            .product(name: \"FlyHUDSwiftUI\", package: \"FlyHUD\")","        ]","    )","]"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Or in Xcode: File → Add Package Dependencies → select "},{"type":"codeVoice","code":"FlyHUDSwiftUI"},{"type":"text","text":"."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"text":" depends on ","type":"text"},{"type":"codeVoice","code":"FlyHUD"},{"type":"text","text":" automatically. You only need to add "},{"code":"FlyIndicatorHUD","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"FlyProgressHUD","type":"codeVoice"},{"text":" if you use custom indicator\/progress styles.","type":"text"}]}],"style":"note","type":"aside","name":"Note"},{"type":"heading","text":"Import","anchor":"Import","level":2},{"syntax":"swift","type":"codeListing","code":["import FlyHUDSwiftUI","","\/\/ Optional — for custom indicator styles","import FlyIndicatorHUD","","\/\/ Optional — for custom progress styles","import FlyProgressHUD"]},{"type":"heading","text":"Layer 1: UIKit Bridge","anchor":"Layer-1-UIKit-Bridge","level":2},{"type":"paragraph","inlineContent":[{"text":"For maximum control, use ","type":"text"},{"code":".hudHost()","type":"codeVoice"},{"text":" to obtain a backing UIView, then call UIKit APIs directly:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["struct MyView: View {","    @State private var hostView: UIView?","","    var body: some View {","        VStack {","            Button(\"Show HUD\") {","                guard let view = hostView else { return }","                HUD.show(to: view, mode: .indicator(), label: \"Loading...\")","            }","            Button(\"Hide HUD\") {","              