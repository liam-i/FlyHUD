{"variants":[{"paths":["\/documentation\/flyhud\/testing"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"seeAlsoSections":[{"identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices"],"anchor":"Guides","title":"Guides","generated":true}],"metadata":{"title":"Testing Guide","modules":[{"name":"FlyHUD"}],"roleHeading":"Article","role":"article"},"kind":"article","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"},"abstract":[{"text":"Strategies for unit testing, integration testing, and mocking FlyHUD in your app.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Unit-Testing-HUD-Logic","text":"Unit Testing HUD Logic","type":"heading"},{"level":3,"anchor":"Testing-HUD-Display-State","text":"Testing HUD Display State","type":"heading"},{"syntax":"swift","code":["import XCTest","@testable import FlyHUD","","@MainActor","final class HUDDisplayTests: XCTestCase {","    var containerView: UIView!","","    override func setUp() {","        super.setUp()","        containerView = UIView(frame: CGRect(x: 0, y: 0, width: 375, height: 812))","    }","","    override func tearDown() {","        containerView = nil","        super.tearDown()","    }","","    func testShowAddsHUDToView() {","        let hud = HUD.show(to: containerView, animated: false)","        XCTAssertTrue(containerView.subviews.contains(hud))","        hud.hide(animated: false)","    }","","    func testHideRemovesHUDFromView() {","        let hud = HUD.show(to: containerView, animated: false)","        hud.hide(animated: false)","        XCTAssertFalse(containerView.subviews.contains(hud))","    }","","    func testActivityCount() {","        let hud = HUD.show(to: containerView, animated: false)","        hud.isCountEnabled = true","","        hud.show(animated: false)  \/\/ count = 2","        hud.show(animated: false)  \/\/ count = 3","","        hud.hide(animated: false)  \/\/ count = 2","        XCTAssertTrue(containerView.subviews.contains(hud))","","        hud.hide(animated: false)  \/\/ count = 1","        XCTAssertTrue(containerView.subviews.contains(hud))","","        hud.hide(animated: false)  \/\/ count = 0, hides","        XCTAssertFalse(containerView.subviews.contains(hud))","    }","}"],"type":"codeListing"},{"level":3,"anchor":"Testing-Content-Configuration","text":"Testing Content Configuration","type":"heading"},{"syntax":"swift","code":["@MainActor","func testLabelText() {","    let hud = HUD.show(to: containerView, animated: false, label: \"Loading\")","    XCTAssertEqual(hud.contentView.label.text, \"Loading\")","    hud.hide(animated: false)","}","","@MainActor","func testModeChange() {","    let hud = HUD.show(to: containerView, animated: false)","    hud.contentView.mode = .text","    XCTAssertTrue(hud.contentView.mode.isText)","    hud.hide(animated: false)","}","","@MainActor","func testProgressUpdate() {","    let hud = HUD.show(to: containerView, animated: false, mode: .progress(.default))","    hud.contentView.progress = 0.5","    XCTAssertEqual(hud.contentView.progress, 0.5)","    hud.hide(animated: false)","}"],"type":"codeListing"},{"level":2,"anchor":"Mocking-HUD-in-App-Tests","text":"Mocking HUD in App Tests","type":"heading"},{"inlineContent":[{"type":"image","identifier":"testing-mock.svg"}],"type":"paragraph"},{"level":3,"anchor":"Protocol-Based-Abstraction","text":"Protocol-Based Abstraction","type":"heading"},{"inlineContent":[{"text":"Abstract HUD operations behind a protocol for testability:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ In your app code","@MainActor","protocol HUDDisplayable {","    func showLoading(on view: UIView, label: String?)","    func showSuccess(on view: UIView, label: String?)","    func showError(on view: UIView, label: String?)","    func hide(from view: UIView)","}","","@MainActor","final class RealHUDService: HUDDisplayable {","    func showLoading(on view: UIView, label: String?) {","        HUD.show(to: view, label: label)","    }","","    func showSuccess(on view: UIView, label: String?) {","        let image = UIImageView(image: UIImage(systemName: \"checkmark\"))","        HUD.showStatus(to: view, mode: .custom(image), label: label)","    }","","    func showError(on view: UIView, label: String?) {","        HUD.showStatus(to: view, mode: .text, label: label)","    }","","    func hide(from view: UIView) {","        HUD.hide(for: view)","    }","}"],"type":"codeListing"},{"level":3,"anchor":"Mock-Implementation-for-Tests","text":"Mock Implementation for Tests","type":"heading"},{"syntax":"swift","code":["@MainActor","final class MockHUDService: HUDDisplayable {","    var showLoadingCalled = false","    var showSuccessCalled = false","    var showErrorCalled = false","    var hideCalled = false","    var lastLabel: String?","","    func showLoading(on view: UIView, label: String?) {","        showLoadingCalled = true","        lastLabel = label","    }","","    func showSuccess(on view: UIView, label: String?) {","        showSuccessCalled = true","        lastLabel = label","    }","","    func showError(on view: UIView, label: String?) {","        showErrorCalled = true","        lastLabel = label","    }","","    func hide(from view: UIView) {","        hideCalled = true","    }","}"],"type":"codeListing"},{"type":"heading","text":"Using the Mock in Tests","level":3,"anchor":"Using-the-Mock-in-Tests"},{"type":"codeListing","syntax":"swift","code":["@MainActor","final class ViewModelTests: XCTestCase {","    func testFetchShowsAndHidesHUD() async {","        let mockHUD = MockHUDService()","        let viewModel = MyViewModel(hudService: mockHUD)","","        await viewModel.fetchData()","","        XCTAssertTrue(mockHUD.showLoadingCalled)","        XCTAssertTrue(mockHUD.hideCalled)","    }","}"]},{"type":"heading","text":"Testing Animations","level":2,"anchor":"Testing-Animations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Animations are difficult to unit test directly. Use these strategies:"}]},{"type":"heading","text":"Disable Animations in Tests","level":3,"anchor":"Disable-Animations-in-Tests"},{"type":"codeListing","syntax":"swift","code":["@MainActor","func testHideWithoutAnimation() {","    let hud = HUD.show(to: containerView, animated: false)","    hud.hide(animated: false)","    \/\/ Assert immediately — no animation delay","    XCTAssertTrue(hud.isHidden)","}"]},{"type":"heading","text":"Use Animation Style `.none`","level":3,"anchor":"Use-Animation-Style-none"},{"type":"codeListing","syntax":"swift","code":["let hud = HUD.show(to: containerView, using: .animation(.none))","hud.hide(using: .animation(.none))"]},{"type":"heading","text":"Testing Delegates","level":2,"anchor":"Testing-Delegates"},{"type":"codeListing","syntax":"swift","code":["@MainActor","final class DelegateTests: XCTestCase, HUDDelegate {","    var hudDidHide = false","","    func hudWasHidden(_ hud: HUD) {","        hudDidHide = true","    }","","    func testDelegateCalledOnHide() {","        let hud = HUD.show(to: containerView, animated: false)","        hud.delegate = self","        hud.hide(animated: false)","        XCTAssertTrue(hudDidHide)","    }","}"]},{"type":"heading","text":"Testing Custom Indicators","level":2,"anchor":"Testing-Custom-Indicators"},{"type":"heading","text":"ActivityIndicatorView Tests","level":3,"anchor":"ActivityIndicatorView-Tests"},{"type":"codeListing","syntax":"swift","code":["@MainActor","func testActivityIndicatorStartStop() {","    let indicator = ActivityIndicatorView(style: .ringClipRotate)","    XCTAssertFalse(indicator.isAnimating)","","    indicator.startAnimating()","    XCTAssertTrue(indicator.isAnimating)","    XCTAssertFalse(indicator.isHidden)","","    indicator.stopAnimating()","    XCTAssertFalse(indicator.isAnimating)","    XCTAssertTrue(indicator.isHidden) \/\/ hidesWhenStopped = true","}"]},{"type":"heading","text":"ProgressView Tests","level":3,"anchor":"ProgressView-Tests"},{"type":"codeListing","syntax":"swift","code":["@MainActor","func testProgressViewBounds() {","    let progressView = ProgressView(style: .round)","    XCTAssertEqual(progressView.progress, 0.0)","","    progressView.progress = 0.75","    XCTAssertEqual(progressView.progress, 0.75)","}"]},{"type":"heading","text":"Test Strategy","level":2,"anchor":"Test-Strategy"},{"type":"paragraph","inlineContent":[{"identifier":"testing-strategy.svg","type":"image"}]},{"type":"heading","text":"Running Tests","level":2,"anchor":"Running-Tests"},{"type":"heading","text":"Command Line","level":3,"anchor":"Command-Line"},{"type":"codeListing","syntax":"bash","code":["# Run all unit tests",".\/scripts\/build.sh test","","# Run specific test class",".\/scripts\/build.sh test HUDTests","","# Run UI tests",".\/scripts\/build.sh test ui","","# SPM build (swift test not supported — UIKit unavailable on macOS CLI)",".\/scripts\/build.sh swift"]},{"type":"heading","text":"Xcode","level":3,"anchor":"Xcode"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Select the test target and press Cmd+U, or run individual tests via the test navigator."}]},{"type":"heading","text":"Test Organization","level":2,"anchor":"Test-Organization"},{"type":"codeListing","syntax":"text","code":["Tests\/","├── HUD\/","│   ├── HUDTests.swift              # Core show\/hide behavior","│   ├── HUDStressTests.swift        # Concurrent and stress scenarios","│   ├── ModelTests.swift            # Layout, Animation models","│   ├── Extensions\/                 # Extension tests","│   ├── Observables\/                # DisplayLink, Keyboard tests","│   ├── Protocols\/                  # Protocol conformance tests","│   └── Views\/                      # ContentView, BackgroundView tests","├── IndicatorHUD\/","│   └── ActivityIndicatorViewTests.swift","└── ProgressHUD\/","    └── ProgressViewTests.swift"]}]}],"references":{"doc://flyhud.FlyHUD/documentation/FlyHUD/swiftui-integration":{"type":"topic","kind":"article","abstract":[{"text":"Use FlyHUD declaratively in SwiftUI with the ","type":"text"},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"text":" module.","type":"text"}],"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","title":"SwiftUI Integration","url":"\/documentation\/flyhud\/swiftui-integration","role":"article"},"doc://flyhud.FlyHUD/documentation/FlyHUD/best-practices":{"type":"topic","kind":"article","abstract":[{"text":"Recommended patterns for using FlyHUD effectively in production apps.","type":"text"}],"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","url":"\/documentation\/flyhud\/best-practices","title":"Best Practices","role":"article"},"doc://flyhud.FlyHUD/documentation/FlyHUD":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"A lightweight and easy-to-use HUD for displaying progress and status of ongoing tasks on iOS, tvOS, and visionOS."}],"role":"collection","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD","title":"FlyHUD","url":"\/documentation\/flyhud"},"doc://flyhud.FlyHUD/documentation/FlyHUD/custom-ui":{"type":"topic","kind":"article","abstract":[{"type":"text","text":"Build custom activity indicators, progress views, and display modes."}],"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","title":"Custom UI","url":"\/documentation\/flyhud\/custom-ui","role":"article"},"testing-mock.svg":{"alt":"Class diagram showing HUDDisplayable protocol with RealHUDService (production) and MockHUDService (test) conformances, and ViewModel depending on the protocol.","identifier":"testin