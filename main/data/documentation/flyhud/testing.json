{"sections":[],"abstract":[{"type":"text","text":"Strategies for unit testing, integration testing, and mocking FlyHUD in your app."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"content":[{"anchor":"Unit-Testing-HUD-Logic","type":"heading","text":"Unit Testing HUD Logic","level":2},{"anchor":"Testing-HUD-Display-State","type":"heading","text":"Testing HUD Display State","level":3},{"syntax":"swift","code":["import XCTest","@testable import FlyHUD","","@MainActor","final class HUDDisplayTests: XCTestCase {","    var containerView: UIView!","","    override func setUp() {","        super.setUp()","        containerView = UIView(frame: CGRect(x: 0, y: 0, width: 375, height: 812))","    }","","    override func tearDown() {","        containerView = nil","        super.tearDown()","    }","","    func testShowAddsHUDToView() {","        let hud = HUD.show(to: containerView, animated: false)","        XCTAssertTrue(containerView.subviews.contains(hud))","        hud.hide(animated: false)","    }","","    func testHideRemovesHUDFromView() {","        let hud = HUD.show(to: containerView, animated: false)","        hud.hide(animated: false)","        XCTAssertFalse(containerView.subviews.contains(hud))","    }","","    func testActivityCount() {","        let hud = HUD.show(to: containerView, animated: false)","        hud.isCountEnabled = true","","        hud.show(animated: false)  \/\/ count = 2","        hud.show(animated: false)  \/\/ count = 3","","        hud.hide(animated: false)  \/\/ count = 2","        XCTAssertTrue(containerView.subviews.contains(hud))","","        hud.hide(animated: false)  \/\/ count = 1","        XCTAssertTrue(containerView.subviews.contains(hud))","","        hud.hide(animated: false)  \/\/ count = 0, hides","        XCTAssertFalse(containerView.subviews.contains(hud))","    }","}"],"type":"codeListing"},{"anchor":"Testing-Content-Configuration","type":"heading","text":"Testing Content Configuration","level":3},{"syntax":"swift","code":["@MainActor","func testLabelText() {","    let hud = HUD.show(to: containerView, animated: false, label: \"Loading\")","    XCTAssertEqual(hud.contentView.label.text, \"Loading\")","    hud.hide(animated: false)","}","","@MainActor","func testModeChange() {","    let hud = HUD.show(to: containerView, animated: false)","    hud.contentView.mode = .text","    XCTAssertTrue(hud.contentView.mode.isText)","    hud.hide(animated: false)","}","","@MainActor","func testProgressUpdate() {","    let hud = HUD.show(to: containerView, animated: false, mode: .progress(.default))","    hud.contentView.progress = 0.5","    XCTAssertEqual(hud.contentView.progress, 0.5)","    hud.hide(animated: false)","}"],"type":"codeListing"},{"anchor":"Mocking-HUD-in-App-Tests","type":"heading","text":"Mocking HUD in App Tests","level":2},{"type":"paragraph","inlineContent":[{"identifier":"testing-mock.svg","type":"image"}]},{"anchor":"Protocol-Based-Abstraction","type":"heading","text":"Protocol-Based Abstraction","level":3},{"type":"paragraph","inlineContent":[{"text":"Abstract HUD operations behind a protocol for testability:","type":"text"}]},{"syntax":"swift","code":["\/\/ In your app code","@MainActor","protocol HUDDisplayable {","    func showLoading(on view: UIView, label: String?)","    func showSuccess(on view: UIView, label: String?)","    func showError(on view: UIView, label: String?)","    func hide(from view: UIView)","}","","@MainActor","final class RealHUDService: HUDDisplayable {","    func showLoading(on view: UIView, label: String?) {","        HUD.show(to: view, label: label)","    }","","    func showSuccess(on view: UIView, label: String?) {","        let image = UIImageView(image: UIImage(systemName: \"checkmark\"))","        HUD.showStatus(to: view, mode: .custom(image), label: label)","    }","","    func showError(on view: UIView, label: String?) {","        HUD.showStatus(to: view, mode: .text, label: label)","    }","","    func hide(from view: UIView) {","        HUD.hide(for: view)","    }","}"],"type":"codeListing"},{"anchor":"Mock-Implementation-for-Tests","type":"heading","text":"Mock Implementation for Tests","level":3},{"syntax":"swift","code":["@MainActor","final class MockHUDService: HUDDisplayable {","    var showLoadingCalled = false","    var showSuccessCalled = false","    var showErrorCalled = false","    var hideCalled = false","    var lastLabel: String?","","    func showLoading(on view: UIView, label: String?) {","        showLoadingCalled = true","        lastLabel = label","    }","","    func showSuccess(on view: UIView, label: String?) {","        showSuccessCalled = true","        lastLabel = label","    }","","    func showError(on view: UIView, label: String?) {","        showErrorCalled = true","        lastLabel = label","    }","","    func hide(from view: UIView) {","        hideCalled = true","    }","}"],"type":"codeListing"},{"anchor":"Using-the-Mock-in-Tests","type":"heading","text":"Using the Mock in Tests","level":3},{"syntax":"swift","code":["@MainActor","final class ViewModelTests: XCTestCase {","    func testFetchShowsAndHidesHUD() async {","        let mockHUD = MockHUDService()","        let viewModel = MyViewModel(hudService: mockHUD)","","        await viewModel.fetchData()","","        XCTAssertTrue(mockHUD.showLoadingCalled)","        XCTAssertTrue(mockHUD.hideCalled)","    }","}"],"type":"codeListing"},{"anchor":"Testing-Animations","type":"heading","text":"Testing Animations","level":2},{"type":"paragraph","inlineContent":[{"text":"Animations are difficult to unit test directly. Use these strategies:","type":"text"}]},{"anchor":"Disable-Animations-in-Tests","type":"heading","text":"Disable Animations in Tests","level":3},{"syntax":"swift","code":["@MainActor","func testHideWithoutAnimation() {","    let hud = HUD.show(to: containerView, animated: false)","    hud.hide(animated: false)","    \/\/ Assert immediately — no animation delay","    XCTAssertTrue(hud.isHidden)","}"],"type":"codeListing"},{"anchor":"Use-Animation-Style-none","type":"heading","text":"Use Animation Style `.none`","level":3},{"syntax":"swift","code":["let hud = HUD.show(to: containerView, using: .animation(.none))","hud.hide(using: .animation(.none))"],"type":"codeListing"},{"anchor":"Testing-Delegates","type":"heading","text":"Testing Delegates","level":2},{"syntax":"swift","code":["@MainActor","final class DelegateTests: XCTestCase, HUDDelegate {","    var hudDidHide = false","","    func hudWasHidden(_ hud: HUD) {","        hudDidHide = true","    }","","    func testDelegateCalledOnHide() {","        let hud = HUD.show(to: containerView, animated: false)","        hud.delegate = self","        hud.hide(animated: false)","        XCTAssertTrue(hudDidHide)","    }","}"],"type":"codeListing"},{"anchor":"Testing-Custom-Indicators","type":"heading","text":"Testing Custom Indicators","level":2},{"anchor":"ActivityIndicatorView-Tests","type":"heading","text":"ActivityIndicatorView Tests","level":3},{"syntax":"swift","code":["@MainActor","func testActivityIndicatorStartStop() {","    let indicator = ActivityIndicatorView(style: .ringClipRotate)","    XCTAssertFalse(indicator.isAnimating)","","    indicator.startAnimating()","    XCTAssertTrue(indicator.isAnimating)","    XCTAssertFalse(indicator.isHidden)","","    indicator.stopAnimating()","    XCTAssertFalse(indicator.isAnimating)","    XCTAssertTrue(indicator.isHidden) \/\/ hidesWhenStopped = true","}"],"type":"codeListing"},{"anchor":"ProgressView-Tests","type":"heading","text":"ProgressView Tests","level":3},{"syntax":"swift","code":["@MainActor","func testProgressViewBounds() {","    let progressView = ProgressView(style: .round)","    XCTAssertEqual(progressView.progress, 0.0)","","    progressView.progress = 0.75","    XCTAssertEqual(progressView.progress, 0.75)","}"],"type":"codeListing"},{"anchor":"Test-Strategy","type":"heading","text":"Test Strategy","level":2},{"type":"paragraph","inlineContent":[{"identifier":"testing-strategy.svg","type":"image"}]},{"anchor":"Running-Tests","type":"heading","text":"Running Tests","level":2},{"anchor":"Command-Line","type":"heading","text":"Command Line","level":3},{"syntax":"bash","code":["# Run all unit tests",".\/scripts\/build.sh test","","# Run specific test class",".\/scripts\/build.sh test HUDTests","","# Run UI tests",".\/scripts\/build.sh test ui","","# SPM build (swift test not supported — UIKit unavailable on macOS CLI)",".\/scripts\/build.sh swift"],"type":"codeListing"},{"level":3,"type":"heading","text":"Xcode","anchor":"Xcode"},{"inlineContent":[{"type":"text","text":"Select the test target and press Cmd+U, or run individual tests via the test navigator."}],"type":"paragraph"},{"level":2,"text":"Test Organization","type":"heading","anchor":"Test-Organization"},{"syntax":"text","type":"codeListing","code":["Tests\/","├── HUD\/","│   ├── HUDTests.swift              # Core show\/hide behavior","│   ├── HUDStressTests.swift        # Concurrent and stress scenarios","│   ├── ModelTests.swift            # Layout, Animation models","│   ├── Extensions\/                 # Extension tests","│   ├── Observables\/                # DisplayLink, Keyboard tests","│   ├── Protocols\/                  # Protocol conformance tests","│   └── Views\/                      # ContentView, BackgroundView tests","├── IndicatorHUD\/","│   └── ActivityIndicatorViewTests.swift","└── ProgressHUD\/","    └── ProgressViewTests.swift"]}],"kind":"content"}],"kind":"article","metadata":{"roleHeading":"Article","title":"Testing Guide","modules":[{"name":"FlyHUD"}],"role":"article"},"variants":[{"paths":["\/documentation\/flyhud\/testing"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"},"seeAlsoSections":[{"identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices"],"title":"Guides","anchor":"Guides","generated":true}],"references":{"doc://flyhud.FlyHUD/documentation/FlyHUD/best-practices":{"url":"\/documentation\/flyhud\/best-practices","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","abstract":[{"type":"text","text":"Recommended patterns for using FlyHUD effectively in production apps."}],"title":"Best Practices","type":"topic","kind":"article","role":"article"},"testing-mock.svg":{"identifier":"testing-mock.svg","alt":"Class diagram showing HUDDisplayable protocol with RealHUDService (production) and MockHUDService (test) conformances, and ViewModel depending on the protocol.","variants":[{"svgID":"my-svg","traits":["1x","light"],"url":"\/images\/flyhud.FlyHUD\/testing-mock.svg"}],"type":"image"},"doc://flyhud.FlyHUD/documentation/FlyHUD":{"kind":"symbol","type":"topic","abstract":[{"text":"A lightweight and easy-to-use HUD for displaying progress and status of ongoing tasks on iOS, tvOS, and visionOS.","type":"text"}],"url":"\/documentation\/flyhud","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD","role":"collection","title":"FlyHUD"},"doc://flyhud.FlyHUD/documentation/FlyHUD/advanced-features":{"abstract":[{"text":"Explore keyboard tracking, animations, grace time, activity counts, and more.","type":"text"}],"kind":"article","type":"topic","role":"article","title":"Advanced Features","url":"\/documentation\/flyhud\/advanced-features","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features"},"doc://flyhud.FlyHUD/documentation/FlyHUD/swiftui-integration":{"abstract":[{"text":"Use FlyHUD declaratively in SwiftUI with the ","type":"text"},{"type":"codeVoice","code":"FlyHUDSwiftUI"},{"text":" module.","type":"text"}],"kind":"article","type":"topic","role":"article","title":"SwiftUI Integration","url":"\/documentation\/flyhud\/swiftui-integration","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration"},"doc://flyhud.FlyHUD/documentation/FlyHUD/custom-ui":{"kind":"article","type":"topic","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","url":"\/documentation\/flyhud\/custom-ui","abstract":[{"type":"text","text":"Build custom activity indicators, progress views, and display modes."}],"role":"article","title":"Custom UI"},"testing-strategy.svg":{"variants":[{"svgID":"my-svg","traits":["1x","light"],"url":"\/images\/flyhud.FlyHUD\/testing-strategy.svg"}],"identifier":"testing-strategy.svg","type":"image","alt":"Flowchart showing test strategy decision tree: HUD display logic → use animated:false; Business logic → use Mock; Custom indicators → test state; Delegates → assert callbacks."}}}