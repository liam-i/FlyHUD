{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flyhud\/custom-ui"]}],"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"metadata":{"roleHeading":"Article","role":"article","title":"Custom UI","modules":[{"name":"FlyHUD"}]},"kind":"article","schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following diagram shows the protocol hierarchy for custom indicators and progress views:"}]},{"type":"paragraph","inlineContent":[{"identifier":"custom-protocols.svg","type":"image"}]},{"type":"heading","level":2,"text":"Custom Activity Indicators","anchor":"Custom-Activity-Indicators"},{"type":"heading","level":3,"text":"Using FlyIndicatorHUD Built-in Styles","anchor":"Using-FlyIndicatorHUD-Built-in-Styles"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Import "},{"type":"codeVoice","code":"FlyIndicatorHUD"},{"type":"text","text":" to access pre-built indicator styles:"}]},{"type":"codeListing","code":["import FlyIndicatorHUD","","\/\/ Ring clip rotation","HUD.show(to: view, mode: .indicator(.ringClipRotate))","","\/\/ Ball spin fade","HUD.show(to: view, mode: .indicator(.ballSpinFade))","","\/\/ Circle stroke spin","HUD.show(to: view, mode: .indicator(.circleStrokeSpin))","","\/\/ Circle arc dot spin","HUD.show(to: view, mode: .indicator(.circleArcDotSpin))"],"syntax":"swift"},{"type":"heading","level":3,"text":"Customizing ActivityIndicatorView Properties","anchor":"Customizing-ActivityIndicatorView-Properties"},{"type":"codeListing","code":["let indicator = ActivityIndicatorView(style: .circleStrokeSpin)","indicator.color = .systemBlue","indicator.trackColor = UIColor.systemBlue.withAlphaComponent(0.2)","indicator.lineWidth = 3.0","","HUD.show(to: view, mode: .custom(indicator), label: \"Loading\")"],"syntax":"swift"},{"type":"heading","level":3,"text":"Choosing Your Customization Approach","anchor":"Choosing-Your-Customization-Approach"},{"type":"paragraph","inlineContent":[{"identifier":"custom-indicator-decision.svg","type":"image"}]},{"type":"heading","level":3,"text":"Implementing ActivityIndicatorViewStyleable","anchor":"Implementing-ActivityIndicatorViewStyleable"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create entirely custom indicator animations:"}]},{"type":"codeListing","code":["struct PulseStyle: ActivityIndicatorViewStyleable {","    func isEqual(_ object: Any) -> Bool {","        object is PulseStyle","    }","","    func makeAnimation() -> ActivityIndicatorAnimationBuildable {","        PulseAnimation()","    }","","    var defaultSize: CGSize { CGSize(width: 40, height: 40) }","    var defaultColor: UIColor { .systemPurple }","    var defaultTrackColor: UIColor? { nil }","    var defaultLineWidth: CGFloat { 0 }","}","","struct PulseAnimation: ActivityIndicatorAnimationBuildable {","    func make(in layer: CALayer, color: UIColor, trackColor: UIColor?, lineWidth: CGFloat) {","        let circle = CAShapeLayer()","        circle.path = UIBezierPath(ovalIn: layer.bounds).cgPath","        circle.fillColor = color.cgColor","","        let animation = CABasicAnimation(keyPath: \"transform.scale\")","        animation.fromValue = 0.5","        animation.toValue = 1.0","        animation.duration = 0.8","        animation.autoreverses = true","        animation.repeatCount = .greatestFiniteMagnitude","        circle.add(animation, forKey: \"pulse\")","","        layer.addSublayer(circle)","    }","}","","\/\/ Usage","HUD.show(to: view, mode: .indicator(PulseStyle()))"],"syntax":"swift"},{"type":"heading","level":3,"text":"Implementing RotateViewable","anchor":"Implementing-RotateViewable"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For simple rotation-based indicators, conform to "},{"type":"codeVoice","code":"RotateViewable"},{"type":"text","text":":"}]},{"type":"codeListing","code":["class SpinnerView: UIView, RotateViewable {","    var duration: CFTimeInterval { 0.5 }","","    override init(frame: CGRect) {","        super.init(frame: frame)","        \/\/ VoiceOver: ContentView handles accessibility for the HUD.","        \/\/ Custom indicators should not be separate focus elements.","        isAccessibilityElement = false","    }","","    required init?(coder: NSCoder) { fatalError() }","","    override var intrinsicContentSize: CGSize {","        CGSize(width: 37, height: 37)","    }","","    override func draw(_ rect: CGRect) {","        \/\/ Draw your custom shape","    }","}","","\/\/ Usage — rotation is handled automatically","let spinner = SpinnerView()","HUD.show(to: view, mode: .custom(spinner))"],"syntax":"swift"},{"type":"heading","level":2,"text":"Custom Progress Views","anchor":"Custom-Progress-Views"},{"type":"heading","level":3,"text":"Using FlyProgressHUD Built-in Styles","anchor":"Using-FlyProgressHUD-Built-in-Styles"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Import "},{"type":"codeVoice","code":"FlyProgressHUD"},{"type":"text","text":" for pre-built progress styles:"}]},{"type":"codeListing","code":["import FlyProgressHUD","","\/\/ Bar progress (butt cap)","HUD.show(to: view, mode: .progress(.buttBar))","","\/\/ Bar progress (round cap)","HUD.show(to: view, mode: .progress(.roundBar))","","\/\/ Circular progress ring","HUD.show(to: view, mode: .progress(.round))","","\/\/ Annular ring","HUD.show(to: view, mode: .progress(.annularRound))","","\/\/ Pie chart","HUD.show(to: view, mode: .progress(.pie))"],"syntax":"swift"},{"type":"heading","level":3,"text":"Customizing ProgressView Properties","anchor":"Customizing-ProgressView-Properties"},{"type":"codeListing","code":["let progressView = ProgressView(style: .annularRound)","progressView.progressTintColor = .systemGreen","progressView.trackTintColor = UIColor.systemGreen.withAlphaComponent(0.15)","progressView.lineWidth = 4.0","progressView.isLabelEnabled = true  \/\/ Show percentage text","progressView.labelFont = .boldSystemFont(ofSize: 12)","","let hud = HUD.show(to: view, mode: .custom(progressView))"],"syntax":"swift"},{"type":"heading","level":3,"text":"Implementing ProgressViewStyleable","anchor":"Implementing-ProgressViewStyleable"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create entirely custom progress animations:"}]},{"type":"codeListing","code":["struct GradientBarStyle: ProgressViewStyleable {","    func isEqual(_ object: Any) -> Bool {","        object is GradientBarStyle","    }","","    func makeAnimation() -> ProgressAnimationBuildable {","        GradientBarAnimation()","    }","","    var defaultSize: CGSize { CGSize(width: 120, height: 12) }","    var defaultProgressTintColor: UIColor { .systemBlue }","    var defaultTrackTintColor: UIColor? { .systemGray5 }","    var defaultLineWidth: CGFloat { 0 }","    var defaultIsLabelEnabled: Bool { false }","    var defaultLabelFont: UIFont { .boldSystemFont(ofSize: 8) }","}","","struct GradientBarAnimation: ProgressAnimationBuildable {","    func makeShape(in layer: CALayer, progress: CGFloat, color: UIColor, trackColor: UIColor?, lineWidth: CGFloat) {","        let size = layer.bounds.size","        let radius = size.height \/ 2.0","","        \/\/ Track","        if let trackColor {","            let trackPath = UIBezierPath(roundedRect: layer.bounds, cornerRadius: radius)","            trackColor.setFill()","            trackPath.fill()","        }","","        \/\/ Progress fill","        let progressWidth = size.width * progress","        let progressRect = CGRect(x: 0, y: 0, width: progressWidth, height: size.height)","        let progressPath = UIBezierPath(roundedRect: progressRect, cornerRadius: radius)","        color.setFill()","        progressPath.fill()","    }","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"Implementing ProgressViewable Protocol","anchor":"Implementing-ProgressViewable-Protocol"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For full control, implement "},{"type":"codeVoice","code":"ProgressViewable"},{"type":"text","text":" on your own UIView subclass:"}]},{"type":"codeListing","code":["class CustomProgressView: UIView, ProgressViewable {","    var progress: Float = 0.0 {","        didSet { setNeedsDisplay() }","    }","    var progressTintColor: UIColor? = .systemBlue","    var trackTintColor: UIColor? = .systemGray5","    var observedProgress: Progress?","","    override var intrinsicContentSize: CGSize {","        CGSize(width: 100, height: 100)","    }","","    override func draw(_ rect: CGRect) {","        \/\/ Your custom drawing","    }","}"],"syntax":"swift"},{"type":"heading","level":2,"text":"Custom Background Styles","anchor":"Custom-Background-Styles"},{"type":"heading","level":3,"text":"Blur Styles","anchor":"Blur-Styles"},{"type":"codeListing","code":["hud.contentView.style = .blur(.systemUltraThinMaterial)","hud.backgroundView.style = .blur(.systemMaterial)"],"syntax":"swift"},{"type":"heading","level":3,"text":"Solid Color","anchor":"Solid-Color"},{"type":"codeListing","code":["hud.contentView.style = .solidColor","hud.contentView.color = UIColor(white: 0.1, alpha: 0.9)"],"syntax":"swift"},{"type":"heading","level":3,"text":"Liquid Glass (iOS 26+)","anchor":"Liquid-Glass-iOS-26+"},{"type":"codeListing","code":["if #available(iOS 26.0, *) {","    hud.contentView.style = .glass","    hud.contentView.color = .systemBlue  \/\/ Glass tint color","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"Rounded Corners","anchor":"Rounded-Corners"},{"type":"codeListing","code":["\/\/ Custom radius","hud.contentView.roundedCorners = .radius(12.0)","","\/\/ Fully rounded (capsule)","hud.contentView.roundedCorners = .full"],"syntax":"swift"},{"type":"heading","level":2,"text":"Combining Custom Elements","anchor":"Combining-Custom-Elements"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Build complex HUD configurations by combining elements:"}]},{"type":"codeListing","code":["\/\/ Custom indicator with progress-style layout","let indicator = ActivityIndicatorView(style: .circleStrokeSpin)","indicator.color = .white","","let hud = HUD.show(to: view, mode: .custom(indicator)) { hud in","    hud.contentView.label.text = \"Syncing...\"","    hud.contentView.detailsLabel.text = \"3 of 10 files\"","    hud.contentView.contentColor = .white","    hud.contentView.style = .solidColor","    hud.contentView.color = UIColor.black.withAlphaComponent(0.85)","    hud.contentView.roundedCorners = .radius(16)","    hud.contentView.layout.hMargin = 24","    hud.contentView.layout.vMargin = 20","    hud.animation = .animation(.zoomInOut, damping: .default)","    hud.backgroundView.style = .solidColor","    hud.backgroundView.color = UIColor.black.withAlphaComponent(0.2)","}"],"syntax":"swift"}],"kind":"content"}],"sections":[],"abstract":[{"type":"text","text":"Build custom activity indicators, progress views, and display modes."}],"identifier":{"url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","interfaceLanguage":"swift"},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"],"title":"Guides","anchor":"Guides"}],"references":{"custom-indicator-decision.svg":{"variants":[{"svgID":"my-svg","url":"\/images\/flyhud.FlyHUD\/custom-indicator-decision.svg","traits":["1x","light"]}],"alt":"Flowchart decision tree: Simple rotation → RotateViewable; Complex animation → ActivityIndicatorViewStyleable; Any UIView → .custom(view).","identifier":"custom-indicator-decision.svg","type":"image"},"doc://flyhud.FlyHUD/documentation/FlyHUD/testing":{"url":"\/documentation\/flyhud\/testing","kind":"article","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing","abstract":[{"type":"text","text":"Strategies for unit testing, integration testing, and mocking FlyHUD in your app."}],"title":"Testing Guide","type":"topic","role":"article"},"doc://flyhud.FlyHUD/documentation/FlyHUD/advanced-features":{"url":"\/documentation\/flyhud\/advanced-features","kind":"article","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","abstract":[{"type":"text","text":"Explore keyboard tracking, animations, grace time, activity counts, and more."}],"title":"Advanced Features","type":"topic","role":"article"},"doc://flyhud.FlyHUD/documentation/FlyHUD":{"type":"topic","kind":"symbol","title":"FlyHUD","role":"collection","abstract":[{"type":"text","text":"A lightweight and easy-to-use HUD for displaying progress and status of ongoing tasks on iOS, tvOS, and visionOS."}],"url":"\/documentation\/flyhud","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"},"doc://flyhud.FlyHUD/documentation/FlyHUD/swiftui-integration":{"url":"\/documentation\/flyhud\/swiftui-integration","kind":"article","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","abstract":[{"type":"text","text":"Use FlyHUD declaratively in SwiftUI with the "},{"type":"codeVoice","code":"FlyHUDSwiftUI"},{"type":"text","text":" module."}],"title":"SwiftUI Integration","type":"topic","role":"article"},"custom-protocols.svg":{"variants":[{"svgID":"my-svg","url":"\/images\/flyhud.FlyHUD\/custom-protocols.svg","traits":["1x","light"]}],"alt":"Class diagram showing the relationships between ActivityIndicatorViewStyleable, ProgressViewStyleable, RotateViewable, ProgressViewable protocols and their concrete implementations.","identifier":"custom-protocols.svg","type":"image"},"doc://flyhud.FlyHUD/documentation/FlyHUD/best-practices":{"url":"\/documentation\/flyhud\/best-practices","kind":"article","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","abstract":[{"type":"text","text":"Recommended patterns for using FlyHUD effectively in production apps."}],"title":"Best Practices","type":"topic","role":"article"}}}