{"sections":[],"abstract":[{"type":"text","text":"Build custom activity indicators, progress views, and display modes."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"The following diagram shows the protocol hierarchy for custom indicators and progress views:","type":"text"}]},{"type":"paragraph","inlineContent":[{"identifier":"custom-protocols.svg","type":"image"}]},{"anchor":"Custom-Activity-Indicators","type":"heading","text":"Custom Activity Indicators","level":2},{"anchor":"Using-FlyIndicatorHUD-Built-in-Styles","type":"heading","text":"Using FlyIndicatorHUD Built-in Styles","level":3},{"type":"paragraph","inlineContent":[{"text":"Import ","type":"text"},{"type":"codeVoice","code":"FlyIndicatorHUD"},{"text":" to access pre-built indicator styles:","type":"text"}]},{"code":["import FlyIndicatorHUD","","\/\/ Ring clip rotation","HUD.show(to: view, mode: .indicator(.ringClipRotate))","","\/\/ Ball spin fade","HUD.show(to: view, mode: .indicator(.ballSpinFade))","","\/\/ Circle stroke spin","HUD.show(to: view, mode: .indicator(.circleStrokeSpin))","","\/\/ Circle arc dot spin","HUD.show(to: view, mode: .indicator(.circleArcDotSpin))"],"type":"codeListing","syntax":"swift"},{"anchor":"Customizing-ActivityIndicatorView-Properties","type":"heading","text":"Customizing ActivityIndicatorView Properties","level":3},{"code":["let indicator = ActivityIndicatorView(style: .circleStrokeSpin)","indicator.color = .systemBlue","indicator.trackColor = UIColor.systemBlue.withAlphaComponent(0.2)","indicator.lineWidth = 3.0","","HUD.show(to: view, mode: .custom(indicator), label: \"Loading\")"],"type":"codeListing","syntax":"swift"},{"anchor":"Choosing-Your-Customization-Approach","type":"heading","text":"Choosing Your Customization Approach","level":3},{"type":"paragraph","inlineContent":[{"identifier":"custom-indicator-decision.svg","type":"image"}]},{"anchor":"Implementing-ActivityIndicatorViewStyleable","type":"heading","text":"Implementing ActivityIndicatorViewStyleable","level":3},{"type":"paragraph","inlineContent":[{"text":"Create entirely custom indicator animations:","type":"text"}]},{"code":["struct PulseStyle: ActivityIndicatorViewStyleable {","    func isEqual(_ object: Any) -> Bool {","        object is PulseStyle","    }","","    func makeAnimation() -> ActivityIndicatorAnimationBuildable {","        PulseAnimation()","    }","","    var defaultSize: CGSize { CGSize(width: 40, height: 40) }","    var defaultColor: UIColor { .systemPurple }","    var defaultTrackColor: UIColor? { nil }","    var defaultLineWidth: CGFloat { 0 }","}","","struct PulseAnimation: ActivityIndicatorAnimationBuildable {","    func make(in layer: CALayer, color: UIColor, trackColor: UIColor?, lineWidth: CGFloat) {","        let circle = CAShapeLayer()","        circle.path = UIBezierPath(ovalIn: layer.bounds).cgPath","        circle.fillColor = color.cgColor","","        let animation = CABasicAnimation(keyPath: \"transform.scale\")","        animation.fromValue = 0.5","        animation.toValue = 1.0","        animation.duration = 0.8","        animation.autoreverses = true","        animation.repeatCount = .greatestFiniteMagnitude","        circle.add(animation, forKey: \"pulse\")","","        layer.addSublayer(circle)","    }","}","","\/\/ Usage","HUD.show(to: view, mode: .indicator(PulseStyle()))"],"type":"codeListing","syntax":"swift"},{"anchor":"Implementing-RotateViewable","type":"heading","text":"Implementing RotateViewable","level":3},{"type":"paragraph","inlineContent":[{"text":"For simple rotation-based indicators, conform to ","type":"text"},{"type":"codeVoice","code":"RotateViewable"},{"text":":","type":"text"}]},{"code":["class SpinnerView: UIView, RotateViewable {","    var duration: CFTimeInterval { 0.5 }","","    override init(frame: CGRect) {","        super.init(frame: frame)","        \/\/ VoiceOver: ContentView handles accessibility for the HUD.","        \/\/ Custom indicators should not be separate focus elements.","        isAccessibilityElement = false","    }","","    required init?(coder: NSCoder) { fatalError() }","","    override var intrinsicContentSize: CGSize {","        CGSize(width: 37, height: 37)","    }","","    override func draw(_ rect: CGRect) {","        \/\/ Draw your custom shape","    }","}","","\/\/ Usage — rotation is handled automatically","let spinner = SpinnerView()","HUD.show(to: view, mode: .custom(spinner))"],"type":"codeListing","syntax":"swift"},{"anchor":"Custom-Progress-Views","type":"heading","text":"Custom Progress Views","level":2},{"anchor":"Using-FlyProgressHUD-Built-in-Styles","type":"heading","text":"Using FlyProgressHUD Built-in Styles","level":3},{"type":"paragraph","inlineContent":[{"text":"Import ","type":"text"},{"type":"codeVoice","code":"FlyProgressHUD"},{"text":" for pre-built progress styles:","type":"text"}]},{"code":["import FlyProgressHUD","","\/\/ Bar progress (butt cap)","HUD.show(to: view, mode: .progress(.buttBar))","","\/\/ Bar progress (round cap)","HUD.show(to: view, mode: .progress(.roundBar))","","\/\/ Circular progress ring","HUD.show(to: view, mode: .progress(.round))","","\/\/ Annular ring","HUD.show(to: view, mode: .progress(.annularRound))","","\/\/ Pie chart","HUD.show(to: view, mode: .progress(.pie))"],"type":"codeListing","syntax":"swift"},{"anchor":"Customizing-ProgressView-Properties","type":"heading","text":"Customizing ProgressView Properties","level":3},{"code":["let progressView = ProgressView(style: .annularRound)","progressView.progressTintColor = .systemGreen","progressView.trackTintColor = UIColor.systemGreen.withAlphaComponent(0.15)","progressView.lineWidth = 4.0","progressView.isLabelEnabled = true  \/\/ Show percentage text","progressView.labelFont = .boldSystemFont(ofSize: 12)","","let hud = HUD.show(to: view, mode: .custom(progressView))"],"type":"codeListing","syntax":"swift"},{"anchor":"Implementing-ProgressViewStyleable","type":"heading","text":"Implementing ProgressViewStyleable","level":3},{"type":"paragraph","inlineContent":[{"text":"Create entirely custom progress animations:","type":"text"}]},{"code":["struct GradientBarStyle: ProgressViewStyleable {","    func isEqual(_ object: Any) -> Bool {","        object is GradientBarStyle","    }","","    func makeAnimation() -> ProgressAnimationBuildable {","        GradientBarAnimation()","    }","","    var defaultSize: CGSize { CGSize(width: 120, height: 12) }","    var defaultProgressTintColor: UIColor { .systemBlue }","    var defaultTrackTintColor: UIColor? { .systemGray5 }","    var defaultLineWidth: CGFloat { 0 }","    var defaultIsLabelEnabled: Bool { false }","    var defaultLabelFont: UIFont { .boldSystemFont(ofSize: 8) }","}","","struct GradientBarAnimation: ProgressAnimationBuildable {","    func makeShape(in layer: CALayer, progress: CGFloat, color: UIColor, trackColor: UIColor?, lineWidth: CGFloat) {","        let size = layer.bounds.size","        let radius = size.height \/ 2.0","","        \/\/ Track","        if let trackColor {","            let trackPath = UIBezierPath(roundedRect: layer.bounds, cornerRadius: radius)","            trackColor.setFill()","            trackPath.fill()","        }","","        \/\/ Progress fill","        let progressWidth = size.width * progress","        let progressRect = CGRect(x: 0, y: 0, width: progressWidth, height: size.height)","        let progressPath = UIBezierPath(roundedRect: progressRect, cornerRadius: radius)","        color.setFill()","        progressPath.fill()","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Implementing-ProgressViewable-Protocol","type":"heading","text":"Implementing ProgressViewable Protocol","level":3},{"type":"paragraph","inlineContent":[{"text":"For full control, implement ","type":"text"},{"type":"codeVoice","code":"ProgressViewable"},{"text":" on your own UIView subclass:","type":"text"}]},{"code":["class CustomProgressView: UIView, ProgressViewable {","    var progress: Float = 0.0 {","        didSet { setNeedsDisplay() }","    }","    var progressTintColor: UIColor? = .systemBlue","    var trackTintColor: UIColor? = .systemGray5","    var observedProgress: Progress?","","    override var intrinsicContentSize: CGSize {","        CGSize(width: 100, height: 100)","    }","","    override func draw(_ rect: CGRect) {","        \/\/ Your custom drawing","    }","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Custom-Background-Styles","type":"heading","text":"Custom Background Styles","level":2},{"anchor":"Blur-Styles","type":"heading","text":"Blur Styles","level":3},{"code":["hud.contentView.style = .blur(.systemUltraThinMaterial)","hud.backgroundView.style = .blur(.systemMaterial)"],"type":"codeListing","syntax":"swift"},{"anchor":"Solid-Color","type":"heading","text":"Solid Color","level":3},{"code":["hud.contentView.style = .solidColor","hud.contentView.color = UIColor(white: 0.1, alpha: 0.9)"],"type":"codeListing","syntax":"swift"},{"anchor":"Liquid-Glass-iOS-26+","type":"heading","text":"Liquid Glass (iOS 26+)","level":3},{"code":["if #available(iOS 26.0, *) {","    hud.contentView.style = .glass","    hud.contentView.color = .systemBlue  \/\/ Glass tint color","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Rounded-Corners","type":"heading","text":"Rounded Corners","level":3},{"code":["\/\/ Custom radius","hud.contentView.roundedCorners = .radius(12.0)","","\/\/ Fully rounded (capsule)","hud.contentView.roundedCorners = .full"],"type":"codeListing","syntax":"swift"},{"anchor":"Combining-Custom-Elements","type":"heading","text":"Combining Custom Elements","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Build complex HUD configurations by combining elements:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Custom indicator with progress-style layout","let indicator = ActivityIndicatorView(style: .circleStrokeSpin)","indicator.color = .white","","let hud = HUD.show(to: view, mode: .custom(indicator)) { hud in","    hud.contentView.label.text = \"Syncing...\"","    hud.contentView.detailsLabel.text = \"3 of 10 files\"","    hud.contentView.contentColor = .white","    hud.contentView.style = .solidColor","    hud.contentView.color = UIColor.black.withAlphaComponent(0.85)","    hud.contentView.roundedCorners = .radius(16)","    hud.contentView.layout.hMargin = 24","    hud.contentView.layout.vMargin = 20","    hud.animation = .animation(.zoomInOut, damping: .default)","    hud.backgroundView.style = .solidColor","    hud.backgroundView.color = UIColor.black.withAlphaComponent(0.2)","}"]}],"kind":"content"}],"kind":"article","metadata":{"modules":[{"name":"FlyHUD"}],"title":"Custom UI","roleHeading":"Article","role":"article"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flyhud\/custom-ui"]}],"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui"},"seeAlsoSections":[{"identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"],"anchor":"Guides","title":"Guides","generated":true}],"references":{"custom-indicator-decision.svg":{"variants":[{"svgID":"my-svg","url":"\/images\/flyhud.FlyHUD\/custom-indicator-decision.svg","traits":["1x","light"]}],"identifier":"custom-indicator-decision.svg","type":"image","alt":"Flowchart decision tree: Simple rotation → RotateViewable; Complex animation → ActivityIndicatorViewStyleable; Any UIView → .custom(view)."},"doc://flyhud.FlyHUD/documentation/FlyHUD/testing":{"abstract":[{"text":"Strategies for unit testing, integration testing, and mocking FlyHUD in your app.","type":"text"}],"kind":"article","type":"topic","role":"article","title":"Testing Guide","url":"\/documentation\/flyhud\/testing","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"},"doc://flyhud.FlyHUD/documentation/FlyHUD/best-practices":{"url":"\/documentation\/flyhud\/best-practices","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","abstract":[{"type":"text","text":"Recommended patterns for using FlyHUD effectively in production apps."}],"title":"Best Practices","type":"topic","kind":"article","role":"article"},"doc://flyhud.FlyHUD/documentation/FlyHUD":{"kind":"symbol","type":"topic","abstract":[{"text":"A lightweight and easy-to-use HUD for displaying progress and status of ongoing tasks on iOS, tvOS, and visionOS.","type":"text"}],"url":"\/documentation\/flyhud","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD","role":"collection","title":"FlyHUD"},"doc://flyhud.FlyHUD/documentation/FlyHUD/advanced-features":{"abstract":[{"text":"Explore keyboard tracking, animations, grace time, activity counts, and more.","type":"text"}],"kind":"article","type":"topic","role":"article","title":"Advanced Features","url":"\/documentation\/flyhud\/advanced-features","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features"},"doc://flyhud.FlyHUD/documentation/FlyHUD/swiftui-integration":{"abstract":[{"text":"Use FlyHUD declaratively in SwiftUI with the ","type":"text"},{"type":"codeVoice","code":"FlyHUDSwiftUI"},{"text":" module.","type":"text"}],"kind":"article","type":"topic","role":"article","title":"SwiftUI Integration","url":"\/documentation\/flyhud\/swiftui-integration","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration"},"custom-protocols.svg":{"variants":[{"svgID":"my-svg","url":"\/images\/flyhud.FlyHUD\/custom-protocols.svg","traits":["1x","light"]}],"identifier":"custom-protocols.svg","type":"image","alt":"Class diagram showing the relationships be