{"metadata":{"modules":[{"name":"FlyHUD"}],"role":"article","roleHeading":"Article","title":"Advanced Features"},"abstract":[{"text":"Explore keyboard tracking, animations, grace time, activity counts, and more.","type":"text"}],"seeAlsoSections":[{"generated":true,"title":"Guides","identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"],"anchor":"Guides"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"content":[{"type":"heading","anchor":"Animation-System","text":"Animation System","level":2},{"type":"paragraph","inlineContent":[{"text":"FlyHUD provides a rich animation system for showing and hiding the HUD.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"animation-states.svg"}]},{"type":"heading","anchor":"Animation-Styles","text":"Animation Styles","level":3},{"type":"paragraph","inlineContent":[{"text":"Configure via ","type":"text"},{"isActive":true,"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/HUD\/Animation-swift.struct","type":"reference"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Fade (default)","HUD.show(to: view, using: .animation(.fade))","","\/\/ Zoom in when appearing, zoom out when disappearing","HUD.show(to: view, using: .animation(.zoomInOut))","","\/\/ Slide up when appearing, slide down when disappearing","HUD.show(to: view, using: .animation(.slideUpDown))"]},{"type":"paragraph","inlineContent":[{"text":"Available styles:","type":"text"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Style","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"inlineContent":[{"code":".none","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"No animation","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".fade","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Opacity transition"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".zoomInOut"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Zoom in on show, zoom out on hide","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".zoomOutIn","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Zoom out on show, zoom in on hide"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".zoomIn","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Always zoom in"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".zoomOut"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Always zoom out","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".slideUpDown","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Slide up on show, slide down on hide","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideDownUp","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Slide down on show, slide up on hide"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideUp","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Always slide up","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".slideDown"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always slide down"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".slideRightLeft"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Slide right on show, slide left on hide"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideLeftRight","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Slide left on show, slide right on hide","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".slideRight"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always slide right"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".slideLeft"}]}],[{"type":"paragraph","inlineContent":[{"text":"Always slide left","type":"text"}]}]]],"header":"row"},{"text":"Spring Damping","anchor":"Spring-Damping","type":"heading","level":3},{"inlineContent":[{"text":"Add bounce effects with spring damping:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Default damping (0.65)","HUD.show(to: view, using: .animation(.zoomInOut, damping: .default))","","\/\/ Custom damping ratio (lower = more bounce)","HUD.show(to: view, using: .animation(.slideUpDown, damping: .ratio(0.5)))","","\/\/ No damping (smooth deceleration)","HUD.show(to: view, using: .animation(.fade, damping: .disable))"]},{"level":3,"type":"heading","text":"Animation Duration","anchor":"Animation-Duration"},{"syntax":"swift","type":"codeListing","code":["HUD.show(to: view, using: .animation(.fade, duration: 0.5))"]},{"level":3,"type":"heading","text":"Per-Hide Animation","anchor":"Per-Hide-Animation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Override animation when hiding:"}]},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view, using: .animation(.slideUp))","","\/\/ Hide with a different animation","hud.hide(using: .animation(.slideDown))"]},{"level":2,"type":"heading","text":"Keyboard Layout Guide (iOS)","anchor":"Keyboard-Layout-Guide-iOS"},{"type":"paragraph","inlineContent":[{"text":"FlyHUD can automatically adjust its position when the keyboard appears.","type":"text"}]},{"level":3,"type":"heading","text":"Global Configuration","anchor":"Global-Configuration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set once in "},{"type":"codeVoice","code":"AppDelegate"},{"type":"text","text":" or "},{"type":"codeVoice","code":"SceneDelegate"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Center HUD in the visible area above keyboard","HUD.keyboardGuide = .center()","","\/\/ Center with vertical offset","HUD.keyboardGuide = .center(-20.0)","","\/\/ Keep content bottom above keyboard","HUD.keyboardGuide = .bottom(8.0)"]},{"level":3,"type":"heading","text":"Per-Instance Configuration","anchor":"Per-Instance-Configuration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Override the global setting for individual HUDs:"}]},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view, label: \"Verifying...\")","hud.keyboardGuide = .center()"]},{"level":3,"type":"heading","text":"Keyboard Guide Modes","anchor":"Keyboard-Guide-Modes"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Mode","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Behavior","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".disable","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No keyboard tracking (default)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".center(offsetY)"}]}],[{"type":"paragraph","inlineContent":[{"text":"Center HUD in visible area above keyboard","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".bottom(spacing)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Position content bottom relative to keyboard top"}]}]]],"type":"table","header":"row"},{"type":"aside","content":[{"inlineContent":[{"text":"Keyboard guide is only available on iOS. It has no effect on tvOS or visionOS.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note"},{"anchor":"Grace-Time","type":"heading","level":2,"text":"Grace Time"},{"inlineContent":[{"text":"The following diagram illustrates how ","type":"text"},{"type":"codeVoice","code":"graceTime"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"minShowTime"},{"text":" interact:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"grace-time.svg"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Prevent HUD from appearing for very short tasks:"}],"type":"paragraph"},{"code":["let hud = HUD(with: view)","hud.graceTime = 0.5  \/\/ Don't show if task completes within 0.5s","view.addSubview(hud)","hud.show()","","\/\/ If hide() is called within 0.5s, HUD never appears","DispatchQueue.main.asyncAfter(deadline: .now() + 0.3) {","    hud.hide()  \/\/ HUD was never shown","}"],"syntax":"swift","type":"codeListing"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"graceTime"},{"type":"text","text":" must be set before calling "},{"type":"codeVoice","code":"show()"},{"type":"text","text":". The convenience"},{"type":"text","text":" "},{"type":"text","text":"method "},{"type":"codeVoice","code":"HUD.show(to:)"},{"type":"text","text":" does not support grace time — use manual initialization instead."}]}],"style":"important","name":"Important"},{"anchor":"Minimum-Show-Time","type":"heading","level":2,"text":"Minimum Show Time"},{"inlineContent":[{"type":"text","text":"Prevent HUD from flickering by enforcing a minimum display duration:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD(with: view)","hud.minShowTime = 1.0  \/\/ Show for at least 1 second","view.addSubview(hud)","hud.show()","","\/\/ Even if hide() is called immediately, HUD stays for 1s","hud.hide()"]},{"text":"Activity Count","type":"heading","level":2,"anchor":"Activity-Count"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"activity-count.svg"}]},{"type":"paragraph","inlineContent":[{"text":"Track multiple show\/hide pairs with a reference counter:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view)","hud.isCountEnabled = true","","\/\/ Each show increments count","hud.show()  \/\/ count = 2","hud.show()  \/\/ count = 3","","\/\/ Each hide decrements count; HUD hides only when count reaches 0","hud.hide()  \/\/ count = 2, still visible","hud.hide()  \/\/ count = 1, still visible","hud.hide()  \/\/ count = 0, hides"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is useful when multiple subsystems independently request the HUD."}]},{"text":"Event Delivery","type":"heading","level":2,"anchor":"Event-Delivery"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Control whether touches pass through the HUD overlay:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Default: HUD blocks all touches","hud.isEventDeliveryEnabled = false","","\/\/ Allow touches outside contentView to pass through","hud.isEventDeliveryEnabled = true"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When enabled, only touches within the content card are captured by the HUD."},{"type":"text","text":" "},{"type":"text","text":"Touches in the surrounding overlay area pass through to the parent view."}]},{"text":"Layout Configuration","type":"heading","level":2,"anchor":"Layout-Configuration"},{"text":"Offset","type":"heading","level":3,"anchor":"Offset"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Position the HUD content relative to center:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Bottom of screen","hud.layout.offset = .h.vMaxOffset","","\/\/ Top of screen","hud.layout.offset = .h.vMinOffset","","\/\/ Centered (default)","hud.layout.offset = .zero"]},{"text":"Edge Insets","type":"heading","level":3,"anchor":"Edge-Insets"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set minimum distance from HUD edges:"}]},{"syntax":"swift","type":"codeListing","code":["hud.layout.edgeInsets = UIEdgeInsets(top: 40, left: 20, bottom: 40, right: 20)"]},{"text":"Safe Area","type":"heading","level":3,"anchor":"Safe-Area"},{"type":"paragraph","inlineContent":[{"text":"Control whether safe area insets are respected:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["hud.layout.isSafeAreaLayoutGuideEnabled = true  \/\/ Default"]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"isSafeAreaLayoutGuideEnabled","type":"codeVoice"},{"type":"text","text":" must be set before the first "},{"code":"show()","type":"codeVoice"},{"type":"text","text":" call."}]}],"type":"aside","name":"Warning","style":"warning"},{"text":"Content View Layout","level":2,"type":"heading","anchor":"Content-View-Layout"},{"type":"paragraph","inlineContent":[{"text":"Fine-tune the content card’s internal layout:","type":"text"}]},{"code":["\/\/ Margins between card edge and content","hud.contentView.layout.hMargin = 24.0","hud.contentView.layout.vMargin = 24.0","","\/\/ Spacing between elements","hud.contentView.layout.hSpacing = 12.0","hud.contentView.layout.vSpacing = 8.0","","\/\/ Minimum content size","hud.contentView.layout.minSize = CGSize(width: 100, height: 100)","","\/\/ Force square aspect ratio","hud.contentView.layout.isSquare = true","","\/\/ Text alignment","hud.contentView.layout.alignment = .leading"],"type":"codeListing","syntax":"swift"},{"text":"Motion Effects","level":2,"type":"heading","anchor":"Motion-Effects"},{"type":"paragraph","inlineContent":[{"text":"Add a parallax tilt effect to the content view:","type":"text"}]},{"code":["hud.contentView.isMotionEffectsEnabled = true"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"text":"Subclassing","anchor":"Subclassing"},{"type":"paragraph","inlineContent":[{"code":"HUD","type":"codeVoice"},{"type":"text","text":" is an "},{"code":"open","type":"codeVoice"},{"type":"text","text":" class. Override "},{"code":"makeHUD(with:)","type":"codeVoice"},{"text":" to provide custom instances:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class MyHUD: HUD {","    override class func makeHUD(with view: UIView) -> HUD {","        let hud = MyHUD(frame: view.bounds)","        \/\/ Custom setup","        return hud","    }","}"]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/flyhud\/advanced-features"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","identifier":{"url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"references":{"doc://flyhud.FlyHUD/documentation/FlyHUD/swiftui-integration":{"type":"topic","kind":"article","abstract":[{"text":"Use FlyHUD declaratively in SwiftUI with the ","type":"text"},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"text":" module.","type":"text"}],"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","title":"SwiftUI Integration","url":"\/documentation\/flyhud\/swiftui-integration","role":"article"},"activity-count.svg":{"variants":[{"traits":["1x","light"],"url":"\/images\/flyhud.FlyHUD\/activity-count.svg","svgID":"my-svg"}],"alt":"State diagram showing activity count reference counter: Idle(0) → Active(1) → Active(2) → Active(3), decrements on hide(), HUD only hides when count reaches 0.","type":"image","identifier":"activity-count.svg"},"doc://flyhud.FlyHUD/documentation/FlyHUD/custom-ui":{"type":"topic","kind":"article","abstract":[{"type":"text","text":"Build custom activity indicators, progress views, and display modes."}],"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","title":"Custom UI","url":"\/documentation\/flyhud\/custom-ui","role":"article"},"grace-time.svg":{"variants":[{"traits":["1x","light"],"url":"\/images\/flyhud.FlyHUD\/grace-time.svg","svgID":"my-svg"}],"alt":"Grace Time and MinShowTime sequence diagram showing two scenarios: a fast task where the HUD never appears, and a slow task where the HUD respects minimum display duration.","type":"image","identifier":"grace-time.svg"},"doc://flyhud.FlyHUD/documentation