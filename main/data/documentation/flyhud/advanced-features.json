{"sections":[],"identifier":{"url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","interfaceLanguage":"swift"},"seeAlsoSections":[{"generated":true,"anchor":"Guides","title":"Guides","identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"roleHeading":"Article","modules":[{"name":"FlyHUD"}],"role":"article","title":"Advanced Features"},"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"abstract":[{"type":"text","text":"Explore keyboard tracking, animations, grace time, activity counts, and more."}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Animation-System","level":2,"text":"Animation System","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD provides a rich animation system for showing and hiding the HUD."}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"animation-states.svg"}]},{"type":"heading","anchor":"Animation-Styles","level":3,"text":"Animation Styles"},{"inlineContent":[{"type":"text","text":"Configure via "},{"isActive":true,"type":"reference","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/HUD\/Animation-swift.struct"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Fade (default)","HUD.show(to: view, using: .animation(.fade))","","\/\/ Zoom in when appearing, zoom out when disappearing","HUD.show(to: view, using: .animation(.zoomInOut))","","\/\/ Slide up when appearing, slide down when disappearing","HUD.show(to: view, using: .animation(.slideUpDown))"]},{"inlineContent":[{"type":"text","text":"Available styles:"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Style"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Description"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".none"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No animation"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".fade"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Opacity transition"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".zoomInOut"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Zoom in on show, zoom out on hide"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".zoomOutIn"}]}],[{"type":"paragraph","inlineContent":[{"text":"Zoom out on show, zoom in on hide","type":"text"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":".zoomIn"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always zoom in"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":".zoomOut"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always zoom out"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":".slideUpDown"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Slide up on show, slide down on hide"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideDownUp","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Slide down on show, slide up on hide"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".slideUp"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always slide up"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".slideDown"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always slide down"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".slideRightLeft"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Slide right on show, slide left on hide"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".slideLeftRight"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Slide left on show, slide right on hide"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".slideRight"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always slide right"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".slideLeft"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always slide left"}]}]]],"type":"table","header":"row"},{"level":3,"text":"Spring Damping","type":"heading","anchor":"Spring-Damping"},{"inlineContent":[{"type":"text","text":"Add bounce effects with spring damping:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Default damping (0.65)","HUD.show(to: view, using: .animation(.zoomInOut, damping: .default))","","\/\/ Custom damping ratio (lower = more bounce)","HUD.show(to: view, using: .animation(.slideUpDown, damping: .ratio(0.5)))","","\/\/ No damping (smooth deceleration)","HUD.show(to: view, using: .animation(.fade, damping: .disable))"]},{"level":3,"text":"Animation Duration","type":"heading","anchor":"Animation-Duration"},{"syntax":"swift","type":"codeListing","code":["HUD.show(to: view, using: .animation(.fade, duration: 0.5))"]},{"level":3,"text":"Per-Hide Animation","type":"heading","anchor":"Per-Hide-Animation"},{"inlineContent":[{"type":"text","text":"Override animation when hiding:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view, using: .animation(.slideUp))","","\/\/ Hide with a different animation","hud.hide(using: .animation(.slideDown))"]},{"level":2,"text":"Keyboard Layout Guide (iOS)","type":"heading","anchor":"Keyboard-Layout-Guide-iOS"},{"inlineContent":[{"type":"text","text":"FlyHUD can automatically adjust its position when the keyboard appears."}],"type":"paragraph"},{"level":3,"text":"Global Configuration","type":"heading","anchor":"Global-Configuration"},{"inlineContent":[{"type":"text","text":"Set once in "},{"type":"codeVoice","code":"AppDelegate"},{"type":"text","text":" or "},{"type":"codeVoice","code":"SceneDelegate"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Center HUD in the visible area above keyboard","HUD.keyboardGuide = .center()","","\/\/ Center with vertical offset","HUD.keyboardGuide = .center(-20.0)","","\/\/ Keep content bottom above keyboard","HUD.keyboardGuide = .bottom(8.0)"]},{"level":3,"text":"Per-Instance Configuration","type":"heading","anchor":"Per-Instance-Configuration"},{"inlineContent":[{"type":"text","text":"Override the global setting for individual HUDs:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view, label: \"Verifying...\")","hud.keyboardGuide = .center()"]},{"level":3,"text":"Keyboard Guide Modes","type":"heading","anchor":"Keyboard-Guide-Modes"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Behavior"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".disable"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No keyboard tracking (default)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".center(offsetY)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Center HUD in visible area above keyboard"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".bottom(spacing)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Position content bottom relative to keyboard top"}]}]]],"type":"table","header":"row"},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Keyboard guide is only available on iOS. It has no effect on tvOS or visionOS."}]}],"style":"note"},{"level":2,"text":"Grace Time","type":"heading","anchor":"Grace-Time"},{"inlineContent":[{"type":"text","text":"The following diagram illustrates how "},{"type":"codeVoice","code":"graceTime"},{"type":"text","text":" and "},{"type":"codeVoice","code":"minShowTime"},{"type":"text","text":" interact:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"grace-time.svg"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Prevent HUD from appearing for very short tasks:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD(with: view)","hud.graceTime = 0.5  \/\/ Don't show if task completes within 0.5s","view.addSubview(hud)","hud.show()","","\/\/ If hide() is called within 0.5s, HUD never appears","DispatchQueue.main.asyncAfter(deadline: .now() + 0.3) {","    hud.hide()  \/\/ HUD was never shown","}"]},{"name":"Important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"graceTime"},{"type":"text","text":" must be set before calling "},{"type":"codeVoice","code":"show()"},{"type":"text","text":". The convenience"},{"type":"text","text":" "},{"type":"text","text":"method "},{"type":"codeVoice","code":"HUD.show(to:)"},{"type":"text","text":" does not support grace time — use manual initialization instead."}]}],"style":"important"},{"level":2,"text":"Minimum Show Time","type":"heading","anchor":"Minimum-Show-Time"},{"inlineContent":[{"type":"text","text":"Prevent HUD from flickering by enforcing a minimum display duration:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD(with: view)","hud.minShowTime = 1.0  \/\/ Show for at least 1 second","view.addSubview(hud)","hud.show()","","\/\/ Even if hide() is called immediately, HUD stays for 1s","hud.hide()"]},{"level":2,"text":"Activity Count","type":"heading","anchor":"Activity-Count"},{"inlineContent":[{"type":"image","identifier":"activity-count.svg"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Track multiple show\/hide pairs with a reference counter:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view)","hud.isCountEnabled = true","","\/\/ Each show increments count","hud.show()  \/\/ count = 2","hud.show()  \/\/ count = 3","","\/\/ Each hide decrements count; HUD hides only when count reaches 0","hud.hide()  \/\/ count = 2, still visible","hud.hide()  \/\/ count = 1, still visible","hud.hide()  \/\/ count = 0, hides"]},{"inlineContent":[{"type":"text","text":"This is useful when multiple subsystems independently request the HUD."}],"type":"paragraph"},{"level":2,"text":"Event Delivery","type":"heading","anchor":"Event-Delivery"},{"inlineContent":[{"type":"text","text":"Control whether touches pass through the HUD overlay:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Default: HUD blocks all touches","hud.isEventDeliveryEnabled = false","","\/\/ Allow touches outside contentView to pass through","hud.isEventDeliveryEnabled = true"]},{"inlineContent":[{"type":"text","text":"When enabled, only touches within the content card are captured by the HUD."},{"type":"text","text":" "},{"type":"text","text":"Touches in the surrounding overlay area pass through to the parent view."}],"type":"paragraph"},{"level":2,"text":"Layout Configuration","type":"heading","anchor":"Layout-Configuration"},{"level":3,"text":"Offset","type":"heading","anchor":"Offset"},{"inlineContent":[{"type":"text","text":"Position the HUD content relative to center:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Bottom of screen","hud.layout.offset = .h.vMaxOffset","","\/\/ Top of screen","hud.layout.offset = .h.vMinOffset","","\/\/ Centered (default)","hud.layout.offset = .zero"]},{"level":3,"text":"Edge Insets","type":"heading","anchor":"Edge-Insets"},{"inlineContent":[{"type":"text","text":"Set minimum distance from HUD edges:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["hud.layout.edgeInsets = UIEdgeInsets(top: 40, left: 20, bottom: 40, right: 20)"]},{"level":3,"text":"Safe Area","type":"heading","anchor":"Safe-Area"},{"inlineContent":[{"type":"text","text":"Control whether safe area insets are respected:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["hud.layout.isSafeAreaLayoutGuideEnabled = true  \/\/ Default"]},{"name":"Warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"isSafeAreaLayoutGuideEnabled"},{"text":" must be set before the first ","type":"text"},{"code":"show()","type":"codeVoice"},{"text":" call.","type":"text"}]}],"style":"warning"},{"level":2,"text":"Content View Layout","type":"heading","anchor":"Content-View-Layout"},{"inlineContent":[{"text":"Fine-tune the content card’s internal layout:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Margins between card edge and content","hud.contentView.layout.hMargin = 24.0","hud.contentView.layout.vMargin = 24.0","","\/\/ Spacing between elements","hud.contentView.layout.hSpacing = 12.0","hud.contentView.layout.vSpacing = 8.0","","\/\/ Minimum content size","hud.contentView.layout.minSize = CGSize(width: 100, height: 100)","","\/\/ Force square aspect ratio","hud.contentView.layout.isSquare = true","","\/\/ Text alignment","hud.contentView.layout.alignment = .leading"],"syntax":"swift"},{"type":"heading","anchor":"Motion-Effects","level":2,"text":"Motion Effects"},{"type":"paragraph","inlineContent":[{"text":"Add a parallax tilt effect to the content view:","type":"text"}]},{"type":"codeListing","code":["hud.contentView.isMotionEffectsEnabled = true"],"syntax":"swift"},{"type":"heading","anchor":"Subclassing","level":2,"text":"Subclassing"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"HUD"},{"type":"text","text":" is an "},{"type":"codeVoice","code":"open"},{"type":"text","text":" class. Override "},{"type":"codeVoice","code":"makeHUD(with:)"},{"type":"text","text":" to provide custom instances:"}]},{"type":"codeListing","code":["class MyHUD: HUD {","    override class func makeHUD(with view: UIView) -> HUD {","        let hud = MyHUD(frame: view.bounds)","        \/\/ Custom setup","        return hud","    }","}"],"syntax":"swift"}]}],"variants":[{"paths":["\/documentation\/flyhud\/advanced-features"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","references":{"doc://flyhud.FlyHUD/documentation/FlyHUD/best-practices":{"abstract":[{"type":"text","text":"Recommended patterns for using FlyHUD effectively in production apps."}],"role":"article","title":"Best Practices","url":"\/documentation\/flyhud\/best-practices","type":"topic","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","kind":"article"},"doc://flyhud.FlyHUD/documentation/FlyHUD/HUD/Animation-swift.struct":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Animation"}],"abstract":[],"kind":"symbol","url":"\/documentation\/flyhud\/hud\/animation-swift.struct","navigatorTitle":[{"kind":"identifier","text":"Animation"}],"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/HUD\/Animation-swift.struct","title":"HUD.Animation","type":"topic","role":"symbol"},"doc://flyhud.FlyHUD/documentation/FlyHUD/swiftui-integration":{"abstract":[{"type":"text","text":"Use FlyHUD declaratively in SwiftUI with the "},{"type":"codeVoice","code":"FlyHUDSwiftUI"},{"type":"text","text":" module."}],"role":"article","url":"\/documentation\/flyhud\/swiftui-integration","title":"SwiftUI Integration","type":"topic","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","kind":"article"},"grace-time.svg":{"type":"image","identifier":"grace-time.svg","variants":[{"svgID":"my-svg","traits":["1x","light"],"url":"\/images\/flyhud.FlyHUD\/grace-time.svg"}],"alt":"Grace Time and MinShowTime sequence diagram showing 