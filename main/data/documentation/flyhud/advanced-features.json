{"metadata":{"title":"Advanced Features","roleHeading":"Article","role":"article","modules":[{"name":"FlyHUD"}]},"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features"},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flyhud\/advanced-features"]}],"seeAlsoSections":[{"title":"Guides","anchor":"Guides","generated":true,"identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"]}],"kind":"article","primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Animation-System","text":"Animation System"},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD provides a rich animation system for showing and hiding the HUD."}]},{"type":"paragraph","inlineContent":[{"identifier":"animation-states.svg","type":"image"}]},{"anchor":"Animation-Styles","text":"Animation Styles","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Configure via "},{"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/HUD\/Animation-swift.struct","type":"reference","isActive":true},{"type":"text","text":":"}]},{"code":["\/\/ Fade (default)","HUD.show(to: view, using: .animation(.fade))","","\/\/ Zoom in when appearing, zoom out when disappearing","HUD.show(to: view, using: .animation(.zoomInOut))","","\/\/ Slide up when appearing, slide down when disappearing","HUD.show(to: view, using: .animation(.slideUpDown))"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Available styles:","type":"text"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Style"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".none","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"No animation","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".fade","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Opacity transition","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".zoomInOut","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Zoom in on show, zoom out on hide","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".zoomOutIn","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Zoom out on show, zoom in on hide","type":"text"}]}]],[[{"inlineContent":[{"code":".zoomIn","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Always zoom in","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".zoomOut","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"Always zoom out"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".slideUpDown","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Slide up on show, slide down on hide"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".slideDownUp","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Slide down on show, slide up on hide"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".slideUp"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always slide up"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideDown","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always slide down"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideRightLeft","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Slide right on show, slide left on hide","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideLeftRight","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Slide left on show, slide right on hide"}]}]],[[{"inlineContent":[{"code":".slideRight","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always slide right"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideLeft","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always slide left"}]}]]],"header":"row"},{"type":"heading","level":3,"anchor":"Spring-Damping","text":"Spring Damping"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add bounce effects with spring damping:"}]},{"code":["\/\/ Default damping (0.65)","HUD.show(to: view, using: .animation(.zoomInOut, damping: .default))","","\/\/ Custom damping ratio (lower = more bounce)","HUD.show(to: view, using: .animation(.slideUpDown, damping: .ratio(0.5)))","","\/\/ No damping (smooth deceleration)","HUD.show(to: view, using: .animation(.fade, damping: .disable))"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"anchor":"Animation-Duration","text":"Animation Duration"},{"code":["HUD.show(to: view, using: .animation(.fade, duration: 0.5))"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"anchor":"Per-Hide-Animation","text":"Per-Hide Animation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Override animation when hiding:"}]},{"code":["let hud = HUD.show(to: view, using: .animation(.slideUp))","","\/\/ Hide with a different animation","hud.hide(using: .animation(.slideDown))"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"anchor":"Keyboard-Layout-Guide-iOS","text":"Keyboard Layout Guide (iOS)"},{"inlineContent":[{"type":"text","text":"FlyHUD can automatically adjust its position when the keyboard appears."}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Global-Configuration","text":"Global Configuration"},{"inlineContent":[{"type":"text","text":"Set once in "},{"code":"AppDelegate","type":"codeVoice"},{"type":"text","text":" or "},{"code":"SceneDelegate","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["\/\/ Center HUD in the visible area above keyboard","HUD.keyboardGuide = .center()","","\/\/ Center with vertical offset","HUD.keyboardGuide = .center(-20.0)","","\/\/ Keep content bottom above keyboard","HUD.keyboardGuide = .bottom(8.0)"],"syntax":"swift","type":"codeListing"},{"anchor":"Per-Instance-Configuration","text":"Per-Instance Configuration","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Override the global setting for individual HUDs:"}],"type":"paragraph"},{"code":["let hud = HUD.show(to: view, label: \"Verifying...\")","hud.keyboardGuide = .center()"],"syntax":"swift","type":"codeListing"},{"anchor":"Keyboard-Guide-Modes","text":"Keyboard Guide Modes","level":3,"type":"heading"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mode"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Behavior"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".disable","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"No keyboard tracking (default)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".center(offsetY)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Center HUD in visible area above keyboard","type":"text"}]}]],[[{"inlineContent":[{"code":".bottom(spacing)","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Position content bottom relative to keyboard top","type":"text"}]}]]],"type":"table"},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"Keyboard guide is only available on iOS. It has no effect on tvOS or visionOS."}],"type":"paragraph"}],"type":"aside","style":"note"},{"level":2,"anchor":"Grace-Time","type":"heading","text":"Grace Time"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following diagram illustrates how "},{"code":"graceTime","type":"codeVoice"},{"type":"text","text":" and "},{"code":"minShowTime","type":"codeVoice"},{"text":" interact:","type":"text"}]},{"inlineContent":[{"identifier":"grace-time.svg","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"Prevent HUD from appearing for very short tasks:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let hud = HUD(with: view)","hud.graceTime = 0.5  \/\/ Don't show if task completes within 0.5s","view.addSubview(hud)","hud.show()","","\/\/ If hide() is called within 0.5s, HUD never appears","DispatchQueue.main.asyncAfter(deadline: .now() + 0.3) {","    hud.hide()  \/\/ HUD was never shown","}"],"type":"codeListing"},{"name":"Important","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"graceTime"},{"type":"text","text":" must be set before calling "},{"type":"codeVoice","code":"show()"},{"type":"text","text":". The convenience"},{"type":"text","text":" "},{"type":"text","text":"method "},{"type":"codeVoice","code":"HUD.show(to:)"},{"type":"text","text":" does not support grace time — use manual initialization instead."}]}],"type":"aside"},{"type":"heading","level":2,"anchor":"Minimum-Show-Time","text":"Minimum Show Time"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prevent HUD from flickering by enforcing a minimum display duration:"}]},{"code":["let hud = HUD(with: view)","hud.minShowTime = 1.0  \/\/ Show for at least 1 second","view.addSubview(hud)","hud.show()","","\/\/ Even if hide() is called immediately, HUD stays for 1s","hud.hide()"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":2,"anchor":"Activity-Count","text":"Activity Count"},{"type":"paragraph","inlineContent":[{"identifier":"activity-count.svg","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Track multiple show\/hide pairs with a reference counter:"}]},{"code":["let hud = HUD.show(to: view)","hud.isCountEnabled = true","","\/\/ Each show increments count","hud.show()  \/\/ count = 2","hud.show()  \/\/ count = 3","","\/\/ Each hide decrements count; HUD hides only when count reaches 0","hud.hide()  \/\/ count = 2, still visible","hud.hide()  \/\/ count = 1, still visible","hud.hide()  \/\/ count = 0, hides"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This is useful when multiple subsystems independently request the HUD.","type":"text"}]},{"type":"heading","level":2,"anchor":"Event-Delivery","text":"Event Delivery"},{"inlineContent":[{"text":"Control whether touches pass through the HUD overlay:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Default: HUD blocks all touches","hud.isEventDeliveryEnabled = false","","\/\/ Allow touches outside contentView to pass through","hud.isEventDeliveryEnabled = true"],"type":"codeListing"},{"inlineContent":[{"text":"When enabled, only touches within the content card are captured by the HUD.","type":"text"},{"text":" ","type":"text"},{"text":"Touches in the surrounding overlay area pass through to the parent view.","type":"text"}],"type":"paragraph"},{"text":"Layout Configuration","anchor":"Layout-Configuration","level":2,"type":"heading"},{"anchor":"Offset","text":"Offset","level":3,"type":"heading"},{"inlineContent":[{"text":"Position the HUD content relative to center:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Bottom of screen","hud.layout.offset = .h.vMaxOffset","","\/\/ Top of screen","hud.layout.offset = .h.vMinOffset","","\/\/ Centered (default)","hud.layout.offset = .zero"],"type":"codeListing"},{"text":"Edge Insets","anchor":"Edge-Insets","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Set minimum distance from HUD edges:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["hud.layout.edgeInsets = UIEdgeInsets(top: 40, left: 20, bottom: 40, right: 20)"]},{"anchor":"Safe-Area","text":"Safe Area","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Control whether safe area insets are respected:"}],"type":"paragraph"},{"code":["hud.layout.isSafeAreaLayoutGuideEnabled = true  \/\/ Default"],"type":"codeListing","syntax":"swift"},{"content":[{"inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"isSafeAreaLayoutGuideEnabled"},{"text":" must be set before the first ","type":"text"},{"code":"show()","type":"codeVoice"},{"text":" call.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"warning","name":"Warning"},{"text":"Content View Layout","anchor":"Content-View-Layout","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Fine-tune the content card’s internal layout:","type":"text"}]},{"syntax":"swift","code":["\/\/ Margins between card edge and content","hud.contentView.layout.hMargin = 24.0","hud.contentView.layout.vMargin = 24.0","","\/\/ Spacing between elements","hud.contentView.layout.hSpacing = 12.0","hud.contentView.layout.vSpacing = 8.0","","\/\/ Minimum content size","hud.contentView.layout.minSize = CGSize(width: 100, height: 100)","","\/\/ Force square aspect ratio","hud.contentView.layout.isSquare = true","","\/\/ Text alignment","hud.contentView.layout.alignment = .leading"],"type":"codeListing"},{"level":2,"anchor":"Motion-Effects","type":"heading","text":"Motion Effects"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a parallax tilt effect to the content view:"}]},{"syntax":"swift","code":["hud.contentView.isMotionEffectsEnabled = true"],"type":"codeListing"},{"level":2,"anchor":"Subclassing","type":"heading","text":"Subclassing"},{"type":"paragraph","inlineContent":[{"code":"HUD","type":"codeVoice"},{"type":"text","text":" is an "},{"code":"open","type":"codeVoice"},{"type":"text","text":" class. Override "},{"code":"makeHUD(with:)","type":"codeVoice"},{"type":"text","text":" to provide custom instances:"}]},{"syntax":"swift","code":["class MyHUD: HUD {","    override class func makeHUD(with view: UIView) -> HUD {","        let hud = MyHUD(frame: view.bounds)","        \/\/ Custom setup","        return hud","    }","}"],"type":"codeListing"}],"kind":"content"}],"abstract":[{"type":"text","text":"Explore keyboard tracking, animations, grace time, activity counts, and more."}],"references":{"doc://flyhud.FlyHUD/documentation/FlyHUD":{"abstract":[{"type":"text","text":"A lightweight and easy-to-use HUD for displaying progress and status of ongoing tasks on iOS, tvOS, and visionOS."}],"role":"collection","kind":"symbol","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD","url":"\/documentation\/flyhud","title":"FlyHUD","type":"topic"},"doc://flyhud.FlyHUD/documentation/FlyHUD/testing":{"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing","url":"\/documentation\/flyhud\/testing","kind":"article","role":"article","abstract":[{"type":"text","text":"Strategies for unit testing, integration testing, and mocking FlyHUD in your app."}],"title":"Testing Guide","type":"topic"},"doc://flyhud.FlyHUD/documentation/FlyHUD/best-practices":{"abstract":[{"type":"text","text":"Recommended patterns for using FlyHUD effectively in production apps."}],"role":"article","kind":"article","url":"\/documentation\/flyhud\/best-practices","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","title":"Best Practices","type":"topic"},"doc://flyhud.FlyHUD/documentation/FlyHUD/HUD/Animation-swift.struct":{"abstract":[],"title":"HUD.Animation","role":"symbol","navigatorTitle":[{"text":"Animation","kind":"identifier"}],"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/HUD\/Animation-swift.struct","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Animation","kind":"identifier"}],"url":"\/documentation\/flyhud\/hud\/animation-swift.struct","type":"topic"},"doc://flyhud.FlyHUD/documentation/FlyHUD/custom-ui":{"abstract":[{"type":"text","text":"Build custom activity indicators, progress views, and display modes."}],"role":"article","kind":"article","url":"\/documentation\/flyhud\/custom-ui","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","title":"Custom UI","type":"topic"},"activity-count.svg":{"identifier":"activity-count.svg","alt":"State diagram showing activity count reference counter: Idle(0) → Active(1) → Active(2) → Active(3), decrements on hide(), HUD only hides when count reaches 0.","variants":[{"traits":["1x","light"],"url":"\/images\/flyhud.FlyHUD\/activity-count.svg","svgID":"my-svg"}],"type":"image"},"doc://flyhud.FlyHUD/documentation/FlyHUD/swiftui-integration":{"abstract":[{"type":"text","text":"Use FlyHUD declaratively in SwiftUI with the "},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"type":"text","text":" module."}],"role":"article","kind":"article","url":"\/documentation\/flyhud\/swiftui-integration","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","title":"SwiftUI Integration","type":"topic"},"animation-states.svg":{"identifier":"animation-states.svg","alt":"State diagram showing animation transitions: Hidden → AnimatingIn (fade\/zoom\/slide) → Visible → AnimatingOut → Hidden, with spring damping and per-hide override.","variants":[{"traits":["1x","light"],"url":"\/images\/flyhud.FlyHUD\/animation-states.svg","svgID":"my-svg"}],"type":"image"},"grace-time.svg":{"identifier":"grace-time.svg","alt":"Grace Time and MinShowTime sequence diagram showing two scenarios: a fast task where the HUD never appears, and a slow task where the HUD respects minimum display duration.","variants":[{"traits":["1x","light"],"url":"\/images\/flyhud.FlyHUD\/grace-time.svg","svgID":"my-svg"}],"type":"image"}}}