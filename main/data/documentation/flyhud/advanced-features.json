{"sections":[],"abstract":[{"type":"text","text":"Explore keyboard tracking, animations, grace time, activity counts, and more."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Animation-System","type":"heading","text":"Animation System","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD provides a rich animation system for showing and hiding the HUD."}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"animation-states.svg"}]},{"anchor":"Animation-Styles","type":"heading","text":"Animation Styles","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Configure via "},{"type":"reference","isActive":true,"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/HUD\/Animation-swift.struct"},{"type":"text","text":":"}]},{"syntax":"swift","code":["\/\/ Fade (default)","HUD.show(to: view, using: .animation(.fade))","","\/\/ Zoom in when appearing, zoom out when disappearing","HUD.show(to: view, using: .animation(.zoomInOut))","","\/\/ Slide up when appearing, slide down when disappearing","HUD.show(to: view, using: .animation(.slideUpDown))"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Available styles:"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Style","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Description","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".none","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"No animation","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".fade","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Opacity transition","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".zoomInOut","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Zoom in on show, zoom out on hide","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".zoomOutIn","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Zoom out on show, zoom in on hide","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".zoomIn","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Always zoom in","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".zoomOut","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Always zoom out","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideUpDown","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Slide up on show, slide down on hide","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideDownUp","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Slide down on show, slide up on hide","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideUp","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Always slide up","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideDown","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Always slide down","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideRightLeft","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Slide right on show, slide left on hide","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideLeftRight","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Slide left on show, slide right on hide","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideRight","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Always slide right","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".slideLeft","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Always slide left","type":"text"}]}]]],"type":"table","header":"row"},{"anchor":"Spring-Damping","type":"heading","text":"Spring Damping","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add bounce effects with spring damping:"}]},{"syntax":"swift","code":["\/\/ Default damping (0.65)","HUD.show(to: view, using: .animation(.zoomInOut, damping: .default))","","\/\/ Custom damping ratio (lower = more bounce)","HUD.show(to: view, using: .animation(.slideUpDown, damping: .ratio(0.5)))","","\/\/ No damping (smooth deceleration)","HUD.show(to: view, using: .animation(.fade, damping: .disable))"],"type":"codeListing"},{"anchor":"Animation-Duration","type":"heading","text":"Animation Duration","level":3},{"syntax":"swift","code":["HUD.show(to: view, using: .animation(.fade, duration: 0.5))"],"type":"codeListing"},{"anchor":"Per-Hide-Animation","type":"heading","text":"Per-Hide Animation","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Override animation when hiding:"}]},{"syntax":"swift","code":["let hud = HUD.show(to: view, using: .animation(.slideUp))","","\/\/ Hide with a different animation","hud.hide(using: .animation(.slideDown))"],"type":"codeListing"},{"anchor":"Keyboard-Layout-Guide-iOS","type":"heading","text":"Keyboard Layout Guide (iOS)","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD can automatically adjust its position when the keyboard appears."}]},{"anchor":"Global-Configuration","type":"heading","text":"Global Configuration","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set once in "},{"type":"codeVoice","code":"AppDelegate"},{"type":"text","text":" or "},{"type":"codeVoice","code":"SceneDelegate"},{"type":"text","text":":"}]},{"syntax":"swift","code":["\/\/ Center HUD in the visible area above keyboard","HUD.keyboardGuide = .center()","","\/\/ Center with vertical offset","HUD.keyboardGuide = .center(-20.0)","","\/\/ Keep content bottom above keyboard","HUD.keyboardGuide = .bottom(8.0)"],"type":"codeListing"},{"anchor":"Per-Instance-Configuration","type":"heading","text":"Per-Instance Configuration","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Override the global setting for individual HUDs:"}]},{"syntax":"swift","code":["let hud = HUD.show(to: view, label: \"Verifying...\")","hud.keyboardGuide = .center()"],"type":"codeListing"},{"anchor":"Keyboard-Guide-Modes","type":"heading","text":"Keyboard Guide Modes","level":3},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Mode","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Behavior","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".disable","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"No keyboard tracking (default)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".center(offsetY)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Center HUD in visible area above keyboard","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".bottom(spacing)","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Position content bottom relative to keyboard top","type":"text"}]}]]],"type":"table","header":"row"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Keyboard guide is only available on iOS. It has no effect on tvOS or visionOS.","type":"text"}]}],"type":"aside","style":"note","name":"Note"},{"anchor":"Grace-Time","type":"heading","text":"Grace Time","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following diagram illustrates how "},{"type":"codeVoice","code":"graceTime"},{"type":"text","text":" and "},{"type":"codeVoice","code":"minShowTime"},{"type":"text","text":" interact:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"grace-time.svg"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prevent HUD from appearing for very short tasks:"}]},{"syntax":"swift","code":["let hud = HUD(with: view)","hud.graceTime = 0.5  \/\/ Don't show if task completes within 0.5s","view.addSubview(hud)","hud.show()","","\/\/ If hide() is called within 0.5s, HUD never appears","DispatchQueue.main.asyncAfter(deadline: .now() + 0.3) {","    hud.hide()  \/\/ HUD was never shown","}"],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"graceTime","type":"codeVoice"},{"text":" must be set before calling ","type":"text"},{"code":"show()","type":"codeVoice"},{"text":". The convenience","type":"text"},{"text":" ","type":"text"},{"text":"method ","type":"text"},{"code":"HUD.show(to:)","type":"codeVoice"},{"text":" does not support grace time — use manual initialization instead.","type":"text"}]}],"type":"aside","style":"important","name":"Important"},{"anchor":"Minimum-Show-Time","type":"heading","text":"Minimum Show Time","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prevent HUD from flickering by enforcing a minimum display duration:"}]},{"syntax":"swift","code":["let hud = HUD(with: view)","hud.minShowTime = 1.0  \/\/ Show for at least 1 second","view.addSubview(hud)","hud.show()","","\/\/ Even if hide() is called immediately, HUD stays for 1s","hud.hide()"],"type":"codeListing"},{"anchor":"Activity-Count","type":"heading","text":"Activity Count","level":2},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"activity-count.svg"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Track multiple show\/hide pairs with a reference counter:"}]},{"syntax":"swift","code":["let hud = HUD.show(to: view)","hud.isCountEnabled = true","","\/\/ Each show increments count","hud.show()  \/\/ count = 2","hud.show()  \/\/ count = 3","","\/\/ Each hide decrements count; HUD hides only when count reaches 0","hud.hide()  \/\/ count = 2, still visible","hud.hide()  \/\/ count = 1, still visible","hud.hide()  \/\/ count = 0, hides"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is useful when multiple subsystems independently request the HUD."}]},{"anchor":"Event-Delivery","type":"heading","text":"Event Delivery","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Control whether touches pass through the HUD overlay:"}]},{"syntax":"swift","code":["\/\/ Default: HUD blocks all touches","hud.isEventDeliveryEnabled = false","","\/\/ Allow touches outside contentView to pass through","hud.isEventDeliveryEnabled = true"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When enabled, only touches within the content card are captured by the HUD."},{"type":"text","text":" "},{"type":"text","text":"Touches in the surrounding overlay area pass through to the parent view."}]},{"anchor":"Layout-Configuration","type":"heading","text":"Layout Configuration","level":2},{"anchor":"Offset","type":"heading","text":"Offset","level":3},{"type":"paragraph","inlineContent":[{"text":"Position the HUD content relative to center:","type":"text"}]},{"type":"codeListing","code":["\/\/ Bottom of screen","hud.layout.offset = .h.vMaxOffset","","\/\/ Top of screen","hud.layout.offset = .h.vMinOffset","","\/\/ Centered (default)","hud.layout.offset = .zero"],"syntax":"swift"},{"level":3,"type":"heading","text":"Edge Insets","anchor":"Edge-Insets"},{"type":"paragraph","inlineContent":[{"text":"Set minimum distance from HUD edges:","type":"text"}]},{"type":"codeListing","code":["hud.layout.edgeInsets = UIEdgeInsets(top: 40, left: 20, bottom: 40, right: 20)"],"syntax":"swift"},{"level":3,"type":"heading","text":"Safe Area","anchor":"Safe-Area"},{"type":"paragraph","inlineContent":[{"text":"Control whether safe area insets are respected:","type":"text"}]},{"type":"codeListing","code":["hud.layout.isSafeAreaLayoutGuideEnabled = true  \/\/ Default"],"syntax":"swift"},{"style":"warning","name":"Warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"isSafeAreaLayoutGuideEnabled","type":"codeVoice"},{"text":" must be set before the first ","type":"text"},{"code":"show()","type":"codeVoice"},{"text":" call.","type":"text"}]}]},{"level":2,"type":"heading","text":"Content View Layout","anchor":"Content-View-Layout"},{"inlineContent":[{"type":"text","text":"Fine-tune the content card’s internal layout:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Margins between card edge and content","hud.contentView.layout.hMargin = 24.0","hud.contentView.layout.vMargin = 24.0","","\/\/ Spacing between elements","hud.contentView.layout.hSpacing = 12.0","hud.contentView.layout.vSpacing = 8.0","","\/\/ Minimum content size","hud.contentView.layout.minSize = CGSize(width: 100, height: 100)","","\/\/ Force square aspect ratio","hud.contentView.layout.isSquare = true","","\/\/ Text alignment","hud.contentView.layout.alignment = .leading"],"type":"codeListing"},{"type":"heading","anchor":"Motion-Effects","text":"Motion Effects","level":2},{"type":"paragraph","inlineContent":[{"text":"Add a parallax tilt effect to the content view:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["hud.contentView.isMotionEffectsEnabled = true"]},{"anchor":"Subclassing","type":"heading","text":"Subclassing","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"HUD"},{"type":"text","text":" is an "},{"type":"codeVoice","code":"open"},{"type":"text","text":" class. Override "},{"type":"codeVoice","code":"makeHUD(with:)"},{"type":"text","text":" to provide custom instances:"}]},{"type":"codeListing","syntax":"swift","code":["class MyHUD: HUD {","    override class func makeHUD(with view: UIView) -> HUD {","        let hud = MyHUD(frame: view.bounds)","        \/\/ Custom setup","        return hud","    }","}"]}]}],"kind":"article","metadata":{"roleHeading":"Article","title":"Advanced Features","modules":[{"name":"FlyHUD"}],"role":"article"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flyhud\/advanced-features"]}],"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/docume