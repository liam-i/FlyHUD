{"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flyhud\/best-practices"]}],"seeAlsoSections":[{"generated":true,"title":"Guides","identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"],"anchor":"Guides"}],"metadata":{"roleHeading":"Article","modules":[{"name":"FlyHUD"}],"role":"article","title":"Best Practices"},"abstract":[{"type":"text","text":"Recommended patterns for using FlyHUD effectively in production apps."}],"primaryContentSections":[{"content":[{"text":"Lifecycle Management","anchor":"Lifecycle-Management","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The following diagram shows the recommended pattern for managing HUD lifecycle with async operations:"}],"type":"paragraph"},{"inlineContent":[{"identifier":"best-practices-lifecycle.svg","type":"image"}],"type":"paragraph"},{"text":"Always Hide Your HUDs","anchor":"Always-Hide-Your-HUDs","type":"heading","level":3},{"inlineContent":[{"text":"Ensure every ","type":"text"},{"code":"show()","type":"codeVoice"},{"text":" has a matching ","type":"text"},{"code":"hide()","type":"codeVoice"},{"text":" to prevent leaked HUD views:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view)","","Task {","    do {","        let result = try await fetchData()","        hud.contentView.mode = .custom(UIImageView(image: UIImage(systemName: \"checkmark\")))","        hud.contentView.label.text = \"Done\"","        hud.hide(afterDelay: 1.0)","    } catch {","        hud.contentView.mode = .text","        hud.contentView.label.text = \"Failed\"","        hud.hide(afterDelay: 2.0)","    }","}"]},{"text":"Use removeFromSuperViewOnHide","anchor":"Use-removeFromSuperViewOnHide","type":"heading","level":3},{"inlineContent":[{"text":"When using ","type":"text"},{"code":"HUD.show(to:)","type":"codeVoice"},{"text":", the HUD is automatically removed from its superview","type":"text"},{"text":" ","type":"text"},{"text":"on hide (default behavior). For manually created HUDs, set this explicitly:","type":"text"}],"type":"paragraph"},{"code":["let hud = HUD(with: view)","hud.removeFromSuperViewOnHide = true","view.addSubview(hud)","hud.show()"],"syntax":"swift","type":"codeListing"},{"text":"Avoid Retain Cycles","anchor":"Avoid-Retain-Cycles","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"[weak self]"},{"type":"text","text":" when referencing "},{"type":"codeVoice","code":"self"},{"type":"text","text":" in completion blocks:"}],"type":"paragraph"},{"code":["hud.completionBlock = { [weak self] _ in","    self?.navigateToNextScreen()","}"],"syntax":"swift","type":"codeListing"},{"text":"View Hierarchy","anchor":"View-Hierarchy","level":2,"type":"heading"},{"text":"Choose the Right Parent View","anchor":"Choose-the-Right-Parent-View","level":3,"type":"heading"},{"code":["\/\/ Good: Add to the view controller's view","HUD.show(to: self.view)","","\/\/ Good: Add to a specific container","HUD.show(to: tableView)","","\/\/ Caution: Adding to window covers everything","HUD.show(to: view.window!)"],"syntax":"swift","type":"codeListing"},{"text":"Avoid Adding to Scrollable Views","anchor":"Avoid-Adding-to-Scrollable-Views","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Adding a HUD to a "},{"code":"UIScrollView","type":"codeVoice"},{"type":"text","text":" or "},{"code":"UITableView","type":"codeVoice"},{"type":"text","text":" directly may cause"},{"type":"text","text":" "},{"type":"text","text":"unexpected behavior as the user scrolls. Prefer adding to the view controller’s view."}],"type":"paragraph"},{"text":"Async\/Await Integration","anchor":"AsyncAwait-Integration","level":2,"type":"heading"},{"text":"With Swift Concurrency","anchor":"With-Swift-Concurrency","level":3,"type":"heading"},{"code":["@MainActor","func loadData() async {","    let hud = HUD.show(to: view)","","    do {","        let data = try await api.fetchItems()","        updateUI(with: data)","    } catch {","        showError(error)","    }","","    hud.hide()","}"],"syntax":"swift","type":"codeListing"},{"text":"With URLSession","anchor":"With-URLSession","level":3,"type":"heading"},{"code":["let hud = HUD.show(to: view, mode: .progress(.roundBar), label: \"Downloading\")","","let observation = task.progress.observe(\\.fractionCompleted) { progress, _ in","    DispatchQueue.main.async {","        hud.contentView.progress = Float(progress.fractionCompleted)","    }","}","","\/\/ Or use observedProgress for automatic binding","hud.contentView.observedProgress = task.progress"],"syntax":"swift","type":"codeListing"},{"text":"Grace Time Usage","anchor":"Grace-Time-Usage","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use grace time to avoid HUD flicker for fast operations:"}],"type":"paragraph"},{"code":["let hud = HUD(with: view)","hud.graceTime = 0.3          \/\/ Don't show for tasks < 300ms","hud.minShowTime = 0.5        \/\/ If shown, display for at least 500ms","hud.removeFromSuperViewOnHide = true","view.addSubview(hud)","hud.show()","","\/\/ Fast task — HUD never appears","DispatchQueue.main.asyncAfter(deadline: .now() + 0.1) {","    hud.hide()","}"],"syntax":"swift","type":"codeListing"},{"text":"Activity Count Pattern","anchor":"Activity-Count-Pattern","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use activity counts for multi-source loading states:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class DataManager {","    private var hud: HUD?","","    func showLoading(on view: UIView) {","        if hud == nil {","            hud = HUD.show(to: view)","            hud?.isCountEnabled = true","        } else {","            hud?.show()","        }","    }","","    func hideLoading() {","        hud?.hide()","    }","}"]},{"anchor":"Performance","level":2,"type":"heading","text":"Performance"},{"anchor":"Reuse-HUD-Instances","level":3,"type":"heading","text":"Reuse HUD Instances"},{"inlineContent":[{"type":"text","text":"For repeated show\/hide cycles, reuse the same HUD instance:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["class ViewController: UIViewController {","    private lazy var hud: HUD = {","        let hud = HUD(with: view)","        hud.removeFromSuperViewOnHide = false","        view.addSubview(hud)","        return hud","    }()","","    func refresh() {","        hud.show()","        \/\/ ...","        hud.hide()","    }","}"]},{"anchor":"Avoid-Unnecessary-Mode-Changes","level":3,"type":"heading","text":"Avoid Unnecessary Mode Changes"},{"inlineContent":[{"type":"text","text":"Changing "},{"code":"mode","type":"codeVoice"},{"type":"text","text":" tears down and rebuilds indicator views. Only change when needed:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Avoid in tight loops","\/\/ ❌ hud.contentView.mode = .indicator(.large)  \/\/ every frame","","\/\/ ✅ Set once, update progress\/labels as needed","hud.contentView.progress = newValue"]},{"anchor":"Error-Handling-Pattern","level":2,"type":"heading","text":"Error Handling Pattern"},{"inlineContent":[{"identifier":"error-handling-states.svg","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Transition HUD state on success\/failure:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view, label: \"Saving...\")","","saveDocument { result in","    switch result {","    case .success:","        let checkmark = UIImageView(image: UIImage(systemName: \"checkmark\"))","        hud.contentView.mode = .custom(checkmark)","        hud.contentView.label.text = \"Saved\"","        hud.hide(afterDelay: 1.5)","","    case .failure(let error):","        hud.contentView.mode = .text","        hud.contentView.label.text = \"Error\"","        hud.contentView.detailsLabel.text = error.localizedDescription","        hud.hide(afterDelay: 3.0)","    }","}"]},{"anchor":"Accessibility","level":2,"type":"heading","text":"Accessibility"},{"inlineContent":[{"type":"text","text":"FlyHUD provides comprehensive VoiceOver and accessibility support out of the box."}],"type":"paragraph"},{"anchor":"VoiceOver-Architecture","level":3,"type":"heading","text":"VoiceOver Architecture"},{"inlineContent":[{"type":"image","identifier":"accessibility-architecture.svg"}],"type":"paragraph"},{"inlineContent":[{"text":"FlyHUD uses a ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"single-element"}]},{"text":" accessibility design:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"code":"ContentView","type":"codeVoice"},{"text":" is the sole VoiceOver focus element within the HUD","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"All child views (labels, buttons, indicators, progress views) are hidden from accessibility","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"VoiceOver reads a combined description of labels + progress status as one coherent announcement","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Button actions are exposed via ","type":"text"},{"code":"accessibilityCustomActions","type":"codeVoice"},{"text":" (swipe up\/down to discover)","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The HUD automatically manages VoiceOver focus:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ When shown:  VoiceOver focus moves to HUD (via .screenChanged notification)","\/\/ When hidden: VoiceOver focus returns to underlying content","","let hud = HUD.show(to: view, mode: .indicator(), label: \"Loading...\")","\/\/ VoiceOver announces: \"Loading...\"","","hud.contentView.detailsLabel.text = \"Please wait\"","\/\/ VoiceOver re-reads: \"Loading..., Please wait\""]},{"type":"heading","level":3,"anchor":"Escape-Gesture","text":"Escape Gesture"},{"type":"paragraph","inlineContent":[{"text":"VoiceOver users can dismiss the HUD via the standard two-finger Z-scrub (escape) gesture.","type":"text"},{"text":" ","type":"text"},{"text":"This calls ","type":"text"},{"code":"accessibilityPerformEscape()","type":"codeVoice"},{"text":" and hides the HUD with animation.","type":"text"}]},{"type":"heading","level":3,"anchor":"Contextual-Hints","text":"Contextual Hints"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"accessibilityHint"},{"type":"text","text":" provides mode-aware context to VoiceOver users:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Indicator modes: “Loading in progress”","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Progress modes: “Task in progress”"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Text-only modes: no hint (nil)","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":3,"anchor":"Modal-Focus-Management","text":"Modal Focus Management"},{"inlineContent":[{"type":"text","text":"HUD sets "},{"type":"codeVoice","code":"accessibilityViewIsModal = true"},{"type":"text","text":" to prevent VoiceOver from navigating"},{"type":"text","text":" "},{"type":"text","text":"to elements behind the overlay. This is automatic — no configuration needed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When "},{"code":"isEventDeliveryEnabled = true","type":"codeVoice"},{"type":"text","text":" (touches pass through), "},{"code":"accessibilityViewIsModal","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"is automatically set to "},{"code":"false","type":"codeVoice"},{"type":"text","text":" so VoiceOver focus can reach underlying content."}],"type":"paragraph"},{"anchor":"Progress-Announcements","level":3,"type":"heading","text":"Progress Announcements"},{"inlineContent":[{"text":"In progress mode, VoiceOver users receive periodic updates:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"accessibilityValue"},{"type":"text","text":" dynamically reports the current percentage (e.g., “45%”)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"accessibilityTraits"},{"type":"text","text":" includes "},{"type":"codeVoice","code":".updatesFrequently"},{"type":"text","text":" for progress\/indicator modes"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Milestone announcements are posted at 25% intervals (0%, 25%, 50%, 75%, 100%)"}]}]}]},{"code":["let hud = HUD.show(to: view, mode: .progress(.round), label: \"Downloading\")","\/\/ VoiceOver announces: \"Downloading\" with value \"0%\"","","hud.contentView.progress = 0.5","\/\/ VoiceOver announces: \"50%\" (milestone notification)"],"type":"codeListing","syntax":"swift"},{"anchor":"Dynamic-Type","type":"heading","level":3,"text":"Dynamic Type"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Enable Dynamic Type for HUD labels:"}]},{"syntax":"swift","type":"codeListing","code":["hud.contentView.isDynamicTypeEnabled = true"]},{"text":"Content Color Contrast","type":"heading","anchor":"Content-Color-Contrast","level":3},{"inlineContent":[{"type":"text","text":"Ensure sufficient contrast between content and background:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Dark background with light text","hud.contentView.style = .solidColor","hud.contentView.color = UIColor(white: 0.1, alpha: 0.9)","hud.contentView.contentColor = .white"]},{"text":"Custom Views & Accessibility","type":"heading","anchor":"Custom-Views--Accessibility","level":3},{"inlineContent":[{"type":"text","text":"When using "},{"type":"codeVoice","code":".custom(UIView)"},{"type":"text","text":" mode, set "},{"type":"codeVoice","code":"isAccessibilityElement = false"},{"type":"text","text":" on your custom view"},{"type":"text","text":" "},{"type":"text","text":"to maintain the single-element pattern:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let checkmark = UIImageView(image: UIImage(systemName: \"checkmark\"))","checkmark.isAccessibilityElement = false  \/\/ Recommended","","HUD.show(to: view, mode: .custom(checkmark), label: \"Done\")","\/\/ VoiceOver announces: \"Done\" (not the image's default accessibility)"]},{"text":"Button Actions","type":"heading","anchor":"Button-Actions","level":3},{"inlineContent":[{"type":"text","text":"When a button is configured, VoiceOver exposes it via custom actions:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: view, mode: .indicator(), label: \"Uploading...\")","hud.contentView.button.setTitle(\"Cancel\", for: .normal)","hud.contentView.button.addTarget(self, action: #selector(cancel), for: .touchUpInside)","\/\/ VoiceOver: Swipe up\/down to discover \"Cancel\" action"]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices"},"references":{"doc://flyhud.FlyHUD/documentation/FlyHUD/advanced-features":{"url":"\/documentation\/flyhud\/advanced-features","kind":"article","role":"article","title":"Advanced Features","type":"topic","abstract":[{"type":"text","text":"Explore keyboard tracking, animations, grace time, activity counts, and more."}],"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features"},"doc://flyhud.FlyHUD/documentation/FlyHUD/testing":{"url":"\/documentation\/fl