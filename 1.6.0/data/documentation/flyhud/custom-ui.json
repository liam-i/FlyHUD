{"identifier":{"url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","interfaceLanguage":"swift"},"metadata":{"role":"article","modules":[{"name":"FlyHUD"}],"roleHeading":"Article","title":"Custom UI"},"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Build custom activity indicators, progress views, and display modes."}],"seeAlsoSections":[{"generated":true,"anchor":"Guides","title":"Guides","identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"]}],"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flyhud\/custom-ui"]}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"The following diagram shows the protocol hierarchy for custom indicators and progress views:","type":"text"}]},{"type":"paragraph","inlineContent":[{"identifier":"custom-protocols.svg","type":"image"}]},{"type":"heading","level":2,"text":"Custom Activity Indicators","anchor":"Custom-Activity-Indicators"},{"type":"heading","level":3,"text":"Using FlyIndicatorHUD Built-in Styles","anchor":"Using-FlyIndicatorHUD-Built-in-Styles"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Import "},{"type":"codeVoice","code":"FlyIndicatorHUD"},{"type":"text","text":" to access pre-built indicator styles:"}]},{"type":"codeListing","syntax":"swift","code":["import FlyIndicatorHUD","","\/\/ Ring clip rotation","HUD.show(to: view, mode: .indicator(.ringClipRotate))","","\/\/ Ball spin fade","HUD.show(to: view, mode: .indicator(.ballSpinFade))","","\/\/ Circle stroke spin","HUD.show(to: view, mode: .indicator(.circleStrokeSpin))","","\/\/ Circle arc dot spin","HUD.show(to: view, mode: .indicator(.circleArcDotSpin))"]},{"type":"heading","level":3,"text":"Customizing ActivityIndicatorView Properties","anchor":"Customizing-ActivityIndicatorView-Properties"},{"type":"codeListing","syntax":"swift","code":["let indicator = ActivityIndicatorView(style: .circleStrokeSpin)","indicator.color = .systemBlue","indicator.trackColor = UIColor.systemBlue.withAlphaComponent(0.2)","indicator.lineWidth = 3.0","","HUD.show(to: view, mode: .custom(indicator), label: \"Loading\")"]},{"type":"heading","level":3,"text":"Choosing Your Customization Approach","anchor":"Choosing-Your-Customization-Approach"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"custom-indicator-decision.svg"}]},{"level":3,"anchor":"Implementing-ActivityIndicatorViewStyleable","type":"heading","text":"Implementing ActivityIndicatorViewStyleable"},{"inlineContent":[{"text":"Create entirely custom indicator animations:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct PulseStyle: ActivityIndicatorViewStyleable {","    func isEqual(_ object: Any) -> Bool {","        object is PulseStyle","    }","","    func makeAnimation() -> ActivityIndicatorAnimationBuildable {","        PulseAnimation()","    }","","    var defaultSize: CGSize { CGSize(width: 40, height: 40) }","    var defaultColor: UIColor { .systemPurple }","    var defaultTrackColor: UIColor? { nil }","    var defaultLineWidth: CGFloat { 0 }","}","","struct PulseAnimation: ActivityIndicatorAnimationBuildable {","    func make(in layer: CALayer, color: UIColor, trackColor: UIColor?, lineWidth: CGFloat) {","        let circle = CAShapeLayer()","        circle.path = UIBezierPath(ovalIn: layer.bounds).cgPath","        circle.fillColor = color.cgColor","","        let animation = CABasicAnimation(keyPath: \"transform.scale\")","        animation.fromValue = 0.5","        animation.toValue = 1.0","        animation.duration = 0.8","        animation.autoreverses = true","        animation.repeatCount = .greatestFiniteMagnitude","        circle.add(animation, forKey: \"pulse\")","","        layer.addSublayer(circle)","    }","}","","\/\/ Usage","HUD.show(to: view, mode: .indicator(PulseStyle()))"],"type":"codeListing"},{"level":3,"anchor":"Implementing-RotateViewable","type":"heading","text":"Implementing RotateViewable"},{"inlineContent":[{"type":"text","text":"For simple rotation-based indicators, conform to "},{"type":"codeVoice","code":"RotateViewable"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["class SpinnerView: UIView, RotateViewable {","    var duration: CFTimeInterval { 0.5 }","","    override init(frame: CGRect) {","        super.init(frame: frame)","        \/\/ VoiceOver: ContentView handles accessibility for the HUD.","        \/\/ Custom indicators should not be separate focus elements.","        isAccessibilityElement = false","    }","","    required init?(coder: NSCoder) { fatalError() }","","    override var intrinsicContentSize: CGSize {","        CGSize(width: 37, height: 37)","    }","","    override func draw(_ rect: CGRect) {","        \/\/ Draw your custom shape","    }","}","","\/\/ Usage — rotation is handled automatically","let spinner = SpinnerView()","HUD.show(to: view, mode: .custom(spinner))"],"type":"codeListing"},{"level":2,"anchor":"Custom-Progress-Views","type":"heading","text":"Custom Progress Views"},{"level":3,"anchor":"Using-FlyProgressHUD-Built-in-Styles","type":"heading","text":"Using FlyProgressHUD Built-in Styles"},{"inlineContent":[{"type":"text","text":"Import "},{"type":"codeVoice","code":"FlyProgressHUD"},{"type":"text","text":" for pre-built progress styles:"}],"type":"paragraph"},{"syntax":"swift","code":["import FlyProgressHUD","","\/\/ Bar progress (butt cap)","HUD.show(to: view, mode: .progress(.buttBar))","","\/\/ Bar progress (round cap)","HUD.show(to: view, mode: .progress(.roundBar))","","\/\/ Circular progress ring","HUD.show(to: view, mode: .progress(.round))","","\/\/ Annular ring","HUD.show(to: view, mode: .progress(.annularRound))","","\/\/ Pie chart","HUD.show(to: view, mode: .progress(.pie))"],"type":"codeListing"},{"level":3,"anchor":"Customizing-ProgressView-Properties","type":"heading","text":"Customizing ProgressView Properties"},{"syntax":"swift","code":["let progressView = ProgressView(style: .annularRound)","progressView.progressTintColor = .systemGreen","progressView.trackTintColor = UIColor.systemGreen.withAlphaComponent(0.15)","progressView.lineWidth = 4.0","progressView.isLabelEnabled = true  \/\/ Show percentage text","progressView.labelFont = .boldSystemFont(ofSize: 12)","","let hud = HUD.show(to: view, mode: .custom(progressView))"],"type":"codeListing"},{"level":3,"anchor":"Implementing-ProgressViewStyleable","type":"heading","text":"Implementing ProgressViewStyleable"},{"inlineContent":[{"type":"text","text":"Create entirely custom progress animations:"}],"type":"paragraph"},{"syntax":"swift","code":["struct GradientBarStyle: ProgressViewStyleable {","    func isEqual(_ object: Any) -> Bool {","        object is GradientBarStyle","    }","","    func makeAnimation() -> ProgressAnimationBuildable {","        GradientBarAnimation()","    }","","    var defaultSize: CGSize { CGSize(width: 120, height: 12) }","    var defaultProgressTintColor: UIColor { .systemBlue }","    var defaultTrackTintColor: UIColor? { .systemGray5 }","    var defaultLineWidth: CGFloat { 0 }","    var defaultIsLabelEnabled: Bool { false }","    var defaultLabelFont: UIFont { .boldSystemFont(ofSize: 8) }","}","","struct GradientBarAnimation: ProgressAnimationBuildable {","    func makeShape(in layer: CALayer, progress: CGFloat, color: UIColor, trackColor: UIColor?, lineWidth: CGFloat) {","        let size = layer.bounds.size","        let radius = size.height \/ 2.0","","        \/\/ Track","        if let trackColor {","            let trackPath = UIBezierPath(roundedRect: layer.bounds, cornerRadius: radius)","            trackColor.setFill()","            trackPath.fill()","        }","","        \/\/ Progress fill","        let progressWidth = size.width * progress","        let progressRect = CGRect(x: 0, y: 0, width: progressWidth, height: size.height)","        let progressPath = UIBezierPath(roundedRect: progressRect, cornerRadius: radius)","        color.setFill()","        progressPath.fill()","    }","}"],"type":"codeListing"},{"level":3,"anchor":"Implementing-ProgressViewable-Protocol","type":"heading","text":"Implementing ProgressViewable Protocol"},{"inlineContent":[{"text":"For full control, implement ","type":"text"},{"type":"codeVoice","code":"ProgressViewable"},{"text":" on your own UIView subclass:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class CustomProgressView: UIView, ProgressViewable {","    var progress: Float = 0.0 {","        didSet { setNeedsDisplay() }","    }","    var progressTintColor: UIColor? = .systemBlue","    var trackTintColor: UIColor? = .systemGray5","    var observedProgress: Progress?","","    override var intrinsicContentSize: CGSize {","        CGSize(width: 100, height: 100)","    }","","    override func draw(_ rect: CGRect) {","        \/\/ Your custom drawing","    }","}"],"type":"codeListing"},{"level":2,"anchor":"Custom-Background-Styles","type":"heading","text":"Custom Background Styles"},{"level":3,"anchor":"Blur-Styles","type":"heading","text":"Blur Styles"},{"syntax":"swift","code":["hud.contentView.style = .blur(.systemUltraThinMaterial)","hud.backgroundView.style = .blur(.systemMaterial)"],"type":"codeListing"},{"level":3,"anchor":"Solid-Color","type":"heading","text":"Solid Color"},{"syntax":"swift","code":["hud.contentView.style = .solidColor","hud.contentView.color = UIColor(white: 0.1, alpha: 0.9)"],"type":"codeListing"},{"type":"heading","level":3,"anchor":"Liquid-Glass-iOS-26+","text":"Liquid Glass (iOS 26+)"},{"syntax":"swift","type":"codeListing","code":["if #available(iOS 26.0, *) {","    hud.contentView.style = .glass","    hud.contentView.color = .systemBlue  \/\/ Glass tint color","}"]},{"type":"heading","level":3,"anchor":"Rounded-Corners","text":"Rounded Corners"},{"syntax":"swift","type":"codeListing","code":["\/\/ Custom radius","hud.contentView.roundedCorners = .radius(12.0)","","\/\/ Fully rounded (capsule)","hud.contentView.roundedCorners = .full"]},{"type":"heading","level":2,"anchor":"Combining-Custom-Elements","text":"Combining Custom Elements"},{"type":"paragraph","inlineContent":[{"text":"Build complex HUD configurations by combining elements:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Custom indicator with progress-style layout","let indicator = ActivityIndicatorView(style: .circleStrokeSpin)","indicator.color = .white","","let hud = HUD.show(to: view, mode: .custom(indicator)) { hud in","    hud.contentView.label.text = \"Syncing...\"","    hud.contentView.detailsLabel.text = \"3 of 10 files\"","    hud.contentView.contentColor = .white","    hud.contentView.style = .solidColor","    hud.contentView.color = UIColor.black.withAlphaComponent(0.85)","    hud.contentView.roundedCorners = .radius(16)","    hud.contentView.layout.hMargin = 24","    hud.contentView.layout.vMargin = 20","    hud.animation = .animation(.zoomInOut, damping: .default)","    hud.backgroundView.style = .solidColor","    hud.backgroundView.color = UIColor.black.withAlphaComponent(0.2)","}"]}],"kind":"content"}],"sections":[],"references":{"doc://flyhud.FlyHUD/documentation/FlyHUD/advanced-features":{"url":"\/documentation\/flyhud\/advanced-features","kind":"article","role":"article","title":"Advanced Features","type":"topic","abstract":[{"type":"text","text":"Explore keyboard tracking, animations, grace time, activity counts, and more."}],"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features"},"custom-indicator-decision.svg":{"type":"image","identifier":"custom-indicator-decision.svg","alt":"Flowchart decision tree: Simple rotation → RotateViewable; Complex animation → ActivityIndicatorViewStyleable; Any UIView → .custom(view).","variants":[{"url":"\/images\/flyhud.FlyHUD\/custom-indicator-decision.svg","svgID":"my-svg","traits":["1x","light"]}]},"doc://flyhud.FlyHUD/documentation/FlyHUD/swiftui-integration":{"kind":"article","role":"article","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","type":"topic","abstract":[{"text":"Use FlyHUD declaratively in SwiftUI with the ","type":"text"},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"text":" module.","type":"text"}],"title":"SwiftUI Integration","url":"\/documentation\/flyhud\/swiftui-integration"},"doc://flyhud.FlyHUD/documentation/FlyHUD/best-practices":{"url":"\/documentation\/flyhud\/best-practices","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","kind":"article","title":"Best Practices","type":"topic","role":"article","abstract":[{"text":"Recommended patterns for using FlyHUD effectively in production apps.","type":"text"}]},"custom-protocols.svg":{"alt":"Class diagram showing the relationships between ActivityIndicatorViewStyleable, ProgressViewStyleable, RotateViewable, ProgressViewable protocols and their concrete implementations.","variants":[{"traits":["1x","light"],"svgID":"my-svg","url":"\/images\/flyhud.FlyHUD\/custom-protocols.svg"}],"type":"image","identifier":"custom-protocols.svg"},"doc://flyhud.FlyHUD/documentation/FlyHUD":{"url":"\/documentation\/flyhud","kind":"symbol","role":"collection","title":"FlyHUD","abstract":[{"type":"text","text":"A lightweight and easy-to-use HUD for displaying progress and status of ongoing tasks on iOS, tvOS, and visionOS."}],"type":"topic","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"},"doc://flyhud.FlyHUD/documentation/FlyHUD/testing":{"url":"\/documentation\/flyhud\/testing","kind":"article","role":"article","title":"Testing Guide","type":"topic","abstract":[{"text":"Strategies for unit testing