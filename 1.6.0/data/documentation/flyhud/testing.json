{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/testing"},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"modules":[{"name":"FlyHUD"}],"roleHeading":"Article","role":"article","title":"Testing Guide"},"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"abstract":[{"type":"text","text":"Strategies for unit testing, integration testing, and mocking FlyHUD in your app."}],"seeAlsoSections":[{"generated":true,"title":"Guides","identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/advanced-features","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/swiftui-integration","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices"],"anchor":"Guides"}],"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flyhud\/testing"]}],"primaryContentSections":[{"content":[{"anchor":"Unit-Testing-HUD-Logic","text":"Unit Testing HUD Logic","type":"heading","level":2},{"anchor":"Testing-HUD-Display-State","text":"Testing HUD Display State","type":"heading","level":3},{"syntax":"swift","type":"codeListing","code":["import XCTest","@testable import FlyHUD","","@MainActor","final class HUDDisplayTests: XCTestCase {","    var containerView: UIView!","","    override func setUp() {","        super.setUp()","        containerView = UIView(frame: CGRect(x: 0, y: 0, width: 375, height: 812))","    }","","    override func tearDown() {","        containerView = nil","        super.tearDown()","    }","","    func testShowAddsHUDToView() {","        let hud = HUD.show(to: containerView, animated: false)","        XCTAssertTrue(containerView.subviews.contains(hud))","        hud.hide(animated: false)","    }","","    func testHideRemovesHUDFromView() {","        let hud = HUD.show(to: containerView, animated: false)","        hud.hide(animated: false)","        XCTAssertFalse(containerView.subviews.contains(hud))","    }","","    func testActivityCount() {","        let hud = HUD.show(to: containerView, animated: false)","        hud.isCountEnabled = true","","        hud.show(animated: false)  \/\/ count = 2","        hud.show(animated: false)  \/\/ count = 3","","        hud.hide(animated: false)  \/\/ count = 2","        XCTAssertTrue(containerView.subviews.contains(hud))","","        hud.hide(animated: false)  \/\/ count = 1","        XCTAssertTrue(containerView.subviews.contains(hud))","","        hud.hide(animated: false)  \/\/ count = 0, hides","        XCTAssertFalse(containerView.subviews.contains(hud))","    }","}"]},{"anchor":"Testing-Content-Configuration","text":"Testing Content Configuration","type":"heading","level":3},{"syntax":"swift","type":"codeListing","code":["@MainActor","func testLabelText() {","    let hud = HUD.show(to: containerView, animated: false, label: \"Loading\")","    XCTAssertEqual(hud.contentView.label.text, \"Loading\")","    hud.hide(animated: false)","}","","@MainActor","func testModeChange() {","    let hud = HUD.show(to: containerView, animated: false)","    hud.contentView.mode = .text","    XCTAssertTrue(hud.contentView.mode.isText)","    hud.hide(animated: false)","}","","@MainActor","func testProgressUpdate() {","    let hud = HUD.show(to: containerView, animated: false, mode: .progress(.default))","    hud.contentView.progress = 0.5","    XCTAssertEqual(hud.contentView.progress, 0.5)","    hud.hide(animated: false)","}"]},{"anchor":"Mocking-HUD-in-App-Tests","text":"Mocking HUD in App Tests","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"identifier":"testing-mock.svg","type":"image"}]},{"anchor":"Protocol-Based-Abstraction","text":"Protocol-Based Abstraction","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Abstract HUD operations behind a protocol for testability:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ In your app code","@MainActor","protocol HUDDisplayable {","    func showLoading(on view: UIView, label: String?)","    func showSuccess(on view: UIView, label: String?)","    func showError(on view: UIView, label: String?)","    func hide(from view: UIView)","}","","@MainActor","final class RealHUDService: HUDDisplayable {","    func showLoading(on view: UIView, label: String?) {","        HUD.show(to: view, label: label)","    }","","    func showSuccess(on view: UIView, label: String?) {","        let image = UIImageView(image: UIImage(systemName: \"checkmark\"))","        HUD.showStatus(to: view, mode: .custom(image), label: label)","    }","","    func showError(on view: UIView, label: String?) {","        HUD.showStatus(to: view, mode: .text, label: label)","    }","","    func hide(from view: UIView) {","        HUD.hide(for: view)","    }","}"]},{"anchor":"Mock-Implementation-for-Tests","text":"Mock Implementation for Tests","type":"heading","level":3},{"syntax":"swift","type":"codeListing","code":["@MainActor","final class MockHUDService: HUDDisplayable {","    var showLoadingCalled = false","    var showSuccessCalled = false","    var showErrorCalled = false","    var hideCalled = false","    var lastLabel: String?","","    func showLoading(on view: UIView, label: String?) {","        showLoadingCalled = true","        lastLabel = label","    }","","    func showSuccess(on view: UIView, label: String?) {","        showSuccessCalled = true","        lastLabel = label","    }","","    func showError(on view: UIView, label: String?) {","        showErrorCalled = true","        lastLabel = label","    }","","    func hide(from view: UIView) {","        hideCalled = true","    }","}"]},{"anchor":"Using-the-Mock-in-Tests","text":"Using the Mock in Tests","type":"heading","level":3},{"syntax":"swift","type":"codeListing","code":["@MainActor","final class ViewModelTests: XCTestCase {","    func testFetchShowsAndHidesHUD() async {","        let mockHUD = MockHUDService()","        let viewModel = MyViewModel(hudService: mockHUD)","","        await viewModel.fetchData()","","        XCTAssertTrue(mockHUD.showLoadingCalled)","        XCTAssertTrue(mockHUD.hideCalled)","    }","}"]},{"anchor":"Testing-Animations","text":"Testing Animations","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Animations are difficult to unit test directly. Use these strategies:","type":"text"}]},{"anchor":"Disable-Animations-in-Tests","text":"Disable Animations in Tests","type":"heading","level":3},{"syntax":"swift","type":"codeListing","code":["@MainActor","func testHideWithoutAnimation() {","    let hud = HUD.show(to: containerView, animated: false)","    hud.hide(animated: false)","    \/\/ Assert immediately — no animation delay","    XCTAssertTrue(hud.isHidden)","}"]},{"anchor":"Use-Animation-Style-none","text":"Use Animation Style `.none`","type":"heading","level":3},{"syntax":"swift","type":"codeListing","code":["let hud = HUD.show(to: containerView, using: .animation(.none))","hud.hide(using: .animation(.none))"]},{"text":"Testing Delegates","anchor":"Testing-Delegates","type":"heading","level":2},{"syntax":"swift","type":"codeListing","code":["@MainActor","final class DelegateTests: XCTestCase, HUDDelegate {","    var hudDidHide = false","","    func hudWasHidden(_ hud: HUD) {","        hudDidHide = true","    }","","    func testDelegateCalledOnHide() {","        let hud = HUD.show(to: containerView, animated: false)","        hud.delegate = self","        hud.hide(animated: false)","        XCTAssertTrue(hudDidHide)","    }","}"]},{"text":"Testing Custom Indicators","anchor":"Testing-Custom-Indicators","type":"heading","level":2},{"text":"ActivityIndicatorView Tests","anchor":"ActivityIndicatorView-Tests","type":"heading","level":3},{"syntax":"swift","type":"codeListing","code":["@MainActor","func testActivityIndicatorStartStop() {","    let indicator = ActivityIndicatorView(style: .ringClipRotate)","    XCTAssertFalse(indicator.isAnimating)","","    indicator.startAnimating()","    XCTAssertTrue(indicator.isAnimating)","    XCTAssertFalse(indicator.isHidden)","","    indicator.stopAnimating()","    XCTAssertFalse(indicator.isAnimating)","    XCTAssertTrue(indicator.isHidden) \/\/ hidesWhenStopped = true","}"]},{"type":"heading","level":3,"anchor":"ProgressView-Tests","text":"ProgressView Tests"},{"syntax":"swift","type":"codeListing","code":["@MainActor","func testProgressViewBounds() {","    let progressView = ProgressView(style: .round)","    XCTAssertEqual(progressView.progress, 0.0)","","    progressView.progress = 0.75","    XCTAssertEqual(progressView.progress, 0.75)","}"]},{"type":"heading","level":2,"anchor":"Test-Strategy","text":"Test Strategy"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"testing-strategy.svg"}]},{"type":"heading","level":2,"anchor":"Running-Tests","text":"Running Tests"},{"type":"heading","level":3,"anchor":"Command-Line","text":"Command Line"},{"syntax":"bash","type":"codeListing","code":["# Run all unit tests",".\/scripts\/build.sh test","","# Run specific test class",".\/scripts\/build.sh test HUDTests","","# Run UI tests",".\/scripts\/build.sh test ui","","# SPM build (swift test not supported — UIKit unavailable on macOS CLI)",".\/scripts\/build.sh swift"]},{"type":"heading","level":3,"anchor":"Xcode","text":"Xcode"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Select the test target and press Cmd+U, or run individual tests via the test navigator."}]},{"type":"heading","level":2,"anchor":"Test-Organization","text":"Test Organization"},{"syntax":"text","type":"codeListing","code":["Tests\/","├── HUD\/","│   ├── HUDTests.swift              # Core show\/hide behavior","│   ├── HUDStressTests.swift        # Concurrent and stress scenarios","│   ├── ModelTests.swift            # Layout, Animation models","│   ├── Extensions\/                 # Extension tests","│   ├── Observables\/                # DisplayLink, Keyboard tests","│   ├── Protocols\/                  # Protocol conformance tests","│   └── Views\/                      # ContentView, BackgroundView tests","├── IndicatorHUD\/","│   └── ActivityIndicatorViewTests.swift","└── ProgressHUD\/","    └── ProgressViewTests.swift"]}],"kind":"content"}],"sections":[],"references":{"doc://flyhud.FlyHUD/documentation/FlyHUD":{"url":"\/documentation\/flyhud","kind":"symbol","role":"collection","title":"FlyHUD","abstract":[{"type":"text","text":"A lightweight and easy-to-use HUD for displaying progress and status of ongoing tasks on iOS, tvOS, and visionOS."}],"type":"topic","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"},"testing-mock.svg":{"type":"image","identifier":"testing-mock.svg","alt":"Class diagram showing HUDDisplayable protocol with RealHUDService (production) and MockHUDService (test) conformances, and ViewModel depending on the protocol.","variants":[{"url":"\/images\/flyhud.FlyHUD\/testing-mock.svg","svgID":"my-svg","traits":["1x","light"]}]},"doc://flyhud.FlyHUD/documentation/FlyHUD/best-practices":{"url":"\/documentation\/flyhud\/best-practices","identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/best-practices","kind":"article","title":"Best Practices","type":"topic","role":"article","abstract":[{"text":"Recommended patterns for using FlyHUD effectively in production apps.","type":"text"}]},"doc://flyhud.FlyHUD/documentation/FlyHUD/custom-ui":{"url":"\/documentation\/flyhud\/custom-ui","kind":"article","role":"article","title":"Custom UI","type":"topic","abstract":[{"type":"text","text":"Build custom activity indicators, progress views, and display modes."}],"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/custom-ui"},"testing-strategy.svg":{"variants":[{"url":"\/images\/flyhud.FlyHUD\/testing-strategy.svg","traits":["1x","light"],"svgID":"my-svg"}],"alt":"Flowchart showing test strategy decision tree: HUD display logic → use animated:false; Business logic → use Mock; Custom indicators → test state; Delegates → assert 