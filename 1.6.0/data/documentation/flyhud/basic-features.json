{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/basic-features"},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"article","modules":[{"name":"FlyHUD"}],"roleHeading":"Article","title":"Basic Features"},"hierarchy":{"paths":[["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD"]]},"abstract":[{"type":"text","text":"Learn the fundamental display modes, configurations, and lifecycle of FlyHUD."}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/overview","doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/getting-started"],"title":"Essentials","anchor":"Essentials"}],"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flyhud\/basic-features"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"identifier":"basic-lifecycle.svg","type":"image"}]},{"type":"heading","level":2,"text":"Display Modes","anchor":"Display-Modes"},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlyHUD supports four primary display modes through "},{"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/ContentView\/Mode-swift.enum","isActive":true,"type":"reference"},{"type":"text","text":":"}]},{"type":"heading","level":3,"text":"Text Only","anchor":"Text-Only"},{"type":"paragraph","inlineContent":[{"text":"Displays labels and an optional button without any indicator:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["HUD.showStatus(to: view, mode: .text, label: \"Network error\")"]},{"type":"heading","level":3,"text":"System Activity Indicator","anchor":"System-Activity-Indicator"},{"type":"paragraph","inlineContent":[{"text":"Uses ","type":"text"},{"code":"UIActivityIndicatorView","type":"codeVoice"},{"text":" with configurable style:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Large spinner (default)","HUD.show(to: view, mode: .indicator(.large))","","\/\/ Medium spinner","HUD.show(to: view, mode: .indicator(.medium))"]},{"type":"heading","level":3,"text":"System Progress View","anchor":"System-Progress-View"},{"type":"paragraph","inlineContent":[{"text":"Uses ","type":"text"},{"type":"codeVoice","code":"UIProgressView"},{"type":"text","text":" with configurable style:"}]},{"code":["let hud = HUD.show(to: view, mode: .progress(.default))","hud.contentView.progress = 0.75"],"syntax":"swift","type":"codeListing"},{"anchor":"Custom-View","text":"Custom View","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Display any "},{"code":"UIView","type":"codeVoice"},{"type":"text","text":" as the HUD indicator:"}],"type":"paragraph"},{"code":["let imageView = UIImageView(image: UIImage(systemName: \"checkmark.circle\"))","HUD.show(to: view, mode: .custom(imageView), label: \"Success\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Show-and-Hide","text":"Show and Hide","level":2,"type":"heading"},{"anchor":"Basic-ShowHide","text":"Basic Show\/Hide","level":3,"type":"heading"},{"code":["\/\/ Show with default animation","let hud = HUD.show(to: view)","","\/\/ Hide with default animation","hud.hide()"],"syntax":"swift","type":"codeListing"},{"anchor":"Animated-vs-Immediate","text":"Animated vs. Immediate","level":3,"type":"heading"},{"code":["\/\/ Show without animation","let hud = HUD.show(to: view, animated: false)","","\/\/ Hide without animation","hud.hide(animated: false)"],"syntax":"swift","type":"codeListing"},{"anchor":"Auto-Hide-with-Duration","text":"Auto-Hide with Duration","level":3,"type":"heading"},{"inlineContent":[{"code":"showStatus","type":"codeVoice"},{"text":" automatically hides after a specified duration:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Hides after 2 seconds (default)","HUD.showStatus(to: view, label: \"Saved\")","","\/\/ Hides after 5 seconds","HUD.showStatus(to: view, duration: 5.0, label: \"Processing complete\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Hide-with-Delay","text":"Hide with Delay","level":3,"type":"heading"},{"code":["hud.hide(afterDelay: 1.5)"],"syntax":"swift","type":"codeListing"},{"anchor":"Class-Level-Hide","text":"Class-Level Hide","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Find and hide HUDs by their parent view:"}],"type":"paragraph"},{"code":["\/\/ Hide the top-most HUD","HUD.hide(for: view)","","\/\/ Hide all HUDs on a view","HUD.hideAll(for: view)"],"syntax":"swift","type":"codeListing"},{"anchor":"Labels","text":"Labels","level":2,"type":"heading"},{"inlineContent":[{"text":"FlyHUD provides two labels for displaying text:","type":"text"}],"type":"paragraph"},{"code":["let hud = HUD.show(to: view)","hud.contentView.label.text = \"Loading...\"","hud.contentView.detailsLabel.text = \"Please wait while we process your request\""],"syntax":"swift","type":"codeListing"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"label","type":"text"}],"type":"strong"},{"type":"text","text":" — Primary text (bold, single line by default)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"detailsLabel","type":"text"}],"type":"strong"},{"text":" — Secondary text (smaller, multi-line)","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Button","text":"Button","level":2,"type":"heading"},{"inlineContent":[{"text":"A button is included in the content view. It’s visible only when a title and action are set:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let hud = HUD.show(to: view, label: \"Downloading\")","hud.contentView.button.setTitle(\"Cancel\", for: .normal)","hud.contentView.button.addTarget(self, action: #selector(cancelDownload), for: .touchUpInside)"],"type":"codeListing"},{"anchor":"Progress-Tracking","text":"Progress Tracking","level":2,"type":"heading"},{"anchor":"Manual-Progress","text":"Manual Progress","level":3,"type":"heading"},{"syntax":"swift","code":["let hud = HUD.show(to: view, mode: .progress(.default))","hud.contentView.progress = 0.0","","\/\/ Update as work progresses","hud.contentView.progress = 0.5","hud.contentView.progress = 1.0"],"type":"codeListing"},{"anchor":"Observed-Progress","text":"Observed Progress","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Bind to a "},{"type":"codeVoice","code":"Progress"},{"type":"text","text":" object for automatic updates:"}],"type":"paragraph"},{"syntax":"swift","code":["let hud = HUD.show(to: view, mode: .progress(.default))","hud.contentView.observedProgress = myProgress","","\/\/ Labels auto-update from Progress.localizedDescription","\/\/ and Progress.localizedAdditionalDescription"],"type":"codeListing"},{"anchor":"Content-View-Layout","text":"Content View Layout","level":2,"type":"heading"},{"inlineContent":[{"type":"image","identifier":"content-layout.svg"}],"type":"paragraph"},{"anchor":"Background-Styles","text":"Background Styles","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Configure the HUD background via "},{"identifier":"doc:\/\/flyhud.FlyHUD\/documentation\/FlyHUD\/BackgroundView","isActive":true,"type":"reference"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["let hud = HUD.show(to: view)","","\/\/ Blur (default)","hud.contentView.style = .blur(.systemThickMaterial)","","\/\/ Solid color","hud.contentView.style = .solidColor","hud.contentView.color = UIColor.black.withAlphaComponent(0.8)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The full-screen overlay background is also configurable:"}],"type":"paragraph"},{"syntax":"swift","code":["hud.backgroundView.style = .solidColor","hud.backgroundView.color = UIColor.black.withAlphaComponent(0.3)"],"type":"codeListing"},{"anchor":"Indicator-Position","text":"Indicator Position","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Control where the indicator appears relative to labels:"}],"type":"paragraph"},{"syntax":"swift","code":["let hud = HUD.show(to: view, mode: .custom(myImage), label: \"Done\")","","\/\/ Position options: .top (default), .bottom, .leading, .trailing","hud.contentView.indicatorPosition = .leading"],"type":"codeListing"},{"anchor":"Content-Color","text":"Content Color","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Set a unified color for all content (labels, indicator, button):","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["hud.contentView.contentColor = .white"]},{"inlineContent":[{"type":"text","text":"Set to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to manage each element’s color individually."}],"type":"paragraph"},{"anchor":"Populator-Block","level":2,"type":"heading","text":"Populator Block"},{"inlineContent":[{"type":"text","text":"Use the trailing closure to configure HUD properties inline:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["HUD.show(to: view, mode: .indicator(.large), label: \"Loading\") { hud in","    hud.contentView.detailsLabel.text = \"Fetching data...\"","    hud.contentView.contentColor = .systemBlue","    hud.layout.offset = .zero","}"]},{"anchor":"Finding-HUDs","level":2,"type":"heading","text":"Finding HUDs"},{"inlineContent":[{"type":"text","text":"Retrieve existing HUDs from a view:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Get all active HUDs","let allHuds = HUD.huds(for: view)","","\/\/ Get the top-most HUD","if let topHud = HUD.lastHUD(for: view) {","    topHud.contentView.label.text = \"Almost done...\"","}"]},{"anchor":"Delegate--Completion","level":2,"type":"heading","text":"Delegate & Completion"},{"inlineContent":[{"text":"Get notified when a HUD finishes hiding:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Via delegate","hud.delegate = self","","\/\/ Via completion block","h