aragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Binding-driven state management"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Convenience","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".hudLoading()"},{"type":"text","text":", "},{"type":"codeVoice","code":".hudToast()"},{"type":"text","text":", "},{"type":"codeVoice","code":".hudProgress()"}]}],[{"type":"paragraph","inlineContent":[{"text":"Common presets with minimal setup","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Liquid Glass"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".hudGlass()"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS 26+ translucent glass style"}]}]]],"header":"row"},{"inlineContent":[{"type":"text","text":"All APIs support iOS 13+, tvOS 13+, and visionOS 1.0+."}],"type":"paragraph"},{"level":3,"text":"Architecture","type":"heading","anchor":"Architecture"},{"inlineContent":[{"type":"text","text":"The following diagram shows the layered architecture and how each public API flows through internal components to the UIKit core:"}],"type":"paragraph"},{"inlineContent":[{"identifier":"swiftui-architecture.svg","type":"image"}],"type":"paragraph"},{"anchor":"How-It-Works","type":"heading","level":3,"text":"How It Works"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following diagram shows the interaction flow between SwiftUI bindings and the UIKit HUD:"}]},{"inlineContent":[{"type":"image","identifier":"swiftui-bridge.svg"}],"type":"paragraph"},{"anchor":"Installation","level":2,"type":"heading","text":"Installation"},{"inlineContent":[{"type":"text","text":"Add "},{"type":"codeVoice","code":"FlyHUDSwiftUI"},{"type":"text","text":" to your package dependencies:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/liam-i\/FlyHUD.git\", from: \"1.7.0\")","],","targets: [","    .target(","        name: \"MyTarget\",","        dependencies: [","            .product(name: \"FlyHUDSwiftUI\", package: \"FlyHUD\")","        ]","    )","]"]},{"inlineContent":[{"type":"text","text":"Or in Xcode: File → Add Package Dependencies → select "},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"FlyHUDSwiftUI","type":"codeVoice"},{"type":"text","text":" depends on "},{"code":"FlyHUD","type":"codeVoice"},{"type":"text","text":" automatically. You only need to add "},{"code":"FlyIndicatorHUD","type":"codeVoice"},{"type":"text","text":" or "},{"code":"FlyProgressHUD","type":"codeVoice"},{"type":"text","text":" if you use custom indicator\/progress styles."}]}],"type":"aside","name":"Note"},{"anchor":"Import","level":2,"type":"heading","text":"Import"},{"syntax":"swift","type":"codeListing","code":["import FlyHUDSwiftUI","","\/\/ Optional — for custom indicator styles","import FlyIndicatorHUD","","\/\/ Optional — for custom progress styles","import FlyProgressHUD"]},{"anchor":"Layer-1-UIKit-Bridge","level":2,"type":"heading","text":"Layer 1: UIKit Bridge"},{"inlineContent":[{"type":"text","text":"For maximum control, use "},{"type":"codeVoice","code":".hudHost()"},{"type":"text","text":" to obtain a backing UIView, then call UIKit APIs directly:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct MyView: View {","    @State private var hostView: UIView?","","    var body: some View {","        VStack {","            Button(\"Show HUD\") {","                guard let view = hostView else { return }","                HUD.show(to: view, mode: .indicator(), label: \"Loading...\")","            }","            Button(\"Hide HUD\") {","                guard let view = hostView else { return }","                HUD.hide(for: view)","            }","        }","        .hudHost($hostView)","    }","}"]},{"inlineContent":[{"text":"This pattern gives you full access to the HUD instance and all configuration options.","type":"text"}],"type":"paragraph"},{"anchor":"Layer-2-Declarative-Modifiers","level":2,"type":"heading","text":"Layer 2: Declarative Modifiers"},{"anchor":"Boolean-Driven-HUD","level":3,"type":"heading","text":"Boolean-Driven HUD"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Toggle a HUD by binding a Boolean:"}]},{"type":"codeListing","syntax":"swift","code":["struct DownloadView: View {","    @State private var isLoading = false","","    var body: some View {","        Button(\"Download\") {","            isLoading = true","            startDownload { isLoading = false }","        }","        .hud(isPresented: $isLoading) { hud in","            hud.contentView.mode = .indicator()","            hud.contentView.label.text = \"Downloading...\"","        }","    }","}"]},{"type":"heading","text":"Item-Driven HUD","anchor":"Item-Driven-HUD","level":3},{"type":"paragraph","inlineContent":[{"text":"Present different HUD states based on an ","type":"text"},{"code":"Identifiable","type":"codeVoice"},{"text":" item:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct HUDItem: Identifiable {","    let id = UUID()","    let mode: ContentView.Mode","    let label: String","}","","struct TaskView: View {","    @State private var hudItem: HUDItem?","","    var body: some View {","        Button(\"Start\") {","            hudItem = HUDItem(mode: .indicator(), label: \"Working...\")","        }","        .hud(item: $hudItem) { item, hud in","            hud.contentView.mode = item.mode","            hud.contentView.label.text = item.label","        }","    }","}"]},{"type":"heading","text":"Self-Dismissing Status","anchor":"Self-Dismissing-Status","level":3},{"type":"paragraph","inlineContent":[{"text":"Show a toast that automatically hides after a duration:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct SaveView: View {","    @State private var showSaved = false","","    var body: some View {","        Button(\"Save\") {","            save()","            showSaved = true","        }","        .hudStatus(isPresented: $showSaved, duration: 2.0) { hud in","            hud.contentView.mode = .text","            hud.contentView.label.text = \"Saved!\"","        }","    }","}"]},{"type":"heading","text":"Layer 3: Convenience Presets","anchor":"Layer-3-Convenience-Presets","level":2},{"type":"heading","text":"Loading Indicator","anchor":"Loading-Indicator","level":3},{"type":"codeListing","syntax":"swift","code":["MyView()","    .hudLoading(isPresented: $isLoading, label: \"Please wait...\")"]},{"type":"heading","text":"Toast Message","anchor":"Toast-Message","level":3},{"type":"codeListing","syntax":"swift","code":["MyView()","    .hudToast(isPresented: $showToast, duration: 1.5, label: \"File deleted\")"]},{"type":"heading","text":"Progress Tracking","anchor":"Progress-Tracking","level":3},{"type":"codeListing","syntax":"swift","code":["struct UploadView: View {","    @State private var isUploading = false","    @State private var progress: Float = 0","","    var body: some View {","        Button(\"Upload\") { startUpload() }","            .hudProgress(isPresented: $isUploading, progress: $progress, label: \"Uploading\")","    }","}"]},{"type":"heading","text":"Layer 4: Liquid Glass (iOS 26+)","anchor":"Layer-4-Liquid-Glass-iOS-26+","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"On iOS 26 and later, use the glass style for a modern translucent appearance:"}]},{"type":"codeListing","syntax":"swift","code":["MyView()","    .hudGlass(isPresented: $isLoading, label: \"Loading...\")"]},{"type":"aside","name":"Important","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":".hudGlass()"},{"type":"text","text":" is only available when compiling with Swift 6.2+ and targeting iOS 26.0 or tvOS 26.0."}],"type":"paragraph"}],"style":"important"},{"type":"heading","text":"Animation Customization","anchor":"Animation-Customization","level":2},{"type":"paragraph","inlineContent":[{"text":"All declarative modifiers accept an ","type":"text"},{"code":"animation","type":"codeVoice"},{"text":" parameter:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":[".hud(isPresented: $isLoading, animation: .init(.zoomInOut, damping: .default)) { hud in","    hud.contentView.mode = .indicator()","}"]},{"type":"heading","text":"Migration from UIKit Bridge","anchor":"Migration-from-UIKit-Bridge","level":2},{"inlineContent":[{"type":"text","text":"If you previously used a local "},{"type":"codeVoice","code":"HUDHostView"},{"type":"text","text":" helper, you can now:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Replace ","type":"text"},{"code":"import FlyHUD","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"import FlyHUDSwiftUI","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Remove your local "},{"code":"HUDHostView","type":"codeVoice"},{"type":"text","text":", "},{"code":"HUDContainerModifier","type":"codeVoice"},{"type":"text","text":", and "},{"code":"hudHost()","type":"codeVoice"},{"type":"text","text":" definitions"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":".hudHost($hostView)"},{"type":"text","text":" API is now provided by the SDK"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"text":"For new code, prefer the declarative modifiers (Layer 2\/3) over ","type":"text"},{"code":".hudHost()","type":"codeVoice"},{"text":" for cleaner state management.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Best Practices","anchor":"Best-Practices","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"One HUD per view hierarchy","type":"tex