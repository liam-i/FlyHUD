graph TB
    subgraph "VoiceOver Focus"
        CV["ContentView<br/>(isAccessibilityElement = true)"]
    end

    subgraph "Hidden from Accessibility"
        LBL["Label<br/>(isAccessibilityElement = false)"]
        DET["detailsLabel<br/>(isAccessibilityElement = false)"]
        BTN["Button<br/>(isAccessibilityElement = false)"]
        IND["ActivityIndicatorView<br/>(isAccessibilityElement = false)"]
        PRG["ProgressView<br/>(isAccessibilityElement = false)"]
        BG["BackgroundView<br/>(accessibilityElementsHidden = true)"]
    end

    subgraph "HUD Container"
        HUD["HUD<br/>(accessibilityViewIsModal = true)"]
    end

    HUD --> BG
    HUD --> CV
    CV -->|"accessibilityLabel"| LBL
    CV -->|"accessibilityLabel"| DET
    CV -->|"accessibilityCustomActions"| BTN
    CV -->|"accessibilityTraits"| IND
    CV -->|"accessibilityValue"| PRG

    style CV fill:#4A90D9,stroke:#2E6EA6,color:#fff
    style HUD fill:#50C878,stroke:#30A858,color:#fff
    style LBL fill:#E8E8E8,stroke:#AAAAAA,color:#333
    style DET fill:#E8E8E8,stroke:#AAAAAA,color:#333
    style BTN fill:#E8E8E8,stroke:#AAAAAA,color:#333
    style IND fill:#E8E8E8,stroke:#AAAAAA,color:#333
    style PRG fill:#E8E8E8,stroke:#AAAAAA,color:#333
    style BG fill:#E8E8E8,stroke:#AAAAAA,color:#333
